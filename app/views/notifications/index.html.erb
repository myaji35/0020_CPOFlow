<% content_for :page_title, "알림" %>

<div class="flex flex-col gap-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">알림 센터</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        <% if @unread_count > 0 %>
          읽지 않은 알림 <span class="font-semibold text-primary"><%= @unread_count %>건</span>
        <% else %>
          모두 확인했습니다
        <% end %>
      </p>
    </div>
    <% if @unread_count > 0 %>
      <%= button_to "모두 읽음", read_all_notifications_path, method: :patch,
          class: "text-xs text-primary hover:underline bg-transparent border-0 cursor-pointer" %>
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
    <% if @notifications.any? %>
      <% @notifications.each do |n| %>
        <div class="flex items-start gap-3 px-5 py-4 border-b border-gray-50 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors <%= n.read? ? 'opacity-60' : '' %>">
          <%# 알림 타입 아이콘 %>
          <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0
            <%= case n.notification_type
                when 'due_date'        then 'bg-red-100 dark:bg-red-900/30'
                when 'status_changed'  then 'bg-blue-100 dark:bg-blue-900/30'
                when 'assigned'        then 'bg-green-100 dark:bg-green-900/30'
                else 'bg-gray-100 dark:bg-gray-700'
                end %>">
            <svg class="w-4 h-4 <%= case n.notification_type
                when 'due_date'       then 'text-red-600 dark:text-red-400'
                when 'status_changed' then 'text-blue-600 dark:text-blue-400'
                when 'assigned'       then 'text-green-600 dark:text-green-400'
                else 'text-gray-500'
                end %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <% case n.notification_type
                 when 'due_date' %>
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
              <% when 'assigned' %>
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
              <% else %>
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
              <% end %>
            </svg>
          </div>

          <%# 내용 %>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <p class="text-sm font-medium text-gray-900 dark:text-white <%= n.read? ? '' : 'font-semibold' %>">
                <%= n.title %>
              </p>
              <span class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap">
                <%= n.created_at.strftime("%m/%d %H:%M") %>
              </span>
            </div>
            <% if n.body.present? %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 truncate"><%= n.body %></p>
            <% end %>
            <% if n.notifiable.is_a?(Order) %>
              <%= link_to "주문 보기 →", order_path(n.notifiable),
                  class: "text-xs text-primary hover:underline mt-1 inline-block" %>
            <% end %>
          </div>

          <%# 읽음 처리 %>
          <% unless n.read? %>
            <%= button_to read_notification_path(n), method: :patch,
                class: "text-gray-300 hover:text-primary transition-colors bg-transparent border-0 cursor-pointer p-1",
                title: "읽음 처리" do %>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="p-12 text-center">
        <svg class="w-10 h-10 mx-auto text-gray-200 dark:text-gray-600 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <p class="text-sm text-gray-400 dark:text-gray-500">알림이 없습니다</p>
      </div>
    <% end %>
  </div>
</div>
