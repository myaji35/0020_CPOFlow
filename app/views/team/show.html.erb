<% content_for :title, @member.name %>

<div class="flex flex-col gap-6">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to team_index_path, class: "text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      <% end %>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center text-primary font-bold text-lg">
          <%= @member.name.first.upcase %>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @member.name %></h1>
          <div class="flex items-center gap-2 mt-0.5">
            <span class="text-xs px-2 py-0.5 rounded-full <%= @member.role == 'admin' ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400' : @member.role == 'manager' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400' %>">
              <%= { 'admin' => '관리자', 'manager' => '매니저', 'member' => '멤버' }[@member.role] %>
            </span>
            <span class="text-sm text-gray-500 dark:text-gray-400"><%= @member.email %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# 상태별 통계 뱃지 %>
  <% if @status_counts.any? %>
    <div class="flex flex-wrap gap-2">
      <% Order.statuses.keys.each do |status_key| %>
        <% count = @status_counts[status_key] || 0 %>
        <% next if count == 0 %>
        <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium">
          <%= Order::STATUS_LABELS[status_key] %>
          <span class="bg-white dark:bg-gray-600 text-gray-800 dark:text-gray-200 px-1.5 py-0.5 rounded-full text-xs font-bold leading-none"><%= count %></span>
        </span>
      <% end %>
    </div>
  <% end %>

  <%# 진행 중 주문 %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300">진행 중 주문 (<%= @active_orders.count %>건)</h2>
    </div>
    <% if @active_orders.any? %>
      <div class="divide-y divide-gray-50 dark:divide-gray-700">
        <% @active_orders.each do |order| %>
          <div class="flex items-center justify-between px-5 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
            <div>
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= order.title %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= order.customer_name %></p>
            </div>
            <div class="flex items-center gap-3">
              <% if order.due_date %>
                <span class="text-xs text-gray-400 dark:text-gray-500"><%= order.due_date.strftime("%m/%d") %></span>
              <% end %>
              <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
                <%= Order::STATUS_LABELS[order.status] %>
              </span>
              <%= link_to "보기", order_path(order), class: "text-xs text-primary hover:underline" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-8 text-center text-sm text-gray-400 dark:text-gray-500">진행 중인 주문이 없습니다.</div>
    <% end %>
  </div>
</div>
