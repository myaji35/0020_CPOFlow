<% content_for :title, @supplier.name %>

<div class="flex flex-col gap-6">
  <!-- Header -->
  <div class="flex items-start justify-between">
    <div>
      <div class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500 mb-1">
        <%= link_to "거래처 관리", suppliers_path, class: "hover:text-primary" %>
        <span>/</span>
        <span><%= @supplier.name %></span>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @supplier.name %></h1>
      <div class="flex items-center gap-3 mt-2 text-sm text-gray-500 dark:text-gray-400">
        <span><%= @supplier.country %></span>
        <% if @supplier.industry.present? %><span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400"><%= @supplier.industry_label %></span><% end %>
        <% if @supplier.credit_grade.present? %><span class="text-xs font-bold"><%= @supplier.credit_grade %>등급</span><% end %>
        <% if @supplier.payment_terms.present? %><span><%= @supplier.payment_terms %></span><% end %>
        <% if @supplier.lead_time_days.present? %><span>리드타임 <%= @supplier.lead_time_days %>일</span><% end %>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_supplier_path(@supplier), class: "inline-flex items-center gap-1 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 px-3 py-2 rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-700" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        수정
      <% end %>
    </div>
  </div>

  <!-- KPI -->
  <% perf_color = { "A" => "bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400",
                    "B" => "bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400",
                    "C" => "bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400",
                    "D" => "bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400" } %>
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">총 공급 오더</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @orders.count %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">총 공급 금액</p>
      <p class="text-xl font-bold text-primary mt-1">$<%= number_with_delimiter(@supplier.total_supply_value.round.to_i) %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">납품 품목</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @supplier_products.count %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">납기준수율</p>
      <% if @on_time_rate %>
        <% rate_color = @on_time_rate >= 90 ? 'text-green-600 dark:text-green-400' : (@on_time_rate >= 75 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400') %>
        <p class="text-2xl font-bold <%= rate_color %> mt-1"><%= @on_time_rate %>%</p>
      <% else %>
        <p class="text-2xl font-bold text-gray-300 dark:text-gray-600 mt-1">-</p>
      <% end %>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">성과 등급</p>
      <% if @performance_grade && @performance_grade != "N/A" %>
        <p class="mt-1"><span class="inline-flex px-3 py-1 text-xl font-bold rounded-lg <%= perf_color[@performance_grade] %>"><%= @performance_grade %></span></p>
      <% else %>
        <p class="text-2xl font-bold text-gray-300 dark:text-gray-600 mt-1">-</p>
      <% end %>
    </div>
  </div>

  <!-- 탭 -->
  <div x-data="{ tab: 'contacts' }" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
    <div class="border-b border-gray-100 dark:border-gray-700 px-4">
      <nav class="flex gap-6">
        <button @click="tab='contacts'" :class="tab==='contacts' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">담당자</button>
        <button @click="tab='products'" :class="tab==='products' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">납품 품목</button>
        <button @click="tab='orders'" :class="tab==='orders' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">납품 이력</button>
      </nav>
    </div>

    <div x-show="tab==='contacts'" class="p-4">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium text-gray-900 dark:text-white">담당자 목록</h3>
        <%= link_to new_supplier_contact_person_path(@supplier), class: "inline-flex items-center gap-1 text-sm text-primary hover:underline" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          담당자 추가
        <% end %>
      </div>
      <div class="space-y-3">
        <% @contact_persons.each do |cp| %>
          <div class="flex items-center justify-between p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:border-primary/30 transition-colors">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-700 dark:text-purple-400 font-bold text-sm"><%= cp.name.first.upcase %></div>
              <div>
                <div class="font-medium text-sm text-gray-900 dark:text-white"><%= cp.display_name %> <span class="text-xs text-gray-400 dark:text-gray-500 ml-1"><%= cp.language_label %></span></div>
                <p class="text-xs text-gray-500 dark:text-gray-400"><%= cp.title %></p>
                <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                  <%= cp.email %> <% if cp.phone.present? %> | <%= cp.phone %><% end %>
                </div>
              </div>
            </div>
            <div class="flex gap-2">
              <%= link_to edit_supplier_contact_person_path(@supplier, cp), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-primary" do %>수정<% end %>
              <%= link_to supplier_contact_person_path(@supplier, cp), data: { turbo_method: :delete, turbo_confirm: "삭제?" }, class: "text-xs text-gray-400 dark:text-gray-500 hover:text-red-500" do %>삭제<% end %>
            </div>
          </div>
        <% end %>
        <% if @contact_persons.empty? %><p class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">등록된 담당자가 없습니다.</p><% end %>
      </div>
    </div>

    <div x-show="tab==='products'" class="p-4">
      <h3 class="font-medium text-gray-900 dark:text-white mb-4">납품 가능 품목</h3>
      <div class="space-y-2">
        <% @supplier_products.each do |sp| %>
          <div class="flex items-center justify-between p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:border-primary/30 transition-colors">
            <span class="text-sm font-medium text-gray-900 dark:text-white"><%= sp.product.name %></span>
            <div class="flex items-center gap-4">
              <span class="text-sm text-gray-600 dark:text-gray-400"><%= sp.display_price %></span>
              <% if sp.lead_time_days.present? %><span class="text-xs text-gray-400 dark:text-gray-500"><%= sp.lead_time_days %>일</span><% end %>
            </div>
          </div>
        <% end %>
        <% if @supplier_products.empty? %><p class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">등록된 납품 품목이 없습니다.</p><% end %>
      </div>
    </div>

    <div x-show="tab==='orders'" class="p-4">
      <!-- FR-03: 상태별 분포 + 납기준수율 -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <!-- 상태별 뱃지 바 -->
        <% status_colors = { "inbox"=>"bg-gray-400","reviewing"=>"bg-blue-400","quoted"=>"bg-yellow-400","confirmed"=>"bg-indigo-400","procuring"=>"bg-orange-400","qa"=>"bg-purple-400","delivered"=>"bg-green-500" } %>
        <% status_labels = { "inbox"=>"접수","reviewing"=>"검토중","quoted"=>"견적","confirmed"=>"확정","procuring"=>"조달","qa"=>"QA","delivered"=>"납품" } %>
        <div class="flex flex-wrap gap-1.5">
          <% @order_status_counts.each do |status, cnt| %>
            <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full text-white <%= status_colors[status] || 'bg-gray-400' %>">
              <%= status_labels[status] || status %> <strong><%= cnt %></strong>
            </span>
          <% end %>
        </div>
        <!-- 납기준수율 -->
        <% if @on_time_rate %>
          <% rate_cls = @on_time_rate >= 90 ? 'text-green-600 dark:text-green-400' : @on_time_rate >= 75 ? 'text-orange-500 dark:text-orange-400' : 'text-red-500 dark:text-red-400' %>
          <div class="ml-auto flex items-center gap-1.5 bg-gray-50 dark:bg-gray-700/50 rounded-lg px-3 py-1">
            <svg class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span class="text-xs text-gray-500 dark:text-gray-400">납기준수율</span>
            <span class="text-sm font-bold <%= rate_cls %>"><%= @on_time_rate %>%</span>
          </div>
        <% end %>
      </div>

      <!-- 기간/정렬 필터 -->
      <%= form_with url: supplier_path(@supplier), method: :get, local: true, class: "flex flex-wrap gap-2 mb-4" do |f| %>
        <select name="period" onchange="this.form.submit()" class="text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:outline-none">
          <option value="" <%= params[:period].blank? ? 'selected' : '' %>>전체 기간</option>
          <option value="this_month" <%= params[:period]=="this_month" ? 'selected' : '' %>>이번 달</option>
          <option value="3months"    <%= params[:period]=="3months"    ? 'selected' : '' %>>최근 3개월</option>
          <option value="this_year"  <%= params[:period]=="this_year"  ? 'selected' : '' %>>올해</option>
        </select>
        <select name="sort" onchange="this.form.submit()" class="text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:outline-none">
          <option value="due_date" <%= (params[:sort].blank? || params[:sort]=="due_date") ? 'selected' : '' %>>납기일순</option>
          <option value="value"    <%= params[:sort]=="value"    ? 'selected' : '' %>>금액순</option>
          <option value="recent"   <%= params[:sort]=="recent"   ? 'selected' : '' %>>최신순</option>
        </select>
        <% if params[:period].present? || params[:sort].present? %>
          <%= link_to "초기화", supplier_path(@supplier), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-primary px-2 py-1.5" %>
        <% end %>
        <span class="ml-auto text-xs text-gray-400 dark:text-gray-500 self-center">총 <%= @orders.count %>건</span>
      <% end %>

      <!-- 납품 이력 목록 -->
      <div class="space-y-2">
        <% @orders.each do |order| %>
          <%
            days = order.due_date ? (order.due_date - Date.today).to_i : nil
            row_cls = if order.status == "delivered"
                        "border-green-100 dark:border-green-900/30"
                      elsif days && days < 0
                        "border-red-200 dark:border-red-800/50 bg-red-50/40 dark:bg-red-900/10"
                      elsif days && days <= 7
                        "border-orange-200 dark:border-orange-800/50 bg-orange-50/40 dark:bg-orange-900/10"
                      else
                        "border-gray-100 dark:border-gray-700"
                      end
            due_cls = if days.nil? then "text-gray-400 dark:text-gray-500"
                      elsif days < 0 then "text-red-600 dark:text-red-400 font-bold"
                      elsif days <= 7 then "text-orange-600 dark:text-orange-400 font-medium"
                      elsif days <= 14 then "text-yellow-600 dark:text-yellow-400"
                      else "text-green-600 dark:text-green-400"
                      end
          %>
          <div class="flex items-center justify-between p-3 border rounded-lg hover:border-primary/30 transition-colors <%= row_cls %>">
            <div class="flex-1 min-w-0 mr-3">
              <div class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= order.title %></div>
              <% if order.client.present? || order.project.present? %>
                <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5 truncate">
                  <% if order.client.present? %><%= link_to order.client.name, order.client, class: "hover:text-primary" %><% end %>
                  <% if order.project.present? %><span class="mx-1">·</span><%= order.project.name %><% end %>
                </div>
              <% end %>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <% if order.due_date.present? %>
                <span class="text-xs <%= due_cls %>">
                  <%= order.due_date.strftime("%m/%d") %>
                  <% if days %><span class="ml-0.5"><%= days < 0 ? "D+#{-days}" : "D-#{days}" %></span><% end %>
                </span>
              <% end %>
              <% if order.estimated_value.present? %>
                <span class="text-xs font-medium text-gray-700 dark:text-gray-300">$<%= number_with_delimiter(order.estimated_value.round.to_i) %></span>
              <% end %>
              <span class="text-xs px-2 py-0.5 rounded-full text-white <%= status_colors[order.status] || 'bg-gray-400' %>">
                <%= status_labels[order.status] || order.status %>
              </span>
              <%= link_to "상세", order, class: "text-xs text-primary hover:underline" %>
            </div>
          </div>
        <% end %>
        <% if @orders.empty? %>
          <p class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">납품 이력이 없습니다.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
