<%# 코멘트 작성 폼 — turbo_stream.replace로 초기화 %>
<div id="comment-form-<%= order.id %>">
  <%= form_with url: order_comments_path(order), method: :post, class: "flex gap-3" do |f| %>
    <div class="w-7 h-7 rounded-full bg-primary text-white text-xs flex items-center justify-center font-bold shrink-0 mt-0.5">
      <%= current_user.initials %>
    </div>
    <div class="flex-1 space-y-2"
         data-controller="mention"
         data-mention-mode-value="comment"
         data-mention-url-value="<%= mention_suggestions_path %>">
      <%= f.text_area :body, placeholder: "코멘트를 입력하세요... (@ 로 팀원 멘션)", rows: 2,
          class: "w-full px-3 py-2 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg text-sm focus:ring-2 focus:ring-accent/30 outline-none resize-none",
          data: { mention_target: "input", action: "input->mention#onInput" } %>
      <%# 멘션 드롭다운 (JS가 fixed 위치로 제어) %>
      <div data-mention-target="dropdown"
           class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg overflow-hidden"
           style="display:none"></div>
      <div class="flex items-center justify-between">
        <span class="text-xs text-gray-400">@ 로 팀원 멘션 가능</span>
        <%= f.submit "등록",
            class: "bg-accent text-white text-sm px-4 py-1.5 rounded-lg hover:bg-accent/90 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
