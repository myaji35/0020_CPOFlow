<%# Inbox -- Gmail-style 3-pane layout (Production-ready) %>

<style>
  .inbox-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    height: calc(100vh - 56px);
    overflow: hidden;
  }
  .inbox-main {
    display: grid;
    grid-template-columns: 360px 1fr;
    overflow: hidden;
  }
  .inbox-list { overflow-y: auto; }
  .inbox-body { overflow-y: auto; }
  .email-item.active { background-color: rgba(0, 161, 224, 0.08); }
  .email-item.active.dark-active { background-color: rgba(0, 161, 224, 0.15); }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .inbox-search:focus { outline: none; box-shadow: 0 0 0 2px rgba(0, 161, 224, 0.3); }
  .email-tab-btn { cursor: pointer; background: transparent; }
  .email-tab-btn.active-tab {
    color: #00A1E0;
    border-color: #00A1E0;
    background: #fff;
    margin-bottom: -1px;
  }
  .dark .email-tab-btn.active-tab { background: #111827; }
  .email-tab-panel.hidden { display: none; }
  /* HTML 이메일 렌더링 스타일 */
  .email-html-body { font-size: 0.875rem; color: #374151; line-height: 1.6; }
  .email-html-body a { color: #00A1E0; text-decoration: underline; }
  .email-html-body img { max-width: 100%; height: auto; }
  .email-html-body table { border-collapse: collapse; max-width: 100%; }
  .email-html-body blockquote { border-left: 3px solid #e5e7eb; padding-left: 0.75rem; margin-left: 0; color: #6b7280; }
  .dark .email-html-body { color: #d1d5db; }
  .dark .email-html-body a { color: #38bdf8; }
  /* 미리보기 모달 */
  .preview-modal-backdrop { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; }
  .preview-modal-content { background: #fff; border-radius: 0.75rem; width: 90vw; height: 85vh; max-width: 1200px; display: flex; flex-direction: column; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }
  .dark .preview-modal-content { background: #1f2937; }
  .preview-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; border-bottom: 1px solid #e5e7eb; flex-shrink: 0; }
  .dark .preview-modal-header { border-color: #374151; }
  .preview-modal-iframe { flex: 1; border: none; border-radius: 0 0 0.75rem 0.75rem; width: 100%; }
  /* 발신자 로고 */
  .sender-avatar-img { width: 2rem; height: 2rem; border-radius: 9999px; object-fit: cover; }
</style>

<div class="inbox-layout">

  <%# ===== PANE 1: Folder / Filter sidebar ===== %>
  <div class="border-r border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 overflow-y-auto flex flex-col">
    <div class="p-4 flex-1">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-2 mb-2">
        받은편지함
      </p>
      <nav class="space-y-1">
        <%# All Emails %>
        <a href="<%= inbox_path %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'all' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          전체 메일
          <span class="ml-auto text-xs bg-gray-200 dark:bg-gray-600 text-gray-600 dark:text-gray-300 rounded-full px-2 py-0.5">
            <%= @count_all %>
          </span>
        </a>

        <%# RFQ Only (inbox status) %>
        <a href="<%= inbox_path(filter: 'rfq') %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'rfq' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          RFQ 대기
          <% if @count_rfq > 0 %>
            <span class="ml-auto text-xs bg-blue-600 text-white rounded-full px-2 py-0.5">
              <%= @count_rfq %>
            </span>
          <% end %>
        </a>

        <%# Uncertain — AI 판정 불확실 %>
        <a href="<%= inbox_path(filter: 'uncertain') %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'uncertain' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          확인 필요
          <% if @count_uncertain.to_i > 0 %>
            <span class="ml-auto text-xs bg-red-500 text-white rounded-full px-2 py-0.5 font-bold">
              <%= @count_uncertain %>
            </span>
          <% end %>
        </a>

        <%# Converted (non-inbox status) %>
        <a href="<%= inbox_path(filter: 'converted') %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'converted' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          처리 완료
          <% if @count_converted > 0 %>
            <span class="ml-auto text-xs bg-green-600 text-white rounded-full px-2 py-0.5">
              <%= @count_converted %>
            </span>
          <% end %>
        </a>
      </nav>

      <%# Connected accounts %>
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-2 mb-2 mt-8">
        연결된 계정
      </p>
      <% accounts = current_user.email_accounts.where(connected: true) %>
      <% if accounts.any? %>
        <% accounts.each do |acc| %>
          <div class="px-3 py-2 rounded-lg text-xs text-gray-600 dark:text-gray-400 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></span>
            <span class="truncate"><%= acc.email %></span>
          </div>
        <% end %>
      <% else %>
        <div class="px-3 py-3 text-xs text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-700/50 rounded-lg">
          <p class="mb-1">Gmail 계정이 연결되지 않았습니다.</p>
          <%= link_to settings_root_path, class: "text-blue-500 hover:underline font-medium" do %>
            설정에서 연결하기
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 inline ml-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ===== PANE 2 + 3 ===== %>
  <div class="inbox-main">

    <%# ===== PANE 2: Email list ===== %>
    <div class="inbox-list border-r border-gray-200 dark:border-gray-700 flex flex-col">
      <%# Toolbar with search %>
      <div class="sticky top-0 z-10 bg-white dark:bg-gray-800 border-b border-gray-100 dark:border-gray-700">
        <%# Header row %>
        <div class="px-4 py-3 flex items-center justify-between">
          <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">
            <% case @current_filter
               when "rfq" %>RFQ 대기 메일
            <% when "converted" %>처리된 메일
            <% else %>전체 메일
            <% end %>
          </span>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 dark:text-gray-500"><%= @total_filtered %>건</span>
            <span id="auto-sync-countdown"
                  data-has-account="<%= current_user.email_accounts.where(connected: true).any? %>"
                  class="text-xs text-gray-400 dark:text-gray-500 tabular-nums flex items-center gap-1"></span>
            <button onclick="triggerSync()" id="sync-btn"
                    class="text-xs px-3 py-1.5 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400 flex items-center gap-1 transition-colors">
              <svg id="sync-icon" xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              동기화
            </button>
          </div>
        </div>

        <%# Search bar %>
        <div class="px-4 pb-3">
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text"
                   id="inbox-search"
                   class="inbox-search w-full pl-9 pr-8 py-2 text-sm border border-gray-200 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700/50 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500"
                   placeholder="이메일 검색 (제목, 발신자, 고객명)..."
                   value="<%= @search_query %>"
                   oninput="handleSearch(this.value)">
            <% if @search_query.present? %>
              <button onclick="clearSearch()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <%# Email list items — reference_no 기준 그룹 뷰 %>
      <% status_colors = {
        "inbox"     => "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400",
        "reviewing" => "bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400",
        "quoted"    => "bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-400",
        "confirmed" => "bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-400",
        "procuring" => "bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400",
        "qa"        => "bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-400",
        "delivered" => "bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400"
      } %>
      <% confidence_colors = { "high" => "bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400", "medium" => "bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-500", "low" => "bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400" } %>
      <% confidence_labels = { "high" => "확실", "medium" => "가능성", "low" => "낮음" } %>

      <div class="flex-1 overflow-y-auto">
        <% if @all_orders.any? %>
          <ul id="email-list" class="divide-y divide-gray-100 dark:divide-gray-700">
            <% @grouped_orders.each do |ref_key, group_orders| %>
              <% is_thread = !ref_key.start_with?("single_") && group_orders.size > 1 %>
              <% latest = group_orders.max_by(&:created_at) %>

              <% if is_thread %>
                <%# ===== 그룹 헤더 (Alpine.js fold/unfold) ===== %>
                <li x-data="{ open: false }" class="border-b border-gray-100 dark:border-gray-700">
                  <%# 그룹 헤더 행 %>
                  <div class="flex items-center gap-2 px-4 py-3 cursor-pointer hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors select-none"
                       @click="open = !open">
                    <%# 토글 화살표 %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue-500 flex-shrink-0 transition-transform duration-150"
                         :class="open ? 'rotate-90' : ''"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 18 15 12 9 6"/>
                    </svg>
                    <%# 발주번호 뱃지 %>
                    <span class="text-[11px] font-mono font-semibold text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/40 px-2 py-0.5 rounded flex-shrink-0">
                      <%= ref_key %>
                    </span>
                    <%# 고객명 + 건수 %>
                    <span class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate flex-1">
                      <%= latest.customer_name %>
                    </span>
                    <span class="text-[11px] bg-gray-200 dark:bg-gray-600 text-gray-600 dark:text-gray-300 rounded-full px-2 py-0.5 font-semibold flex-shrink-0">
                      <%= group_orders.size %>건
                    </span>
                    <%# 최신 날짜 %>
                    <span class="text-[11px] text-gray-400 dark:text-gray-500 flex-shrink-0">
                      <%= latest.created_at.strftime("%m/%d") %>
                    </span>
                  </div>
                  <%# 펼침 시 개별 메일 목록 %>
                  <div x-show="open" x-transition:enter="transition ease-out duration-150"
                       x-transition:enter-start="opacity-0 -translate-y-1"
                       x-transition:enter-end="opacity-100 translate-y-0"
                       class="bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700">
                    <% group_orders.sort_by(&:created_at).each do |order| %>
                      <div class="email-item cursor-pointer px-4 py-2.5 pl-10 hover:bg-white dark:hover:bg-gray-700/50 transition-colors border-b border-gray-100 dark:border-gray-700 last:border-0"
                           onclick="showEmail(<%= order.id %>)"
                           data-order-id="<%= order.id %>"
                           id="email-item-<%= order.id %>">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold <%= status_colors[order.status] || 'bg-gray-100 text-gray-600' %>">
                            <%= Order::STATUS_LABELS[order.status] || order.status.humanize %>
                          </span>
                          <% if order.rfq_status == "rfq_excluded" %>
                            <span class="text-[10px] px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 rounded">스레드 추가</span>
                          <% end %>
                          <span class="ml-auto text-[11px] text-gray-400 dark:text-gray-500 flex-shrink-0">
                            <%= order.created_at.strftime("%m/%d %H:%M") %>
                          </span>
                        </div>
                        <p class="text-xs text-gray-700 dark:text-gray-300 truncate font-medium">
                          <%= order.original_email_subject.presence || order.title %>
                        </p>
                        <p class="text-[11px] text-gray-400 dark:text-gray-500 truncate mt-0.5">
                          <%= order.original_email_from.presence || order.customer_name %>
                        </p>
                      </div>
                    <% end %>
                  </div>
                </li>

              <% else %>
                <%# ===== 단건 메일 (기존 방식) ===== %>
                <% order = group_orders.first %>
                <li class="email-item cursor-pointer px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
                    onclick="showEmail(<%= order.id %>)"
                    data-order-id="<%= order.id %>"
                    id="email-item-<%= order.id %>">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold <%= status_colors[order.status] || 'bg-gray-100 text-gray-600' %>">
                      <%= Order::STATUS_LABELS[order.status] || order.status.humanize %>
                    </span>
                    <% if order.respond_to?(:rfq_status) %>
                      <% case order.rfq_status
                         when "rfq_confirmed" %>
                        <span class="text-[10px] px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 rounded font-medium">RFQ</span>
                      <% when "rfq_uncertain" %>
                        <span class="text-[10px] px-1.5 py-0.5 bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400 rounded font-semibold border border-yellow-200 dark:border-yellow-800">AI 불확실</span>
                      <% when "rfq_excluded" %>
                        <span class="text-[10px] px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 rounded font-medium">일반메일</span>
                      <% end %>
                    <% end %>
                    <% case order.priority
                       when "urgent" %>
                      <span class="w-2 h-2 rounded-full bg-red-500 flex-shrink-0" title="긴급"></span>
                    <% when "high" %>
                      <span class="w-2 h-2 rounded-full bg-orange-400 flex-shrink-0" title="높음"></span>
                    <% end %>
                    <span class="ml-auto text-[11px] text-gray-400 dark:text-gray-500 flex-shrink-0">
                      <%= order.created_at.strftime("%m/%d") %>
                    </span>
                  </div>
                  <p class="text-sm text-gray-900 dark:text-white truncate font-medium">
                    <%= order.original_email_subject.presence || order.title %>
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400 truncate mt-0.5">
                    <%= order.original_email_from.presence || order.customer_name %>
                  </p>
                  <% if order.description.present? %>
                    <p class="text-xs text-gray-400 dark:text-gray-500 truncate mt-0.5">
                      <%= order.description.truncate(80) %>
                    </p>
                  <% end %>
                  <% conf = order.respond_to?(:rfq_confidence) ? order.rfq_confidence.to_s : "" %>
                  <div class="mt-1.5 flex items-center gap-1.5 flex-wrap">
                    <% if order.due_date %>
                      <% days = order.days_until_due %>
                      <% due_class = if days && days < 0
                                       "text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20"
                                     elsif days && days <= 7
                                       "text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20"
                                     elsif days && days <= 14
                                       "text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20"
                                     else
                                       "text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20"
                                     end %>
                      <span class="inline-flex items-center gap-1 text-[10px] px-1.5 py-0.5 rounded <%= due_class %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <% if days && days < 0 %>
                          <%= days.abs %>일 초과
                        <% else %>
                          D-<%= days %>
                        <% end %>
                      </span>
                    <% end %>
                    <% if conf.in?(%w[high medium low]) %>
                      <span class="text-[10px] px-1.5 py-0.5 rounded <%= confidence_colors[conf] %> font-medium flex-shrink-0">
                        <%= confidence_labels[conf] %>
                      </span>
                    <% end %>
                  </div>
                </li>
              <% end %>
            <% end %>
          </ul>
          <%# Pagination %>
          <% if @total_pages > 1 %>
            <div class="flex items-center justify-between px-4 py-2.5 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/30">
              <span class="text-xs text-gray-400 dark:text-gray-500">
                <%= (@page - 1) * InboxController::PER_PAGE + 1 %>–<%= [ @page * InboxController::PER_PAGE, @total_filtered ].min %>
                / <%= @total_filtered %>건
              </span>
              <div class="flex items-center gap-1">
                <% if @page > 1 %>
                  <a href="<%= inbox_path(filter: @current_filter == 'all' ? nil : @current_filter, q: @search_query.presence, page: @page - 1) %>"
                     class="px-2.5 py-1 text-xs text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                    <svg class="w-3 h-3 inline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  </a>
                <% end %>
                <span class="px-2 text-xs text-gray-500 dark:text-gray-400 font-medium"><%= @page %> / <%= @total_pages %></span>
                <% if @page < @total_pages %>
                  <a href="<%= inbox_path(filter: @current_filter == 'all' ? nil : @current_filter, q: @search_query.presence, page: @page + 1) %>"
                     class="px-2.5 py-1 text-xs text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                    <svg class="w-3 h-3 inline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <%# Empty state %>
          <div class="flex flex-col items-center justify-center py-20 text-center px-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-200 dark:text-gray-600 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
            <% if @search_query.present? %>
              <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">"<%= @search_query %>" 검색 결과 없음</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">다른 키워드로 검색해보세요</p>
              <button onclick="clearSearch()" class="mt-3 text-sm text-blue-600 hover:underline">검색 초기화</button>
            <% else %>
              <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">이메일이 없습니다</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Gmail 계정을 연결하면 RFQ 이메일이 자동으로 수집됩니다</p>
              <%= link_to settings_root_path, class: "mt-4 text-sm text-blue-600 hover:underline inline-flex items-center gap-1" do %>
                설정으로 이동
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ===== PANE 3: Email body (all orders, not just RFQ) ===== %>
    <div class="inbox-body bg-white dark:bg-gray-900" id="email-body-pane">
      <%# Default empty state %>
      <div id="email-empty-state" class="flex flex-col items-center justify-center h-full text-center px-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-gray-200 dark:text-gray-600 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">이메일을 선택하면 내용이 여기에 표시됩니다</p>
        <p class="text-gray-300 dark:text-gray-600 text-xs mt-1">좌측 목록에서 이메일을 클릭하세요</p>
      </div>

      <%# Email detail panels for ALL orders (not just rfq_orders) %>
      <% @all_orders.each do |order| %>
        <div id="email-detail-<%= order.id %>" class="email-detail hidden">

          <%# Email header area %>
          <div class="border-b border-gray-100 dark:border-gray-700 p-6 pb-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-lg font-bold text-gray-900 dark:text-white leading-tight">
                  <%= order.original_email_subject.presence || order.title %>
                </h2>
                <div class="flex items-center gap-2 mt-2">
                  <%# Sender avatar — 도메인 favicon 또는 이니셜 fallback %>
                  <% sender_domain = order.sender_domain.presence || order.original_email_from.to_s.match(/@([^>@\s]+)/i)&.[](1)&.strip&.downcase %>
                  <% favicon_url = sender_domain ? "https://www.google.com/s2/favicons?domain=#{sender_domain}&sz=64" : nil %>
                  <div class="w-8 h-8 rounded-full flex-shrink-0 relative overflow-hidden bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center">
                    <% if favicon_url %>
                      <img src="<%= favicon_url %>"
                           alt="<%= sender_domain %>"
                           class="sender-avatar-img"
                           onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                      <span class="text-white text-xs font-bold absolute inset-0 items-center justify-center hidden">
                        <%= order.original_email_from.presence&.first&.upcase || "?" %>
                      </span>
                    <% else %>
                      <span class="text-white text-xs font-bold">
                        <%= order.original_email_from.presence&.first&.upcase || "?" %>
                      </span>
                    <% end %>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-700 dark:text-gray-300">
                      <%= order.original_email_from.presence || order.customer_name %>
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-500">
                      <%= order.created_at.strftime("%Y년 %m월 %d일 %H:%M") %>
                    </p>
                  </div>
                </div>
              </div>

              <%# Action buttons %>
              <div class="flex items-center gap-2 flex-shrink-0">
                <%= status_badge(order) %>
                <% if order.status.to_s == "inbox" %>
                  <%= button_to convert_email_to_order_path(order),
                      data: { turbo_confirm: "칸반 보드의 'Under Review' 단계로 이동하시겠습니까?" },
                      class: "flex items-center gap-1.5 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    칸반으로 이동
                  <% end %>
                <% else %>
                  <%= link_to order_path(order), class: "flex items-center gap-1.5 px-3 py-2 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-medium rounded-lg transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    발주 상세 보기
                  <% end %>
                <% end %>
              </div>
            </div>

            <%# Metadata chips %>
            <div class="flex flex-wrap gap-2 mt-4">
              <% if order.due_date %>
                <% days = order.days_until_due %>
                <% chip_class = if days && days < 0
                                   "bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-100 dark:border-red-800"
                                 elsif days && days <= 7
                                   "bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-100 dark:border-red-800"
                                 elsif days && days <= 14
                                   "bg-orange-50 dark:bg-orange-900/20 text-orange-700 dark:text-orange-400 border-orange-100 dark:border-orange-800"
                                 else
                                   "bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 border-green-100 dark:border-green-800"
                                 end %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full border <%= chip_class %>">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  납기 <%= order.due_date.strftime("%Y/%m/%d") %>
                  <% if days && days < 0 %>
                    (<%= days.abs %>일 초과)
                  <% elsif days %>
                    (D-<%= days %>)
                  <% end %>
                </span>
              <% end %>

              <% if order.item_name.present? %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 border border-blue-100 dark:border-blue-800">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <%= order.item_name %>
                </span>
              <% end %>

              <% if order.client %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/20 text-indigo-700 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-800">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <%= order.client.name %>
                </span>
              <% end %>

              <% if order.project %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-teal-50 dark:bg-teal-900/20 text-teal-700 dark:text-teal-400 border border-teal-100 dark:border-teal-800">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                  <%= order.project.name %>
                </span>
              <% end %>

              <% order.tags_array.each do |tag| %>
                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">#<%= tag %></span>
              <% end %>
            </div>
          </div>

          <%# Key info grid %>
          <% if order.client || order.supplier || order.estimated_value.present? || order.project %>
            <div class="px-6 py-4 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700">
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                <% if order.client %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">발주처</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs"><%= order.client.name %></dd>
                  </div>
                <% end %>
                <% if order.supplier %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">거래처</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs"><%= order.supplier.name %></dd>
                  </div>
                <% end %>
                <% if order.estimated_value.present? %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">예상 금액</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs">
                      <%= number_to_currency(order.estimated_value, unit: order.currency.presence || "$", format: "%u %n") %>
                    </dd>
                  </div>
                <% end %>
                <% if order.project %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">현장</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs"><%= order.project.name %></dd>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# RFQ 판정 배너 — inbox 상태인 이메일 전체에 표시 %>
          <% if order.status.to_s == "inbox" && order.respond_to?(:rfq_status) %>
            <% rfq_s = order.rfq_status.to_s %>
            <%# RFQ 대기 필터: 이미 RFQ 판정된 목록 → "RFQ 아님" 버튼만 표시 %>
            <% show_confirmed_btn = @current_filter != 'rfq' && rfq_s != 'rfq_confirmed' %>
            <% show_rejected_btn  = rfq_s != 'rfq_excluded' %>
            <div id="feedback-banner-<%= order.id %>"
                 class="mx-6 mb-0 mt-3 px-4 py-3 rounded-lg flex items-center justify-between gap-4
                        <%= rfq_s == 'rfq_confirmed' ? 'bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800' :
                            rfq_s == 'rfq_excluded'  ? 'bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700' :
                                                       'bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800' %>">
              <div class="flex items-center gap-2 flex-1 min-w-0">
                <% if rfq_s == 'rfq_confirmed' %>
                  <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-xs text-blue-800 dark:text-blue-300 font-medium">RFQ로 확정된 이메일입니다.</span>
                <% elsif rfq_s == 'rfq_excluded' %>
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                  <span class="text-xs text-gray-600 dark:text-gray-400 font-medium">일반 메일로 처리됐습니다. 판정을 변경할 수 있습니다.</span>
                <% elsif @current_filter == 'rfq' %>
                  <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  <span class="text-xs text-blue-800 dark:text-blue-300 font-medium">RFQ 판정 이메일입니다. 아닌 경우 제외할 수 있습니다.</span>
                <% else %>
                  <svg class="w-4 h-4 text-yellow-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  <span class="text-xs text-yellow-800 dark:text-yellow-300 font-medium">AI가 이 이메일을 RFQ로 확신하지 못했습니다. 판정해주세요.</span>
                <% end %>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <% if show_confirmed_btn %>
                  <button onclick="submitFeedback(<%= order.id %>, 'confirmed', '<%= inbox_feedback_path(order.id) %>')"
                          id="feedback-confirmed-<%= order.id %>"
                          class="flex items-center gap-1.5 px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold rounded-lg transition-colors">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    RFQ 맞음
                  </button>
                <% end %>
                <% if show_rejected_btn %>
                  <button onclick="submitFeedback(<%= order.id %>, 'rejected', '<%= inbox_feedback_path(order.id) %>')"
                          id="feedback-rejected-<%= order.id %>"
                          class="flex items-center gap-1.5 px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white text-xs font-semibold rounded-lg transition-colors">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    RFQ 아님
                  </button>
                <% end %>
              </div>
            </div>
            <div id="feedback-done-<%= order.id %>" class="hidden mx-6 mb-0 mt-3 px-4 py-2.5 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
              <p class="text-xs text-green-700 dark:text-green-400 font-medium"></p>
            </div>
          <% end %>

          <%# Email body — 원문 / 번역(한글) / 답변 초안 탭 %>
          <div class="p-6" data-order-id="<%= order.id %>">
            <% plain_body = order.original_email_body.presence || order.description %>
            <% html_body  = order.respond_to?(:original_email_html_body) ? order.original_email_html_body.presence : nil %>
            <% has_body   = plain_body.present? || html_body.present? %>
            <% if has_body %>
              <%# 탭 헤더 %>
              <div class="flex items-center gap-1 mb-3 border-b border-gray-200 dark:border-gray-700">
                <button onclick="switchEmailTab(this, 'original', <%= order.id %>)"
                        class="email-tab-btn active-tab px-3 py-1.5 text-xs font-medium rounded-t-md border border-b-0 border-transparent transition-colors"
                        data-tab="original" data-order="<%= order.id %>">
                  원문
                </button>
                <button onclick="switchEmailTab(this, 'translated', <%= order.id %>)"
                        class="email-tab-btn px-3 py-1.5 text-xs font-medium rounded-t-md border border-b-0 border-transparent transition-colors text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300"
                        data-tab="translated" data-order="<%= order.id %>"
                        data-translate-url="<%= inbox_translate_path(order.id) %>"
                        data-auto-translate="<%= order.translated_body.blank? ? 'true' : 'false' %>">
                  번역 (한글)
                  <% if order.translated_body.present? %>
                    <span class="ml-1 w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
                  <% end %>
                </button>
                <%# 답변 초안 탭 (RFQ inbox 이메일만) %>
                <% if order.source_email_id.present? %>
                  <button onclick="switchEmailTab(this, 'reply-draft', <%= order.id %>)"
                          class="email-tab-btn px-3 py-1.5 text-xs font-medium rounded-t-md border border-b-0 border-transparent transition-colors text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300"
                          data-tab="reply-draft" data-order="<%= order.id %>"
                          data-generate-url="<%= inbox_generate_reply_path(order.id) %>">
                    답변 초안
                    <% if order.respond_to?(:reply_draft) && order.reply_draft.present? %>
                      <span class="ml-1 w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
                    <% end %>
                  </button>
                <% end %>
                <%# 첨부파일 및 링크 탭 %>
                <% att_meta_for_tab = order.respond_to?(:attachment_urls) && order.attachment_urls.present? ? (JSON.parse(order.attachment_urls) rescue []) : [] %>
                <% as_att_for_tab = order.respond_to?(:attachments) ? (order.attachments rescue []) : [] %>
                <% links_for_tab = order.respond_to?(:extracted_links) && order.extracted_links.present? ? (JSON.parse(order.extracted_links) rescue []) : [] %>
                <% att_count = [att_meta_for_tab.size, as_att_for_tab.size].max + links_for_tab.size %>
                <% if att_count > 0 %>
                  <button onclick="switchEmailTab(this, 'attachments', <%= order.id %>)"
                          class="email-tab-btn px-3 py-1.5 text-xs font-medium rounded-t-md border border-b-0 border-transparent transition-colors text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300"
                          data-tab="attachments" data-order="<%= order.id %>">
                    첨부파일 및 링크
                    <span class="ml-1 px-1.5 py-0.5 text-[10px] font-semibold bg-gray-200 dark:bg-gray-600 text-gray-600 dark:text-gray-300 rounded-full"><%= att_count %></span>
                  </button>
                <% end %>
              </div>

              <%# 원문 패널 — HTML 우선, plain text fallback %>
              <div id="tab-original-<%= order.id %>" class="email-tab-panel">
                <% if html_body.present? %>
                  <% cleaned_html = html_body.gsub(/<style[^>]*>.*?<\/style>/mi, "") %>
                  <div class="email-html-body bg-white dark:bg-gray-800/50 rounded-lg border border-gray-100 dark:border-gray-700 p-5 max-h-[480px] overflow-y-auto">
                    <%= sanitize(cleaned_html,
                        tags: %w[p br div span a b i u strong em h1 h2 h3 h4 h5 h6 ul ol li
                                 table thead tbody tr th td blockquote pre code img hr],
                        attributes: %w[href src alt style class target rel]) %>
                  </div>
                <% elsif plain_body.present? %>
                  <% split = Gmail::EmailSignatureParserService.split(plain_body) %>
                  <div class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap font-mono bg-gray-50 dark:bg-gray-800 rounded-lg p-5 border border-gray-100 dark:border-gray-700 max-h-[480px] overflow-y-auto">
<%= split[:body] %>
                  </div>
                  <% if split[:signature].present? %>
                    <div class="mt-3 border-t border-dashed border-gray-200 dark:border-gray-600 pt-3">
                      <div class="flex items-center gap-2 mb-2">
                        <svg class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12L12 12"/><path d="M20 4L8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8L20 20"/></svg>
                        <span class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold">발신자 서명</span>
                      </div>
                      <div class="bg-gray-50/80 dark:bg-gray-700/20 rounded-lg p-4 text-sm text-gray-600 dark:text-gray-400 whitespace-pre-wrap border border-gray-100 dark:border-gray-700">
<%= split[:signature] %>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>

              <%# 번역 패널 — 탭 클릭 시 자동 번역 %>
              <div id="tab-translated-<%= order.id %>" class="email-tab-panel hidden">
                <% if order.translated_body.present? %>
                  <%# 이미 번역된 경우: 번역 결과 표시 + 재번역 버튼 %>
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1">
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8l6 6"/><path d="M4 14l6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="M22 22l-5-10-5 10"/><path d="M14 18h6"/></svg>
                      AI 번역 완료
                    </span>
                    <button onclick="requestTranslation(<%= order.id %>, '<%= inbox_translate_path(order.id) %>', true)"
                            id="retranslate-btn-<%= order.id %>"
                            class="flex items-center gap-1 text-xs text-[#00A1E0] hover:text-blue-700 dark:hover:text-blue-300 transition-colors px-2 py-1 rounded hover:bg-blue-50 dark:hover:bg-blue-900/30">
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
                      재번역
                    </button>
                  </div>
                  <div id="translate-loading-<%= order.id %>" class="hidden flex flex-col items-center justify-center py-10">
                    <svg class="w-6 h-6 text-[#00A1E0] mb-2" style="animation: spin 1s linear infinite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    <p class="text-xs text-gray-400">Gemini AI가 재번역 중...</p>
                  </div>
                  <div id="translate-result-<%= order.id %>" class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap bg-blue-50 dark:bg-blue-900/20 rounded-lg p-5 border border-blue-100 dark:border-blue-800/40 max-h-[480px] overflow-y-auto">
<%= order.translated_body %>
                  </div>
                  <div id="translate-error-<%= order.id %>" class="hidden text-xs text-red-500 dark:text-red-400 text-center py-4"></div>
                <% else %>
                  <%# 미번역인 경우: 자동 번역 대기 %>
                  <div id="translate-placeholder-<%= order.id %>" class="flex flex-col items-center justify-center py-10 text-center">
                    <svg class="w-8 h-8 text-gray-300 dark:text-gray-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8l6 6"/><path d="M4 14l6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="M22 22l-5-10-5 10"/><path d="M14 18h6"/></svg>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">번역 준비 중...</p>
                  </div>
                  <div id="translate-loading-<%= order.id %>" class="hidden flex flex-col items-center justify-center py-10">
                    <svg class="w-6 h-6 text-[#00A1E0] mb-2" style="animation: spin 1s linear infinite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    <p class="text-xs text-gray-400">Gemini AI가 번역 중...</p>
                  </div>
                  <div id="translate-result-<%= order.id %>" class="hidden text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap bg-blue-50 dark:bg-blue-900/20 rounded-lg p-5 border border-blue-100 dark:border-blue-800/40 max-h-[480px] overflow-y-auto"></div>
                  <div id="translate-error-<%= order.id %>" class="hidden text-xs text-red-500 dark:text-red-400 text-center py-4"></div>
                <% end %>
              </div>
            <% else %>
              <div class="flex flex-col items-center justify-center py-12 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-gray-200 dark:text-gray-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <p class="text-xs text-gray-400 dark:text-gray-500">이메일 본문이 없습니다</p>
              </div>
            <% end %>

            <%# 답변 초안 패널 %>
            <% if order.source_email_id.present? %>
              <div id="tab-reply-draft-<%= order.id %>" class="email-tab-panel hidden">
                <% if order.respond_to?(:reply_draft) && order.reply_draft.present? %>
                  <%# 이미 초안이 있는 경우 %>
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1">
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      AI 답변 초안
                    </span>
                    <div class="flex items-center gap-2">
                      <button onclick="copyDraft(<%= order.id %>)"
                              class="flex items-center gap-1 text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        복사
                      </button>
                      <button onclick="regenerateDraft(<%= order.id %>, '<%= inbox_generate_reply_path(order.id) %>')"
                              id="regen-draft-btn-<%= order.id %>"
                              class="flex items-center gap-1 text-xs text-[#00A1E0] hover:text-blue-700 px-2 py-1 rounded hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors">
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
                        재생성
                      </button>
                    </div>
                  </div>
                  <div id="draft-loading-<%= order.id %>" class="hidden flex flex-col items-center justify-center py-6">
                    <svg class="w-5 h-5 text-[#00A1E0] mb-1" style="animation: spin 1s linear infinite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    <p class="text-xs text-gray-400">Gemini AI가 초안 작성 중...</p>
                  </div>
                  <div id="draft-content-<%= order.id %>"
                       class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap bg-indigo-50 dark:bg-indigo-900/20 rounded-lg p-5 border border-indigo-100 dark:border-indigo-800/40 max-h-[400px] overflow-y-auto font-mono text-xs">
<%= order.reply_draft %>
                  </div>
                  <div id="draft-error-<%= order.id %>" class="hidden text-xs text-red-500 dark:text-red-400 text-center py-4"></div>
                <% else %>
                  <%# 초안이 없는 경우: 생성 버튼 %>
                  <div id="draft-placeholder-<%= order.id %>" class="flex flex-col items-center justify-center py-12 text-center">
                    <svg class="w-8 h-8 text-gray-300 dark:text-gray-600 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mb-3">답변 초안이 아직 없습니다</p>
                    <button onclick="regenerateDraft(<%= order.id %>, '<%= inbox_generate_reply_path(order.id) %>')"
                            id="gen-draft-btn-<%= order.id %>"
                            class="flex items-center gap-2 px-4 py-2 bg-[#00A1E0] hover:bg-blue-600 text-white text-xs font-semibold rounded-lg transition-colors">
                      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                      AI로 답변 초안 생성
                    </button>
                  </div>
                  <div id="draft-loading-<%= order.id %>" class="hidden flex flex-col items-center justify-center py-10">
                    <svg class="w-6 h-6 text-[#00A1E0] mb-2" style="animation: spin 1s linear infinite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    <p class="text-xs text-gray-400">Gemini AI가 초안 작성 중...</p>
                  </div>
                  <div id="draft-content-<%= order.id %>"
                       class="hidden text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap bg-indigo-50 dark:bg-indigo-900/20 rounded-lg p-5 border border-indigo-100 dark:border-indigo-800/40 max-h-[400px] overflow-y-auto font-mono text-xs">
                  </div>
                  <div id="draft-error-<%= order.id %>" class="hidden text-xs text-red-500 dark:text-red-400 text-center py-4"></div>
                <% end %>
              </div>
            <% end %>

            <%# LLM 분석 결과 카드 %>
            <% if order.respond_to?(:rfq_confidence) && order.rfq_confidence.present? && order.rfq_confidence != "none" %>
              <div class="mt-4 border border-gray-100 dark:border-gray-700 rounded-lg overflow-hidden">
                <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
                  <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                    AI 분석 결과
                  </span>
                  <%# 신뢰도 게이지 %>
                  <div class="flex items-center gap-2">
                    <div class="w-24 h-1.5 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                      <div class="h-full rounded-full transition-all duration-500 <%= order.rfq_confidence == 'high' ? 'bg-green-500' : order.rfq_confidence == 'medium' ? 'bg-yellow-500' : 'bg-gray-400' %>"
                           style="width: <%= order.respond_to?(:rfq_score) ? (order.rfq_score || 0) : 0 %>%"></div>
                    </div>
                    <span class="text-xs font-bold <%= order.rfq_confidence == 'high' ? 'text-green-600 dark:text-green-400' : order.rfq_confidence == 'medium' ? 'text-yellow-600 dark:text-yellow-400' : 'text-gray-500 dark:text-gray-400' %>">
                      <%= order.respond_to?(:rfq_score) ? (order.rfq_score || 0) : 0 %>점
                    </span>
                  </div>
                </div>
                <div class="px-4 py-3">
                  <% if order.respond_to?(:llm_analysis) && order.llm_analysis.present? %>
                    <% begin; analysis = JSON.parse(order.llm_analysis); rescue; analysis = {}; end %>
                    <% if analysis["reason"].present? %>
                      <p class="text-xs text-gray-600 dark:text-gray-400 mb-3 italic">"<%= analysis["reason"] %>"</p>
                    <% end %>
                    <% extracted = analysis["extracted"] || {} %>
                    <% info_items = [] %>
                    <% info_items << ["품목", extracted["items"]&.join(", ")] if extracted["items"]&.any? %>
                    <% info_items << ["수량", extracted["quantities"]&.join(", ")] if extracted["quantities"]&.any? %>
                    <% info_items << ["프로젝트", extracted["project_name"]] if extracted["project_name"].present? %>
                    <% info_items << ["납기", extracted["due_date"]] if extracted["due_date"].present? %>
                    <% info_items << ["위치", extracted["delivery_location"]] if extracted["delivery_location"].present? %>
                    <% info_items << ["금액", "#{extracted['currency']} #{extracted['estimated_value']}"] if extracted["estimated_value"].present? %>
                    <% if info_items.any? %>
                      <dl class="grid grid-cols-2 gap-x-4 gap-y-1.5">
                        <% info_items.each do |label, value| %>
                          <div>
                            <dt class="text-xs text-gray-400 dark:text-gray-500"><%= label %></dt>
                            <dd class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= value %></dd>
                          </div>
                        <% end %>
                      </dl>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%# 첨부파일 + 링크 탭 패널 %>
            <% att_meta = order.respond_to?(:attachment_urls) && order.attachment_urls.present? ? (JSON.parse(order.attachment_urls) rescue []) : [] %>
            <% active_storage_attachments = order.respond_to?(:attachments) ? (order.attachments rescue []) : [] %>
            <% links = order.respond_to?(:extracted_links) && order.extracted_links.present? ? (JSON.parse(order.extracted_links) rescue []) : [] %>
            <% if att_meta.any? || active_storage_attachments.any? || links.any? %>
              <div id="tab-attachments-<%= order.id %>" class="email-tab-panel hidden">
                <div class="space-y-2">
                  <%# ActiveStorage 첨부파일 (iframe 미리보기 + 다운로드) %>
                  <% active_storage_attachments.each do |att| %>
                    <% blob = att.blob %>
                    <% ct = blob.content_type.to_s %>
                    <% fn = blob.filename.to_s %>
                    <% is_pdf = ct.include?("pdf") %>
                    <% is_image = ct.start_with?("image/") %>
                    <% is_excel = ct.include?("spreadsheet") || ct.include?("excel") || fn.match?(/\.xlsx?\z/i) %>
                    <% is_html = ct.include?("html") %>
                    <% is_viewable = is_pdf || is_image || is_excel || is_html %>
                    <% preview_url = is_excel || is_html ? inbox_attachment_preview_path(order, blob_id: blob.id) : (is_viewable ? rails_blob_path(blob, disposition: "inline") : nil) %>
                    <% icon_color = is_pdf ? "text-red-500" : is_excel ? "text-green-600" : is_image ? "text-purple-500" : is_html ? "text-orange-500" : "text-blue-500" %>
                    <div class="relative flex items-center gap-2.5 p-2.5 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors group cursor-pointer"
                         <% if is_viewable %>onclick="openPreviewModal('<%= j preview_url %>', '<%= j fn %>')"<% end %>>
                      <svg class="w-8 h-8 p-1.5 rounded bg-gray-100 dark:bg-gray-700 <%= icon_color %> flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                      <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= fn %></p>
                        <p class="text-xs text-gray-400 dark:text-gray-500">
                          <%= ct.split("/").last&.upcase %>
                          · <%= number_to_human_size(blob.byte_size) %>
                          <% if is_viewable %>
                            · <span class="text-blue-500">클릭하여 미리보기</span>
                          <% end %>
                        </p>
                      </div>
                      <%# 다운로드 버튼 (z-10으로 카드 클릭과 분리) %>
                      <a href="<%= rails_blob_path(blob, disposition: "attachment") %>" onclick="event.stopPropagation()" class="relative z-10 p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors" title="다운로드">
                        <svg class="w-3.5 h-3.5 text-gray-400 group-hover:text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      </a>
                    </div>
                  <% end %>

                  <%# attachment_urls 메타만 있는 경우 (ActiveStorage 미저장) %>
                  <% if active_storage_attachments.empty? %>
                    <% att_meta.each do |att| %>
                      <% att = att.is_a?(Hash) ? att.with_indifferent_access : {} %>
                      <% icon_color = att[:mime_type].to_s.include?("pdf") ? "text-red-500" : att[:mime_type].to_s.include?("sheet") || att[:mime_type].to_s.include?("excel") ? "text-green-600" : "text-blue-500" %>
                      <div class="flex items-center gap-2.5 p-2.5 rounded-lg border border-gray-100 dark:border-gray-700 opacity-60">
                        <svg class="w-8 h-8 p-1.5 rounded bg-gray-100 dark:bg-gray-700 <%= icon_color %> flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <div class="flex-1 min-w-0">
                          <p class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= att[:filename] %></p>
                          <p class="text-xs text-gray-400 dark:text-gray-500">
                            <%= att[:mime_type]&.split("/")&.last&.upcase %>
                            <% if att[:size] %> · <%= number_to_human_size(att[:size]) %><% end %>
                            · 재동기화 필요
                          </p>
                        </div>
                      </div>
                    <% end %>
                  <% end %>

                  <%# SAP Ariba 링크 분리 표시 %>
                  <% sap_links_json = order.respond_to?(:sap_portal_links) && order.sap_portal_links.present? ? order.sap_portal_links.to_s : "[]" %>
                  <% sap_urls = (JSON.parse(sap_links_json) rescue []) %>
                  <% if sap_urls.any? %>
                    <div class="mt-1 mb-2">
                      <p class="text-xs font-semibold text-orange-600 dark:text-orange-400 mb-1.5 flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        SAP / Ariba Portal Links
                      </p>
                      <% sap_urls.each do |sap_url| %>
                        <div class="flex items-center gap-2 p-2 rounded-lg border border-orange-200 dark:border-orange-800/50 bg-orange-50 dark:bg-orange-900/10 mb-1">
                          <svg class="w-4 h-4 text-orange-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                          <a href="<%= sap_url %>" target="_blank" rel="noopener noreferrer" class="flex-1 text-xs text-orange-700 dark:text-orange-300 hover:underline truncate"><%= sap_url.truncate(60) %></a>
                          <button onclick="fetchAribaDoc(this, '<%= j sap_url %>', <%= order.id %>)"
                                  class="flex-shrink-0 px-2 py-1 text-xs font-medium bg-orange-500 hover:bg-orange-600 text-white rounded transition-colors flex items-center gap-1">
                            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            문서 수집
                          </button>
                          <a href="<%= sap_url %>" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 text-orange-400 hover:text-orange-600">
                            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                          </a>
                        </div>
                      <% end %>
                    </div>
                  <% end %>

                  <%# 일반 링크 (SAP 링크 제외) %>
                  <% links.reject { |u| sap_urls.include?(u) }.each_with_index do |url, li| %>
                    <% link_id = "link-#{order.id}-#{li}" %>
                    <div class="rounded-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
                      <%# 링크 헤더 %>
                      <div class="flex items-center gap-2 p-2.5 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                        <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                        <a href="<%= url %>" target="_blank" rel="noopener noreferrer"
                           class="text-xs text-blue-500 hover:underline truncate flex-1">
                          <%= url.truncate(55) %>
                        </a>
                        <button onclick="analyzeLinkUrl(this, '<%= j url %>', '<%= j inbox_analyze_link_path %>')"
                                data-link-id="<%= link_id %>"
                                class="flex-shrink-0 text-[10px] px-2 py-0.5 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded border border-indigo-100 dark:border-indigo-800 hover:bg-indigo-100 transition-colors whitespace-nowrap flex items-center gap-1">
                          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                          AI 분석
                        </button>
                        <a href="<%= url %>" target="_blank" rel="noopener noreferrer"
                           class="flex-shrink-0 text-gray-300 dark:text-gray-600 group-hover:text-blue-400">
                          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                      </div>
                      <%# AI 분석 결과 영역 (동적) %>
                      <div id="<%= link_id %>-result" class="hidden border-t border-gray-100 dark:border-gray-700 px-3 py-2.5 bg-indigo-50/50 dark:bg-indigo-900/10">
                        <div id="<%= link_id %>-loading" class="hidden flex items-center gap-2 text-xs text-indigo-500 dark:text-indigo-400 py-1">
                          <svg class="w-3.5 h-3.5" style="animation: spin 1s linear infinite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                          URL 내용 분석 중...
                        </div>
                        <div id="<%= link_id %>-content" class="hidden">
                          <p id="<%= link_id %>-title" class="text-[10px] font-semibold text-indigo-700 dark:text-indigo-400 mb-1 truncate"></p>
                          <p id="<%= link_id %>-summary" class="text-xs text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap"></p>
                        </div>
                        <div id="<%= link_id %>-error" class="hidden text-xs text-red-500 dark:text-red-400 py-1"></div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div><!-- /p-6 data-order-id -->

          <%# Footer %>
          <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between gap-3 flex-wrap">
            <p class="text-xs text-gray-400 dark:text-gray-500">
              발주 #<%= order.id %> -- <%= time_ago_in_words(order.created_at) %> 전 생성
            </p>
            <div class="flex items-center gap-2">
              <%# 담당자로 저장 버튼 — sender_domain이 있어야 활성화 (contactable 자동 매칭) %>
              <% if order.sender_domain.present? %>
                <%= button_to create_from_signature_contact_persons_path,
                    params:  { order_id: order.id },
                    method:  :post,
                    data:    { turbo_confirm: "#{order.original_email_from.presence || order.sender_domain} 발신자를 담당자로 저장하시겠습니까?" },
                    class:   "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:border-accent hover:text-accent dark:hover:text-accent rounded-lg transition-colors" do %>
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                  담당자로 저장
                <% end %>
              <% end %>
              <%= link_to order_path(order), class: "text-sm text-blue-600 dark:text-blue-400 hover:underline inline-flex items-center gap-1" do %>
                전체 발주 상세 보기
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // --- Email selection ---
  let currentEmailId = null;

  function showEmail(orderId) {
    // Hide all detail panels
    document.querySelectorAll('.email-detail').forEach(el => el.classList.add('hidden'));
    document.getElementById('email-empty-state')?.classList.add('hidden');

    // Show selected detail
    const detail = document.getElementById('email-detail-' + orderId);
    if (detail) {
      detail.classList.remove('hidden');
    } else {
      // Fallback: navigate to full-page show view
      window.location.href = '/inbox/' + orderId;
      return;
    }

    // Update list item active state
    document.querySelectorAll('.email-item').forEach(el => {
      el.classList.remove('active', 'bg-blue-50/50', 'dark:bg-blue-900/20');
    });
    const item = document.getElementById('email-item-' + orderId);
    if (item) {
      item.classList.add('active', 'bg-blue-50/50');
    }

    currentEmailId = orderId;
  }

  // Auto-select first email
  const firstItem = document.querySelector('.email-item');
  if (firstItem) {
    const firstId = firstItem.getAttribute('data-order-id');
    if (firstId) showEmail(parseInt(firstId));
  }

  // --- Search (debounced server-side) ---
  let searchTimer = null;
  function handleSearch(query) {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      const currentFilter = '<%= @current_filter %>';
      const params = new URLSearchParams();
      if (query.trim()) params.set('q', query.trim());
      if (currentFilter !== 'all') params.set('filter', currentFilter);
      const qs = params.toString();
      window.location.href = '/inbox' + (qs ? '?' + qs : '');
    }, 500);
  }

  function clearSearch() {
    const currentFilter = '<%= @current_filter %>';
    const params = new URLSearchParams();
    if (currentFilter !== 'all') params.set('filter', currentFilter);
    const qs = params.toString();
    window.location.href = '/inbox' + (qs ? '?' + qs : '');
  }

  // --- Sync ---
  function triggerSync() {
    const btn = document.getElementById('sync-btn');
    const icon = document.getElementById('sync-icon');
    if (btn) btn.disabled = true;
    if (icon) icon.style.animation = 'spin 1s linear infinite';

    fetch('/inbox/sync', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content,
        'Content-Type': 'application/json'
      }
    })
    .then(r => r.json())
    .then(data => {
      if (icon) icon.style.animation = '';
      if (btn) btn.disabled = false;

      // Show sync result message
      const msg = data.message || '동기화 완료';
      showSyncNotification(msg, data.status === 'ok' ? 'success' : 'error');

      // Reload after brief delay
      setTimeout(() => window.location.reload(), 1500);
    })
    .catch(() => {
      if (icon) icon.style.animation = '';
      if (btn) btn.disabled = false;
      showSyncNotification('동기화 중 오류가 발생했습니다.', 'error');
    });
  }

  function showSyncNotification(message, type) {
    const existing = document.getElementById('sync-notification');
    if (existing) existing.remove();

    const colors = type === 'success'
      ? 'bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800'
      : 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800';

    const div = document.createElement('div');
    div.id = 'sync-notification';
    div.className = 'fixed top-4 right-4 z-50 px-4 py-3 rounded-lg border text-sm shadow-lg transition-opacity duration-300 ' + colors;
    div.textContent = message;
    document.body.appendChild(div);

    setTimeout(() => {
      div.style.opacity = '0';
      setTimeout(() => div.remove(), 300);
    }, 3000);
  }

  // --- 원문 / 번역 탭 ---
  // 번역 진행 중인 orderId 추적 (중복 요청 방지)
  const _translatingIds = new Set();

  function switchEmailTab(btn, tab, orderId) {
    // 탭 버튼 스타일 갱신
    document.querySelectorAll('[data-order="' + orderId + '"].email-tab-btn').forEach(b => {
      b.classList.remove('active-tab', 'border-[#00A1E0]', 'text-[#00A1E0]', 'bg-white', 'dark:bg-gray-900');
      b.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
    });
    btn.classList.add('active-tab', 'border-[#00A1E0]', 'text-[#00A1E0]', 'bg-white', 'dark:bg-gray-900');
    btn.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');

    // 패널 토글
    ['original', 'translated', 'reply-draft', 'attachments'].forEach(t => {
      const p = document.getElementById('tab-' + t + '-' + orderId);
      if (p) p.classList.add('hidden');
    });
    const target = document.getElementById('tab-' + tab + '-' + orderId);
    if (target) target.classList.remove('hidden');

    // 번역 탭 클릭 시 자동 번역 실행
    if (tab === 'translated' && btn.dataset.autoTranslate === 'true') {
      const url = btn.dataset.translateUrl;
      if (url && !_translatingIds.has(orderId)) {
        requestTranslation(orderId, url);
      }
    }
  }

  function requestTranslation(orderId, url, force) {
    if (_translatingIds.has(orderId)) return;
    _translatingIds.add(orderId);

    const placeholder   = document.getElementById('translate-placeholder-' + orderId);
    const loading       = document.getElementById('translate-loading-' + orderId);
    const result        = document.getElementById('translate-result-' + orderId);
    const error         = document.getElementById('translate-error-' + orderId);
    const retranslateBtn = document.getElementById('retranslate-btn-' + orderId);

    if (placeholder) placeholder.classList.add('hidden');
    if (result)      result.classList.add('hidden');
    if (error)       error.classList.add('hidden');
    if (loading)     loading.classList.remove('hidden');
    // 재번역 버튼 비활성화 (중복 클릭 방지)
    if (retranslateBtn) retranslateBtn.disabled = true;

    const fetchUrl = force ? url + '?force=true' : url;
    fetch(fetchUrl, {
      headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content }
    })
    .then(r => r.json())
    .then(data => {
      _translatingIds.delete(orderId);
      if (loading) loading.classList.add('hidden');
      if (retranslateBtn) retranslateBtn.disabled = false;

      if (data.translated_body) {
        if (result) {
          result.textContent = data.translated_body;
          result.classList.remove('hidden');
        }
        // 탭 버튼에 완료 dot 추가 (최초 번역 시)
        const tabBtn = document.querySelector('[data-order="' + orderId + '"][data-tab="translated"]');
        if (tabBtn && !tabBtn.querySelector('.translate-done-dot')) {
          const dot = document.createElement('span');
          dot.className = 'translate-done-dot ml-1 w-1.5 h-1.5 rounded-full bg-green-400 inline-block';
          tabBtn.appendChild(dot);
          tabBtn.dataset.autoTranslate = 'false';
        }
      } else {
        if (error) {
          error.textContent = data.error || '번역 실패: Gemini API를 다시 시도해주세요.';
          error.classList.remove('hidden');
        }
        if (placeholder) placeholder.classList.remove('hidden');
      }
    })
    .catch(() => {
      _translatingIds.delete(orderId);
      if (loading)     loading.classList.add('hidden');
      if (retranslateBtn) retranslateBtn.disabled = false;
      if (placeholder) placeholder.classList.remove('hidden');
      if (error) {
        error.textContent = '번역 요청 중 네트워크 오류가 발생했습니다.';
        error.classList.remove('hidden');
      }
    });
  }

  // 초기 탭 스타일 적용 (active-tab 버튼 강조)
  document.querySelectorAll('.email-tab-btn.active-tab').forEach(btn => {
    btn.classList.add('border-[#00A1E0]', 'text-[#00A1E0]', 'bg-white', 'dark:bg-gray-900');
    btn.classList.remove('border-transparent', 'text-gray-500');
  });

  // --- Ariba 문서 수집 ---
  function fetchAribaDoc(btn, url, orderId) {
    btn.disabled = true;
    btn.textContent = '수집 요청 중...';
    const csrf = document.querySelector('meta[name=csrf-token]')?.content;

    fetch('<%= inbox_analyze_link_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify({ url: url, order_id: orderId })
    })
    .then(r => r.json())
    .then(data => {
      if (data.ariba) {
        btn.classList.remove('bg-orange-500', 'hover:bg-orange-600');
        btn.classList.add('bg-green-500', 'hover:bg-green-600');
        btn.innerHTML = '<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 수집 시작됨';
        setTimeout(() => {
          btn.disabled = false;
          btn.classList.remove('bg-green-500', 'hover:bg-green-600');
          btn.classList.add('bg-orange-500', 'hover:bg-orange-600');
          btn.innerHTML = '<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> 문서 수집';
        }, 5000);
      } else {
        btn.textContent = '실패';
        btn.disabled = false;
      }
    })
    .catch(() => {
      btn.textContent = '오류';
      btn.disabled = false;
    });
  }

  // --- 링크 AI 분석 ---
  const _analyzingLinks = new Set();

  function analyzeLinkUrl(btn, url, analyzeEndpoint) {
    const linkId = btn.dataset.linkId;
    if (_analyzingLinks.has(linkId)) return;
    _analyzingLinks.add(linkId);

    const resultArea  = document.getElementById(linkId + '-result');
    const loadingEl   = document.getElementById(linkId + '-loading');
    const contentEl   = document.getElementById(linkId + '-content');
    const titleEl     = document.getElementById(linkId + '-title');
    const summaryEl   = document.getElementById(linkId + '-summary');
    const errorEl     = document.getElementById(linkId + '-error');

    // 결과 영역 표시
    if (resultArea) resultArea.classList.remove('hidden');
    if (loadingEl) loadingEl.classList.remove('hidden');
    if (contentEl) contentEl.classList.add('hidden');
    if (errorEl) errorEl.classList.add('hidden');

    // 버튼 비활성화
    btn.disabled = true;
    btn.textContent = '분석 중...';

    const csrf = document.querySelector('meta[name=csrf-token]')?.content;

    fetch(analyzeEndpoint, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrf
      },
      body: JSON.stringify({ url: url })
    })
    .then(r => r.json())
    .then(data => {
      _analyzingLinks.delete(linkId);
      if (loadingEl) loadingEl.classList.add('hidden');
      btn.disabled = false;

      if (data.success) {
        if (titleEl) titleEl.textContent = data.title || url;
        if (summaryEl) summaryEl.textContent = data.summary || '요약 정보 없음';
        if (contentEl) contentEl.classList.remove('hidden');
        // 버튼을 "재분석"으로 변경
        btn.innerHTML = '<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg> 재분석';
      } else {
        if (errorEl) {
          errorEl.textContent = data.error || '분석 실패';
          errorEl.classList.remove('hidden');
        }
        btn.innerHTML = '<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg> AI 분석';
      }
    })
    .catch(err => {
      _analyzingLinks.delete(linkId);
      if (loadingEl) loadingEl.classList.add('hidden');
      if (errorEl) {
        errorEl.textContent = '네트워크 오류가 발생했습니다.';
        errorEl.classList.remove('hidden');
      }
      btn.disabled = false;
      btn.innerHTML = 'AI 분석';
    });
  }

  // --- RFQ 피드백 (맞음/아님) ---
  function submitFeedback(orderId, verdict, url) {
    const confirmedBtn = document.getElementById('feedback-confirmed-' + orderId);
    const rejectedBtn  = document.getElementById('feedback-rejected-' + orderId);
    const banner       = document.getElementById('feedback-banner-' + orderId);
    const doneBanner   = document.getElementById('feedback-done-' + orderId);

    if (confirmedBtn) confirmedBtn.disabled = true;
    if (rejectedBtn)  rejectedBtn.disabled = true;

    const csrf = document.querySelector('meta[name=csrf-token]')?.content;
    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify({ verdict: verdict })
    })
    .then(r => r.json())
    .then(data => {
      if (data.status === 'ok') {
        // 배너 색상·메시지·버튼을 새 상태에 맞게 즉시 업데이트
        if (banner) {
          // 색상 클래스 교체
          banner.className = banner.className
            .replace(/bg-\w+-50|bg-\w+-800|bg-\w+-900\/20|border-\w+-200|border-\w+-800|dark:bg-\w+-900\/20|dark:border-\w+-800/g, '');
          if (verdict === 'confirmed') {
            banner.classList.add('bg-blue-50', 'dark:bg-blue-900/20', 'border', 'border-blue-200', 'dark:border-blue-800');
          } else {
            banner.classList.add('bg-gray-50', 'dark:bg-gray-800', 'border', 'border-gray-200', 'dark:border-gray-700');
          }

          // 아이콘+텍스트 업데이트
          const msgArea = banner.querySelector('.flex-1');
          if (msgArea) {
            if (verdict === 'confirmed') {
              msgArea.innerHTML = '<svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><span class="text-xs text-blue-800 dark:text-blue-300 font-medium">RFQ로 확정된 이메일입니다. 판정을 변경할 수 있습니다.</span>';
            } else {
              msgArea.innerHTML = '<svg class="w-4 h-4 text-gray-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg><span class="text-xs text-gray-600 dark:text-gray-400 font-medium">일반 메일로 처리됐습니다. 판정을 변경할 수 있습니다.</span>';
            }
          }

          // 버튼 교체: 방금 누른 버튼은 숨기고, 반대 버튼만 활성화
          const btnArea = banner.querySelector('.flex-shrink-0.flex');
          if (btnArea) {
            if (verdict === 'confirmed') {
              // "RFQ 아님" 버튼만 남김
              btnArea.innerHTML = '<button onclick="submitFeedback(' + orderId + ', \'rejected\', \'' + url + '\')" id="feedback-rejected-' + orderId + '" class="flex items-center gap-1.5 px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white text-xs font-semibold rounded-lg transition-colors"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>RFQ 아님</button>';
            } else {
              // "RFQ 맞음" 버튼만 남김
              btnArea.innerHTML = '<button onclick="submitFeedback(' + orderId + ', \'confirmed\', \'' + url + '\')" id="feedback-confirmed-' + orderId + '" class="flex items-center gap-1.5 px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold rounded-lg transition-colors"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>RFQ 맞음</button>';
            }
          }
        }

        // 완료 토스트 메시지
        showSyncNotification(data.message, 'success');

        // 목록 카드 뱃지 업데이트
        const listItem = document.getElementById('email-item-' + orderId);
        if (listItem) {
          const badges = listItem.querySelectorAll('span');
          badges.forEach(b => {
            const t = b.textContent.trim();
            if (t === 'AI 불확실' || t === 'RFQ' || t === '일반메일') b.remove();
          });
          // 새 뱃지 추가 (status badge 바로 뒤)
          const statusBadge = listItem.querySelector('span');
          if (statusBadge && verdict === 'confirmed') {
            const newBadge = document.createElement('span');
            newBadge.className = 'text-[10px] px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 rounded font-medium';
            newBadge.textContent = 'RFQ';
            statusBadge.after(newBadge);
          } else if (statusBadge && verdict === 'rejected') {
            const newBadge = document.createElement('span');
            newBadge.className = 'text-[10px] px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 rounded font-medium';
            newBadge.textContent = '일반메일';
            statusBadge.after(newBadge);
          }
        }

        // confirmed → 답변 초안 탭 하이라이트
        if (verdict === 'confirmed') {
          const draftTab = document.querySelector('[data-order="' + orderId + '"][data-tab="reply-draft"]');
          if (draftTab) {
            draftTab.classList.add('text-blue-600', 'dark:text-blue-400');
          }
        }
      } else {
        if (confirmedBtn) confirmedBtn.disabled = false;
        if (rejectedBtn)  rejectedBtn.disabled = false;
        showSyncNotification(data.error || '오류가 발생했습니다.', 'error');
      }
    })
    .catch(() => {
      if (confirmedBtn) confirmedBtn.disabled = false;
      if (rejectedBtn)  rejectedBtn.disabled = false;
      showSyncNotification('네트워크 오류가 발생했습니다.', 'error');
    });
  }

  // --- 답변 초안 생성 ---
  const _generatingDrafts = new Set();

  function regenerateDraft(orderId, url) {
    if (_generatingDrafts.has(orderId)) return;
    _generatingDrafts.add(orderId);

    const placeholder = document.getElementById('draft-placeholder-' + orderId);
    const loading     = document.getElementById('draft-loading-' + orderId);
    const content     = document.getElementById('draft-content-' + orderId);
    const errorEl     = document.getElementById('draft-error-' + orderId);
    const regenBtn    = document.getElementById('regen-draft-btn-' + orderId);
    const genBtn      = document.getElementById('gen-draft-btn-' + orderId);

    if (placeholder) placeholder.classList.add('hidden');
    if (content)     content.classList.add('hidden');
    if (errorEl)     errorEl.classList.add('hidden');
    if (loading)     loading.classList.remove('hidden');
    if (regenBtn)    regenBtn.disabled = true;
    if (genBtn)      genBtn.disabled = true;

    const csrf = document.querySelector('meta[name=csrf-token]')?.content;
    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf }
    })
    .then(r => r.json())
    .then(data => {
      _generatingDrafts.delete(orderId);
      if (loading) loading.classList.add('hidden');
      if (regenBtn) regenBtn.disabled = false;
      if (genBtn)   genBtn.disabled = false;

      if (data.status === 'ok' && data.draft) {
        if (content) {
          content.textContent = data.draft;
          content.classList.remove('hidden');
        }
        if (placeholder) placeholder.classList.add('hidden');
        // 탭 버튼에 완료 dot 추가
        const tabBtn = document.querySelector('[data-order="' + orderId + '"][data-tab="reply-draft"]');
        if (tabBtn && !tabBtn.querySelector('.draft-done-dot')) {
          const dot = document.createElement('span');
          dot.className = 'draft-done-dot ml-1 w-1.5 h-1.5 rounded-full bg-blue-400 inline-block';
          tabBtn.appendChild(dot);
        }
      } else {
        if (errorEl) {
          errorEl.textContent = data.error || '답변 초안 생성에 실패했습니다.';
          errorEl.classList.remove('hidden');
        }
        if (placeholder) placeholder.classList.remove('hidden');
      }
    })
    .catch(() => {
      _generatingDrafts.delete(orderId);
      if (loading)  loading.classList.add('hidden');
      if (regenBtn) regenBtn.disabled = false;
      if (genBtn)   genBtn.disabled = false;
      if (placeholder) placeholder.classList.remove('hidden');
      if (errorEl) {
        errorEl.textContent = '네트워크 오류가 발생했습니다.';
        errorEl.classList.remove('hidden');
      }
    });
  }

  function copyDraft(orderId) {
    const content = document.getElementById('draft-content-' + orderId);
    if (!content) return;
    navigator.clipboard.writeText(content.textContent.trim()).then(() => {
      showSyncNotification('답변 초안이 클립보드에 복사되었습니다.', 'success');
    });
  }

  // --- switchEmailTab에 reply-draft 패널 포함 ---
  // (기존 switchEmailTab을 확장하여 3번째 패널 숨김 처리)
  const _origSwitchEmailTab = window.switchEmailTab;
  function switchEmailTab(btn, tab, orderId) {
    // 탭 버튼 스타일 갱신
    document.querySelectorAll('[data-order="' + orderId + '"].email-tab-btn').forEach(b => {
      b.classList.remove('active-tab', 'border-[#00A1E0]', 'text-[#00A1E0]', 'bg-white', 'dark:bg-gray-900');
      b.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
    });
    btn.classList.add('active-tab', 'border-[#00A1E0]', 'text-[#00A1E0]', 'bg-white', 'dark:bg-gray-900');
    btn.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');

    // 패널 토글 (4개 패널 모두 숨김)
    ['original', 'translated', 'reply-draft', 'attachments'].forEach(t => {
      const p = document.getElementById('tab-' + t + '-' + orderId);
      if (p) p.classList.add('hidden');
    });
    const target = document.getElementById('tab-' + tab + '-' + orderId);
    if (target) target.classList.remove('hidden');

    // 번역 탭 클릭 시 자동 번역
    if (tab === 'translated' && btn.dataset.autoTranslate === 'true') {
      const url = btn.dataset.translateUrl;
      if (url && !_translatingIds.has(orderId)) {
        requestTranslation(orderId, url);
      }
    }
  }

  // --- Keyboard shortcuts ---
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    const items = Array.from(document.querySelectorAll('.email-item'));
    if (!items.length) return;

    const currentIdx = items.findIndex(el => el.id === 'email-item-' + currentEmailId);

    if (e.key === 'j' || e.key === 'ArrowDown') {
      e.preventDefault();
      const nextIdx = Math.min(currentIdx + 1, items.length - 1);
      const nextId = items[nextIdx]?.getAttribute('data-order-id');
      if (nextId) showEmail(parseInt(nextId));
    } else if (e.key === 'k' || e.key === 'ArrowUp') {
      e.preventDefault();
      const prevIdx = Math.max(currentIdx - 1, 0);
      const prevId = items[prevIdx]?.getAttribute('data-order-id');
      if (prevId) showEmail(parseInt(prevId));
    } else if (e.key === '/') {
      e.preventDefault();
      document.getElementById('inbox-search')?.focus();
    }
  });

  // --- 10분 자동 동기화 + 카운트다운 표시 ---
  (function initAutoSync() {
    const countdownEl = document.getElementById('auto-sync-countdown');
    if (!countdownEl) return;

    const hasAccount = countdownEl.dataset.hasAccount === 'true';
    const INTERVAL = 10 * 60; // 600초 (10분)
    let remaining = INTERVAL;
    let countdownTimer = null;

    function formatTime(sec) {
      const m = Math.floor(sec / 60);
      const s = sec % 60;
      return m + '분 ' + String(s).padStart(2, '0') + '초';
    }

    function renderCountdown(sec) {
      const ratio = sec / INTERVAL;
      // 남은 시간에 따라 색상 변경: 2분 이하 주황, 30초 이하 빨강
      const colorClass = sec <= 30 ? 'text-red-500 dark:text-red-400' :
                         sec <= 120 ? 'text-orange-500 dark:text-orange-400' :
                         'text-gray-400 dark:text-gray-500';
      countdownEl.className = 'text-xs tabular-nums flex items-center gap-1 ' + colorClass;
      countdownEl.innerHTML =
        '<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' +
        '<span>' + formatTime(sec) + ' 후 새로고침</span>';
    }

    function startCountdown() {
      remaining = INTERVAL;
      renderCountdown(remaining);

      countdownTimer = setInterval(function() {
        remaining -= 1;
        if (remaining <= 0) {
          clearInterval(countdownTimer);
          countdownEl.innerHTML =
            '<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>' +
            '<span>동기화 중...</span>';
          if (hasAccount) {
            triggerSync(); // triggerSync → reload 이후 카운트다운 자동 재시작
          } else {
            window.location.reload();
          }
        } else {
          renderCountdown(remaining);
        }
      }, 1000);
    }

    startCountdown();
  })();

  // --- 첨부파일 iframe 미리보기 모달 ---
  function openPreviewModal(url, filename) {
    const modal = document.getElementById('preview-modal');
    const iframe = document.getElementById('preview-iframe');
    const title = document.getElementById('preview-title');
    if (!modal || !iframe) return;
    title.textContent = filename || '미리보기';
    iframe.src = url;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closePreviewModal() {
    const modal = document.getElementById('preview-modal');
    const iframe = document.getElementById('preview-iframe');
    if (!modal) return;
    modal.classList.add('hidden');
    iframe.src = 'about:blank';
    document.body.style.overflow = '';
  }

  // ESC 키로 모달 닫기
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closePreviewModal();
  });
</script>

<%# 첨부파일 미리보기 모달 (iframe) %>
<div id="preview-modal" class="preview-modal-backdrop hidden" onclick="if(event.target===this)closePreviewModal()">
  <div class="preview-modal-content">
    <div class="preview-modal-header">
      <div class="flex items-center gap-2 min-w-0">
        <svg class="w-4 h-4 text-gray-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <span id="preview-title" class="text-sm font-medium text-gray-700 dark:text-gray-200 truncate">미리보기</span>
      </div>
      <button onclick="closePreviewModal()" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" title="닫기 (ESC)">
        <svg class="w-5 h-5 text-gray-500 dark:text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <iframe id="preview-iframe" class="preview-modal-iframe" src="about:blank"></iframe>
  </div>
</div>
