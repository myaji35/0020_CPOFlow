<%# Inbox -- Gmail-style 3-pane layout (Production-ready) %>

<style>
  .inbox-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    height: calc(100vh - 56px);
    overflow: hidden;
  }
  .inbox-main {
    display: grid;
    grid-template-columns: 360px 1fr;
    overflow: hidden;
  }
  .inbox-list { overflow-y: auto; }
  .inbox-body { overflow-y: auto; }
  .email-item.active { background-color: rgba(0, 161, 224, 0.08); }
  .email-item.active.dark-active { background-color: rgba(0, 161, 224, 0.15); }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .inbox-search:focus { outline: none; box-shadow: 0 0 0 2px rgba(0, 161, 224, 0.3); }
</style>

<div class="inbox-layout">

  <%# ===== PANE 1: Folder / Filter sidebar ===== %>
  <div class="border-r border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 overflow-y-auto flex flex-col">
    <div class="p-4 flex-1">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-2 mb-2">
        받은편지함
      </p>
      <nav class="space-y-1">
        <%# All Emails %>
        <a href="<%= inbox_path %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'all' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          전체 메일
          <span class="ml-auto text-xs bg-gray-200 dark:bg-gray-600 text-gray-600 dark:text-gray-300 rounded-full px-2 py-0.5">
            <%= @count_all %>
          </span>
        </a>

        <%# RFQ Only (inbox status) %>
        <a href="<%= inbox_path(filter: 'rfq') %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'rfq' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          RFQ 대기
          <% if @count_rfq > 0 %>
            <span class="ml-auto text-xs bg-blue-600 text-white rounded-full px-2 py-0.5">
              <%= @count_rfq %>
            </span>
          <% end %>
        </a>

        <%# Converted (non-inbox status) %>
        <a href="<%= inbox_path(filter: 'converted') %>"
           class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                  <%= @current_filter == 'converted' ? 'text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          처리 완료
          <% if @count_converted > 0 %>
            <span class="ml-auto text-xs bg-green-600 text-white rounded-full px-2 py-0.5">
              <%= @count_converted %>
            </span>
          <% end %>
        </a>
      </nav>

      <%# Connected accounts %>
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-2 mb-2 mt-8">
        연결된 계정
      </p>
      <% accounts = current_user.email_accounts.where(connected: true) %>
      <% if accounts.any? %>
        <% accounts.each do |acc| %>
          <div class="px-3 py-2 rounded-lg text-xs text-gray-600 dark:text-gray-400 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></span>
            <span class="truncate"><%= acc.email %></span>
          </div>
        <% end %>
      <% else %>
        <div class="px-3 py-3 text-xs text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-700/50 rounded-lg">
          <p class="mb-1">Gmail 계정이 연결되지 않았습니다.</p>
          <%= link_to settings_root_path, class: "text-blue-500 hover:underline font-medium" do %>
            설정에서 연결하기
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 inline ml-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ===== PANE 2 + 3 ===== %>
  <div class="inbox-main">

    <%# ===== PANE 2: Email list ===== %>
    <div class="inbox-list border-r border-gray-200 dark:border-gray-700 flex flex-col">
      <%# Toolbar with search %>
      <div class="sticky top-0 z-10 bg-white dark:bg-gray-800 border-b border-gray-100 dark:border-gray-700">
        <%# Header row %>
        <div class="px-4 py-3 flex items-center justify-between">
          <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">
            <% case @current_filter
               when "rfq" %>RFQ 대기 메일
            <% when "converted" %>처리된 메일
            <% else %>전체 메일
            <% end %>
          </span>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 dark:text-gray-500"><%= @all_orders.count %>건</span>
            <% if current_user.email_accounts.where(connected: true).any? %>
              <button onclick="triggerSync()" id="sync-btn"
                      class="text-xs px-3 py-1.5 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400 flex items-center gap-1 transition-colors">
                <svg id="sync-icon" xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                동기화
              </button>
            <% end %>
          </div>
        </div>

        <%# Search bar %>
        <div class="px-4 pb-3">
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text"
                   id="inbox-search"
                   class="inbox-search w-full pl-9 pr-8 py-2 text-sm border border-gray-200 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700/50 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500"
                   placeholder="이메일 검색 (제목, 발신자, 고객명)..."
                   value="<%= @search_query %>"
                   oninput="handleSearch(this.value)">
            <% if @search_query.present? %>
              <button onclick="clearSearch()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <%# Email list items %>
      <div class="flex-1 overflow-y-auto">
        <% if @all_orders.any? %>
          <ul id="email-list" class="divide-y divide-gray-100 dark:divide-gray-700">
            <% @all_orders.each_with_index do |order, idx| %>
              <li class="email-item cursor-pointer px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
                  onclick="showEmail(<%= order.id %>)"
                  data-order-id="<%= order.id %>"
                  id="email-item-<%= order.id %>">
                <div class="flex items-center gap-2 mb-1">
                  <%# Status badge %>
                  <% status_colors = {
                    "inbox"     => "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400",
                    "reviewing" => "bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400",
                    "quoted"    => "bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-400",
                    "confirmed" => "bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-400",
                    "procuring" => "bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400",
                    "qa"        => "bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-400",
                    "delivered" => "bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400"
                  } %>
                  <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold <%= status_colors[order.status] || 'bg-gray-100 text-gray-600' %>">
                    <%= Order::STATUS_LABELS[order.status] || order.status.humanize %>
                  </span>

                  <%# RFQ badge %>
                  <% if order.source_email_id.present? %>
                    <span class="text-[10px] px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 rounded font-medium">RFQ</span>
                  <% end %>

                  <%# Priority indicator %>
                  <% case order.priority
                     when "urgent" %>
                    <span class="w-2 h-2 rounded-full bg-red-500 flex-shrink-0" title="긴급"></span>
                  <% when "high" %>
                    <span class="w-2 h-2 rounded-full bg-orange-400 flex-shrink-0" title="높음"></span>
                  <% end %>

                  <%# Date %>
                  <span class="ml-auto text-[11px] text-gray-400 dark:text-gray-500 flex-shrink-0">
                    <%= order.created_at.strftime("%m/%d") %>
                  </span>
                </div>
                <p class="text-sm text-gray-900 dark:text-white truncate font-medium">
                  <%= order.original_email_subject.presence || order.title %>
                </p>
                <p class="text-xs text-gray-500 dark:text-gray-400 truncate mt-0.5">
                  <%= order.original_email_from.presence || order.customer_name %>
                </p>
                <% if order.description.present? %>
                  <p class="text-xs text-gray-400 dark:text-gray-500 truncate mt-0.5">
                    <%= order.description.truncate(80) %>
                  </p>
                <% end %>

                <%# 신뢰도 뱃지 (LLM 분석 결과) %>
                <% confidence_colors = { "high" => "bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400", "medium" => "bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-500", "low" => "bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400" } %>
                <% conf = order.respond_to?(:rfq_confidence) ? order.rfq_confidence.to_s : "" %>
                <% confidence_labels = { "high" => "확실", "medium" => "가능성", "low" => "낮음" } %>

                <%# Due date chip + confidence badge row %>
                <div class="mt-1.5 flex items-center gap-1.5 flex-wrap">
                  <% if order.due_date %>
                    <% days = order.days_until_due %>
                    <% due_class = if days && days < 0
                                     "text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20"
                                   elsif days && days <= 7
                                     "text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20"
                                   elsif days && days <= 14
                                     "text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20"
                                   else
                                     "text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20"
                                   end %>
                    <span class="inline-flex items-center gap-1 text-[10px] px-1.5 py-0.5 rounded <%= due_class %>">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                      <% if days && days < 0 %>
                        <%= days.abs %>일 초과
                      <% else %>
                        D-<%= days %>
                      <% end %>
                    </span>
                  <% end %>
                  <% if conf.in?(%w[high medium low]) %>
                    <span class="text-[10px] px-1.5 py-0.5 rounded <%= confidence_colors[conf] %> font-medium flex-shrink-0">
                      <%= confidence_labels[conf] %>
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <%# Empty state %>
          <div class="flex flex-col items-center justify-center py-20 text-center px-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-200 dark:text-gray-600 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
            <% if @search_query.present? %>
              <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">"<%= @search_query %>" 검색 결과 없음</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">다른 키워드로 검색해보세요</p>
              <button onclick="clearSearch()" class="mt-3 text-sm text-blue-600 hover:underline">검색 초기화</button>
            <% else %>
              <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">이메일이 없습니다</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Gmail 계정을 연결하면 RFQ 이메일이 자동으로 수집됩니다</p>
              <%= link_to settings_root_path, class: "mt-4 text-sm text-blue-600 hover:underline inline-flex items-center gap-1" do %>
                설정으로 이동
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ===== PANE 3: Email body (all orders, not just RFQ) ===== %>
    <div class="inbox-body bg-white dark:bg-gray-900" id="email-body-pane">
      <%# Default empty state %>
      <div id="email-empty-state" class="flex flex-col items-center justify-center h-full text-center px-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-gray-200 dark:text-gray-600 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">이메일을 선택하면 내용이 여기에 표시됩니다</p>
        <p class="text-gray-300 dark:text-gray-600 text-xs mt-1">좌측 목록에서 이메일을 클릭하세요</p>
      </div>

      <%# Email detail panels for ALL orders (not just rfq_orders) %>
      <% @all_orders.each do |order| %>
        <div id="email-detail-<%= order.id %>" class="email-detail hidden">

          <%# Email header area %>
          <div class="border-b border-gray-100 dark:border-gray-700 p-6 pb-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-lg font-bold text-gray-900 dark:text-white leading-tight">
                  <%= order.original_email_subject.presence || order.title %>
                </h2>
                <div class="flex items-center gap-2 mt-2">
                  <%# Sender avatar %>
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                    <%= order.original_email_from.presence&.first&.upcase || "?" %>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-700 dark:text-gray-300">
                      <%= order.original_email_from.presence || order.customer_name %>
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-500">
                      <%= order.created_at.strftime("%Y년 %m월 %d일 %H:%M") %>
                    </p>
                  </div>
                </div>
              </div>

              <%# Action buttons %>
              <div class="flex items-center gap-2 flex-shrink-0">
                <%= status_badge(order) %>
                <% if order.status.to_s == "inbox" %>
                  <%= button_to convert_email_to_order_path(order),
                      data: { turbo_confirm: "칸반 보드의 'Under Review' 단계로 이동하시겠습니까?" },
                      class: "flex items-center gap-1.5 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    칸반으로 이동
                  <% end %>
                <% else %>
                  <%= link_to order_path(order), class: "flex items-center gap-1.5 px-3 py-2 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-medium rounded-lg transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    발주 상세 보기
                  <% end %>
                <% end %>
              </div>
            </div>

            <%# Metadata chips %>
            <div class="flex flex-wrap gap-2 mt-4">
              <% if order.due_date %>
                <% days = order.days_until_due %>
                <% chip_class = if days && days < 0
                                   "bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-100 dark:border-red-800"
                                 elsif days && days <= 7
                                   "bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-100 dark:border-red-800"
                                 elsif days && days <= 14
                                   "bg-orange-50 dark:bg-orange-900/20 text-orange-700 dark:text-orange-400 border-orange-100 dark:border-orange-800"
                                 else
                                   "bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 border-green-100 dark:border-green-800"
                                 end %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full border <%= chip_class %>">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  납기 <%= order.due_date.strftime("%Y/%m/%d") %>
                  <% if days && days < 0 %>
                    (<%= days.abs %>일 초과)
                  <% elsif days %>
                    (D-<%= days %>)
                  <% end %>
                </span>
              <% end %>

              <% if order.item_name.present? %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 border border-blue-100 dark:border-blue-800">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <%= order.item_name %>
                </span>
              <% end %>

              <% if order.client %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/20 text-indigo-700 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-800">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <%= order.client.name %>
                </span>
              <% end %>

              <% if order.project %>
                <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-teal-50 dark:bg-teal-900/20 text-teal-700 dark:text-teal-400 border border-teal-100 dark:border-teal-800">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                  <%= order.project.name %>
                </span>
              <% end %>

              <% order.tags_array.each do |tag| %>
                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">#<%= tag %></span>
              <% end %>
            </div>
          </div>

          <%# Key info grid %>
          <% if order.client || order.supplier || order.estimated_value.present? || order.project %>
            <div class="px-6 py-4 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700">
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                <% if order.client %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">발주처</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs"><%= order.client.name %></dd>
                  </div>
                <% end %>
                <% if order.supplier %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">거래처</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs"><%= order.supplier.name %></dd>
                  </div>
                <% end %>
                <% if order.estimated_value.present? %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">예상 금액</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs">
                      <%= number_to_currency(order.estimated_value, unit: order.currency.presence || "$", format: "%u %n") %>
                    </dd>
                  </div>
                <% end %>
                <% if order.project %>
                  <div>
                    <dt class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">현장</dt>
                    <dd class="font-medium text-gray-900 dark:text-white text-xs"><%= order.project.name %></dd>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Email body %>
          <div class="p-6">
            <% body = order.original_email_body.presence || order.description %>
            <% if body.present? %>
              <div class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap font-mono bg-gray-50 dark:bg-gray-800 rounded-lg p-5 border border-gray-100 dark:border-gray-700 max-h-96 overflow-y-auto">
<%= body %>
              </div>
            <% else %>
              <div class="flex flex-col items-center justify-center py-12 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-gray-200 dark:text-gray-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <p class="text-xs text-gray-400 dark:text-gray-500">이메일 본문이 없습니다</p>
              </div>
            <% end %>

            <%# LLM 분석 결과 카드 %>
            <% if order.respond_to?(:rfq_confidence) && order.rfq_confidence.present? && order.rfq_confidence != "none" %>
              <div class="mt-4 border border-gray-100 dark:border-gray-700 rounded-lg overflow-hidden">
                <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
                  <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                    AI 분석 결과
                  </span>
                  <%# 신뢰도 게이지 %>
                  <div class="flex items-center gap-2">
                    <div class="w-24 h-1.5 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                      <div class="h-full rounded-full transition-all duration-500 <%= order.rfq_confidence == 'high' ? 'bg-green-500' : order.rfq_confidence == 'medium' ? 'bg-yellow-500' : 'bg-gray-400' %>"
                           style="width: <%= order.respond_to?(:rfq_score) ? (order.rfq_score || 0) : 0 %>%"></div>
                    </div>
                    <span class="text-xs font-bold <%= order.rfq_confidence == 'high' ? 'text-green-600 dark:text-green-400' : order.rfq_confidence == 'medium' ? 'text-yellow-600 dark:text-yellow-400' : 'text-gray-500 dark:text-gray-400' %>">
                      <%= order.respond_to?(:rfq_score) ? (order.rfq_score || 0) : 0 %>점
                    </span>
                  </div>
                </div>
                <div class="px-4 py-3">
                  <% if order.respond_to?(:llm_analysis) && order.llm_analysis.present? %>
                    <% begin; analysis = JSON.parse(order.llm_analysis); rescue; analysis = {}; end %>
                    <% if analysis["reason"].present? %>
                      <p class="text-xs text-gray-600 dark:text-gray-400 mb-3 italic">"<%= analysis["reason"] %>"</p>
                    <% end %>
                    <% extracted = analysis["extracted"] || {} %>
                    <% info_items = [] %>
                    <% info_items << ["품목", extracted["items"]&.join(", ")] if extracted["items"]&.any? %>
                    <% info_items << ["수량", extracted["quantities"]&.join(", ")] if extracted["quantities"]&.any? %>
                    <% info_items << ["프로젝트", extracted["project_name"]] if extracted["project_name"].present? %>
                    <% info_items << ["납기", extracted["due_date"]] if extracted["due_date"].present? %>
                    <% info_items << ["위치", extracted["delivery_location"]] if extracted["delivery_location"].present? %>
                    <% info_items << ["금액", "#{extracted['currency']} #{extracted['estimated_value']}"] if extracted["estimated_value"].present? %>
                    <% if info_items.any? %>
                      <dl class="grid grid-cols-2 gap-x-4 gap-y-1.5">
                        <% info_items.each do |label, value| %>
                          <div>
                            <dt class="text-xs text-gray-400 dark:text-gray-500"><%= label %></dt>
                            <dd class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= value %></dd>
                          </div>
                        <% end %>
                      </dl>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%# 첨부파일 + 링크 패널 %>
            <% attachments = order.respond_to?(:attachment_urls) && order.attachment_urls.present? ? (JSON.parse(order.attachment_urls) rescue []) : [] %>
            <% links = order.respond_to?(:extracted_links) && order.extracted_links.present? ? (JSON.parse(order.extracted_links) rescue []) : [] %>
            <% if attachments.any? || links.any? %>
              <div class="mt-3 border border-gray-100 dark:border-gray-700 rounded-lg overflow-hidden">
                <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700">
                  <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                    첨부파일 및 링크
                  </span>
                </div>
                <div class="px-4 py-3 space-y-2">
                  <% attachments.each do |att| %>
                    <% att = att.is_a?(Hash) ? att.with_indifferent_access : {} %>
                    <% icon_color = att[:mime_type].to_s.include?("pdf") ? "text-red-500" : att[:mime_type].to_s.include?("sheet") || att[:mime_type].to_s.include?("excel") ? "text-green-600" : "text-blue-500" %>
                    <a href="<%= att[:signed_url] %>" target="_blank" rel="noopener noreferrer"
                       class="flex items-center gap-2.5 p-2.5 rounded-lg border border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                      <svg class="w-8 h-8 p-1.5 rounded bg-gray-100 dark:bg-gray-700 <%= icon_color %> flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                      <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= att[:filename] %></p>
                        <p class="text-xs text-gray-400 dark:text-gray-500">
                          <%= att[:mime_type]&.split("/")&.last&.upcase %>
                          <% if att[:size] %> · <%= number_to_human_size(att[:size]) %><% end %>
                        </p>
                      </div>
                      <svg class="w-3.5 h-3.5 text-gray-300 dark:text-gray-600 group-hover:text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    </a>
                  <% end %>
                  <% links.each do |url| %>
                    <a href="<%= url %>" target="_blank" rel="noopener noreferrer"
                       class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                      <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                      <span class="text-xs text-blue-500 hover:underline truncate"><%= url.truncate(60) %></span>
                    </a>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <%# Footer %>
          <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
            <p class="text-xs text-gray-400 dark:text-gray-500">
              발주 #<%= order.id %> -- <%= time_ago_in_words(order.created_at) %> 전 생성
            </p>
            <%= link_to order_path(order), class: "text-sm text-blue-600 dark:text-blue-400 hover:underline inline-flex items-center gap-1" do %>
              전체 발주 상세 보기
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // --- Email selection ---
  let currentEmailId = null;

  function showEmail(orderId) {
    // Hide all detail panels
    document.querySelectorAll('.email-detail').forEach(el => el.classList.add('hidden'));
    document.getElementById('email-empty-state')?.classList.add('hidden');

    // Show selected detail
    const detail = document.getElementById('email-detail-' + orderId);
    if (detail) {
      detail.classList.remove('hidden');
    } else {
      // Fallback: navigate to full-page show view
      window.location.href = '/inbox/' + orderId;
      return;
    }

    // Update list item active state
    document.querySelectorAll('.email-item').forEach(el => {
      el.classList.remove('active', 'bg-blue-50/50', 'dark:bg-blue-900/20');
    });
    const item = document.getElementById('email-item-' + orderId);
    if (item) {
      item.classList.add('active', 'bg-blue-50/50');
    }

    currentEmailId = orderId;
  }

  // Auto-select first email
  const firstItem = document.querySelector('.email-item');
  if (firstItem) {
    const firstId = firstItem.getAttribute('data-order-id');
    if (firstId) showEmail(parseInt(firstId));
  }

  // --- Search (debounced server-side) ---
  let searchTimer = null;
  function handleSearch(query) {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      const currentFilter = '<%= @current_filter %>';
      const params = new URLSearchParams();
      if (query.trim()) params.set('q', query.trim());
      if (currentFilter !== 'all') params.set('filter', currentFilter);
      const qs = params.toString();
      window.location.href = '/inbox' + (qs ? '?' + qs : '');
    }, 500);
  }

  function clearSearch() {
    const currentFilter = '<%= @current_filter %>';
    const params = new URLSearchParams();
    if (currentFilter !== 'all') params.set('filter', currentFilter);
    const qs = params.toString();
    window.location.href = '/inbox' + (qs ? '?' + qs : '');
  }

  // --- Sync ---
  function triggerSync() {
    const btn = document.getElementById('sync-btn');
    const icon = document.getElementById('sync-icon');
    if (btn) btn.disabled = true;
    if (icon) icon.style.animation = 'spin 1s linear infinite';

    fetch('/inbox/sync', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content,
        'Content-Type': 'application/json'
      }
    })
    .then(r => r.json())
    .then(data => {
      if (icon) icon.style.animation = '';
      if (btn) btn.disabled = false;

      // Show sync result message
      const msg = data.message || '동기화 완료';
      showSyncNotification(msg, data.status === 'ok' ? 'success' : 'error');

      // Reload after brief delay
      setTimeout(() => window.location.reload(), 1500);
    })
    .catch(() => {
      if (icon) icon.style.animation = '';
      if (btn) btn.disabled = false;
      showSyncNotification('동기화 중 오류가 발생했습니다.', 'error');
    });
  }

  function showSyncNotification(message, type) {
    const existing = document.getElementById('sync-notification');
    if (existing) existing.remove();

    const colors = type === 'success'
      ? 'bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800'
      : 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800';

    const div = document.createElement('div');
    div.id = 'sync-notification';
    div.className = 'fixed top-4 right-4 z-50 px-4 py-3 rounded-lg border text-sm shadow-lg transition-opacity duration-300 ' + colors;
    div.textContent = message;
    document.body.appendChild(div);

    setTimeout(() => {
      div.style.opacity = '0';
      setTimeout(() => div.remove(), 300);
    }, 3000);
  }

  // --- Keyboard shortcuts ---
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    const items = Array.from(document.querySelectorAll('.email-item'));
    if (!items.length) return;

    const currentIdx = items.findIndex(el => el.id === 'email-item-' + currentEmailId);

    if (e.key === 'j' || e.key === 'ArrowDown') {
      e.preventDefault();
      const nextIdx = Math.min(currentIdx + 1, items.length - 1);
      const nextId = items[nextIdx]?.getAttribute('data-order-id');
      if (nextId) showEmail(parseInt(nextId));
    } else if (e.key === 'k' || e.key === 'ArrowUp') {
      e.preventDefault();
      const prevIdx = Math.max(currentIdx - 1, 0);
      const prevId = items[prevIdx]?.getAttribute('data-order-id');
      if (prevId) showEmail(parseInt(prevId));
    } else if (e.key === '/') {
      e.preventDefault();
      document.getElementById('inbox-search')?.focus();
    }
  });
</script>
