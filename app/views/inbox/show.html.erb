<%# Inbox Email Detail — Full Page View %>
<% content_for :page_title, @order.original_email_subject.presence || @order.title %>

<div class="max-w-4xl mx-auto">

  <%# ── Breadcrumb ─────────────────────────────────────────── %>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to inbox_path, class: "text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300" do %>
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    <% end %>
    <div>
      <p class="text-xs text-gray-400 dark:text-gray-500">받은편지함 / 이메일 상세</p>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white leading-tight truncate max-w-xl">
        <%= @order.original_email_subject.presence || @order.title %>
      </h2>
    </div>
  </div>

  <%# ── Main Email Card ─────────────────────────────────────── %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden mb-6">

    <%# Email Header %>
    <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0">
          <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
            <%= @order.original_email_subject.presence || @order.title %>
          </h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
            <div class="flex items-center gap-1.5">
              <div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                <%= @order.original_email_from.presence&.first&.upcase || "?" %>
              </div>
              <div>
                <span class="font-medium text-gray-700 dark:text-gray-300">
                  <%= @order.original_email_from.presence || @order.customer_name %>
                </span>
              </div>
            </div>
            <span class="text-gray-300 dark:text-gray-600">·</span>
            <span><%= @order.created_at.strftime("%Y년 %m월 %d일 %H:%M") %></span>
          </div>
        </div>

        <%# Action Buttons %>
        <div class="flex items-center gap-2 flex-shrink-0">
          <%= status_badge(@order) %>
          <% if @order.status.to_s == "inbox" %>
            <%= button_to convert_email_to_order_path(@order),
                data: { turbo_confirm: "칸반 보드로 이동하시겠습니까?" },
                class: "flex items-center gap-1.5 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              칸반으로 이동
            <% end %>
          <% else %>
            <%= link_to order_path(@order), class: "flex items-center gap-1.5 px-4 py-2 bg-accent hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              발주 상세 보기
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Meta Chips %>
      <div class="flex flex-wrap items-center gap-2 mt-4">
        <%= priority_badge(@order) %>
        <% if @order.due_date %>
          <%= due_badge(@order) %>
          <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full bg-orange-50 dark:bg-orange-900/20 text-orange-700 dark:text-orange-400 border border-orange-100 dark:border-orange-800/50">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            납기 <%= @order.due_date.strftime("%Y/%m/%d") %>
          </span>
        <% end %>
        <% if @order.source_email_id.present? %>
          <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 border border-purple-100 dark:border-purple-800/50">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Gmail 수신 · ID: <%= @order.source_email_id %>
          </span>
        <% end %>
        <% @order.tags_array.each do |tag| %>
          <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">#<%= tag %></span>
        <% end %>
      </div>
    </div>

    <%# Key Info Grid %>
    <% if @order.item_name.present? || @order.estimated_value.present? || @order.client || @order.project %>
      <div class="px-6 py-4 bg-gray-50 dark:bg-gray-700/30 border-b border-gray-100 dark:border-gray-700">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
          <% if @order.client %>
            <div>
              <dt class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">발주처</dt>
              <dd class="font-medium text-gray-900 dark:text-white"><%= @order.client.name %></dd>
            </div>
          <% end %>
          <% if @order.item_name.present? %>
            <div>
              <dt class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">품목</dt>
              <dd class="font-medium text-gray-900 dark:text-white"><%= @order.item_name %><%= " × #{@order.quantity}" if @order.quantity %></dd>
            </div>
          <% end %>
          <% if @order.estimated_value.present? %>
            <div>
              <dt class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">예상 금액</dt>
              <dd class="font-medium text-gray-900 dark:text-white">
                <%= number_to_currency(@order.estimated_value, unit: @order.currency.presence || "$", format: "%u %n") %>
              </dd>
            </div>
          <% end %>
          <% if @order.project %>
            <div>
              <dt class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">현장</dt>
              <dd class="font-medium text-gray-900 dark:text-white"><%= @order.project.name %></dd>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Email Body %>
    <div class="px-6 py-6">
      <% body = @order.original_email_body.presence || @order.description %>
      <% if body.present? %>
        <div class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap font-mono bg-gray-50 dark:bg-gray-800/50 rounded-lg p-5 border border-gray-100 dark:border-gray-700 max-h-96 overflow-y-auto">
          <%= body %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-12 text-center">
          <svg class="w-10 h-10 text-gray-200 dark:text-gray-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <p class="text-xs text-gray-400 dark:text-gray-500">이메일 본문이 없습니다</p>
        </div>
      <% end %>

      <%# LLM 분석 결과 카드 %>
      <% if @order.respond_to?(:rfq_confidence) && @order.rfq_confidence.present? && @order.rfq_confidence != "none" %>
        <div class="mt-4 border border-gray-100 dark:border-gray-700 rounded-lg overflow-hidden">
          <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
            <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              AI 분석 결과
            </span>
            <%# 신뢰도 게이지 %>
            <div class="flex items-center gap-2">
              <div class="w-24 h-1.5 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-500 <%= @order.rfq_confidence == 'high' ? 'bg-green-500' : @order.rfq_confidence == 'medium' ? 'bg-yellow-500' : 'bg-gray-400' %>"
                     style="width: <%= @order.respond_to?(:rfq_score) ? (@order.rfq_score || 0) : 0 %>%"></div>
              </div>
              <span class="text-xs font-bold <%= @order.rfq_confidence == 'high' ? 'text-green-600 dark:text-green-400' : @order.rfq_confidence == 'medium' ? 'text-yellow-600 dark:text-yellow-400' : 'text-gray-500 dark:text-gray-400' %>">
                <%= @order.respond_to?(:rfq_score) ? (@order.rfq_score || 0) : 0 %>점
              </span>
            </div>
          </div>
          <div class="px-4 py-3">
            <% if @order.respond_to?(:llm_analysis) && @order.llm_analysis.present? %>
              <% begin; analysis = JSON.parse(@order.llm_analysis); rescue; analysis = {}; end %>
              <% if analysis["reason"].present? %>
                <p class="text-xs text-gray-600 dark:text-gray-400 mb-3 italic">"<%= analysis["reason"] %>"</p>
              <% end %>
              <% extracted = analysis["extracted"] || {} %>
              <% info_items = [] %>
              <% info_items << ["품목", extracted["items"]&.join(", ")] if extracted["items"]&.any? %>
              <% info_items << ["수량", extracted["quantities"]&.join(", ")] if extracted["quantities"]&.any? %>
              <% info_items << ["프로젝트", extracted["project_name"]] if extracted["project_name"].present? %>
              <% info_items << ["납기", extracted["due_date"]] if extracted["due_date"].present? %>
              <% info_items << ["위치", extracted["delivery_location"]] if extracted["delivery_location"].present? %>
              <% info_items << ["금액", "#{extracted['currency']} #{extracted['estimated_value']}"] if extracted["estimated_value"].present? %>
              <% if info_items.any? %>
                <dl class="grid grid-cols-2 gap-x-4 gap-y-1.5">
                  <% info_items.each do |label, value| %>
                    <div>
                      <dt class="text-xs text-gray-400 dark:text-gray-500"><%= label %></dt>
                      <dd class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= value %></dd>
                    </div>
                  <% end %>
                </dl>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# 첨부파일 + 링크 패널 %>
      <% attachments = @order.respond_to?(:attachment_urls) && @order.attachment_urls.present? ? (JSON.parse(@order.attachment_urls) rescue []) : [] %>
      <% links = @order.respond_to?(:extracted_links) && @order.extracted_links.present? ? (JSON.parse(@order.extracted_links) rescue []) : [] %>
      <% if attachments.any? || links.any? %>
        <div class="mt-3 border border-gray-100 dark:border-gray-700 rounded-lg overflow-hidden">
          <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-700">
            <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
              첨부파일 및 링크
            </span>
          </div>
          <div class="px-4 py-3 space-y-2">
            <% attachments.each do |att| %>
              <% att = att.is_a?(Hash) ? att.with_indifferent_access : {} %>
              <% icon_color = att[:mime_type].to_s.include?("pdf") ? "text-red-500" : att[:mime_type].to_s.include?("sheet") || att[:mime_type].to_s.include?("excel") ? "text-green-600" : "text-blue-500" %>
              <a href="<%= att[:signed_url] %>" target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-2.5 p-2.5 rounded-lg border border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                <svg class="w-8 h-8 p-1.5 rounded bg-gray-100 dark:bg-gray-700 <%= icon_color %> flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate"><%= att[:filename] %></p>
                  <p class="text-xs text-gray-400 dark:text-gray-500">
                    <%= att[:mime_type]&.split("/")&.last&.upcase %>
                    <% if att[:size] %> · <%= number_to_human_size(att[:size]) %><% end %>
                  </p>
                </div>
                <svg class="w-3.5 h-3.5 text-gray-300 dark:text-gray-600 group-hover:text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            <% end %>
            <% links.each do |url| %>
              <a href="<%= url %>" target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span class="text-xs text-blue-500 hover:underline truncate"><%= url.truncate(60) %></span>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Footer %>
    <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/20 flex items-center justify-between">
      <p class="text-xs text-gray-400 dark:text-gray-500">
        발주 #<%= @order.id %> · <%= time_ago_in_words(@order.created_at) %> 전 생성
      </p>
      <%= link_to order_path(@order), class: "text-sm text-accent hover:underline flex items-center gap-1" do %>
        발주 상세 전체 보기
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      <% end %>
    </div>
  </div>

  <%# ── 발신처 카드 (이메일 서명 파싱 결과) ──────────────────── %>
  <% sig = @order.email_signature %>
  <% if sig.present? || @order.original_email_from.present? %>
    <div class="bg-gray-50 dark:bg-gray-700/30 rounded-xl border border-gray-200 dark:border-gray-700 p-5 mb-6">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          발신처 정보
        </h3>
        <%# 담당자로 저장 버튼 (contact-person-management 연동) %>
        <% if @order.sender_domain.present? %>
          <%= button_to create_from_signature_contact_persons_path,
              params: { order_id: @order.id },
              method: :post,
              data: { turbo_confirm: "이 발신자를 담당자로 저장하시겠습니까?" },
              class: "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-accent text-white rounded-lg hover:bg-accent/90 transition-colors" do %>
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
            담당자로 저장
          <% end %>
        <% end %>
      </div>

      <%# 이니셜 아바타 + 이름/직책 %>
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
          <%= (sig[:name].presence || @order.sender_name.to_s).first(2).upcase.presence || "?" %>
        </div>
        <div class="flex-1 min-w-0">
          <% display_name = sig[:name].presence || @order.sender_name %>
          <% if display_name.present? %>
            <p class="text-sm font-semibold text-gray-900 dark:text-white"><%= display_name %></p>
          <% end %>
          <% if sig[:title].present? %>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= sig[:title] %></p>
          <% end %>
          <% if sig[:company].present? %>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= sig[:company] %></p>
          <% end %>
        </div>
      </div>

      <%# 연락처 그리드 %>
      <% contact_items = [] %>
      <% contact_items << { icon: "mail", label: sig[:email].presence || @order.original_email_from, href: "mailto:#{sig[:email].presence || @order.original_email_from}" } if sig[:email].present? || @order.original_email_from.present? %>
      <% contact_items << { icon: "phone", label: sig[:phone], href: "tel:#{sig[:phone]}" } if sig[:phone].present? %>
      <% contact_items << { icon: "smartphone", label: sig[:mobile], href: "tel:#{sig[:mobile]}" } if sig[:mobile].present? %>
      <% contact_items << { icon: "globe", label: sig[:website], href: sig[:website] } if sig[:website].present? %>
      <% if contact_items.any? %>
        <div class="mt-3 grid grid-cols-1 gap-1.5">
          <% contact_items.each do |item| %>
            <a href="<%= item[:href] %>" class="flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300 hover:text-accent truncate">
              <% if item[:icon] == "mail" %>
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <% elsif item[:icon] == "phone" %>
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <% elsif item[:icon] == "smartphone" %>
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
              <% else %>
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <% end %>
              <span class="truncate"><%= item[:label] %></span>
            </a>
          <% end %>
        </div>
      <% end %>

      <%# 주소 %>
      <% if sig[:address].present? %>
        <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 flex items-start gap-1.5">
          <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <%= sig[:address] %>
        </p>
      <% end %>

      <%# 도메인 정보 %>
      <% if @order.sender_domain.present? %>
        <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">도메인: <%= @order.sender_domain %></p>
      <% end %>
    </div>
  <% end %>

  <%# ── Related Orders from Same Sender ─────────────────────── %>
  <% if @order.original_email_from.present? %>
    <% same_sender = Order.where(original_email_from: @order.original_email_from)
                          .where.not(id: @order.id)
                          .order(created_at: :desc).limit(5) %>
    <% if same_sender.any? %>
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 mb-6">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-3">
          <svg class="w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          같은 발신자의 다른 이메일
        </h3>
        <ul class="space-y-1">
          <% same_sender.each do |o| %>
            <li>
              <%= link_to inbox_email_path(o), class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group" do %>
                <span class="text-sm text-gray-900 dark:text-white group-hover:text-accent truncate flex-1">
                  <%= o.original_email_subject.presence || o.title %>
                </span>
                <%= status_badge(o) %>
                <span class="text-xs text-gray-400 dark:text-gray-500 flex-shrink-0"><%= o.created_at.strftime("%m/%d") %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>

  <%# ── Quick Actions ────────────────────────────────────────── %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">빠른 액션</h3>
    <div class="flex flex-wrap gap-3">
      <% if @order.status.to_s == "inbox" %>
        <%= button_to convert_email_to_order_path(@order),
            data: { turbo_confirm: "칸반 보드로 이동하시겠습니까?" },
            class: "flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          칸반으로 이동
        <% end %>
      <% end %>
      <%= link_to order_path(@order), class: "flex items-center gap-2 px-4 py-2 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        발주 상세
      <% end %>
      <%= link_to kanban_path, class: "flex items-center gap-2 px-4 py-2 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        칸반 보드
      <% end %>
      <%= link_to inbox_path, class: "flex items-center gap-2 px-4 py-2 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
        받은편지함
      <% end %>
    </div>
  </div>

</div>
