<% content_for :page_title, "Edit Order" %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to order_path(@order), class: "text-gray-400 hover:text-gray-600" do %>
      <i class="lni lni-arrow-left text-lg"></i>
    <% end %>
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Edit Order</h2>
    <span class="text-gray-400 dark:text-gray-500 text-sm">· <%= @order.title.truncate(40) %></span>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
    <%= render "form", order: @order %>
  </div>
</div>
