<% content_for :title, "새 주문 등록" %>

<%# 배경 오버레이 — 클릭 시 칸반으로 돌아감 %>
<div class="fixed inset-0 bg-black/40 z-40" onclick="history.back()"></div>

<%# 슬라이드오버 패널 %>
<div class="fixed top-0 right-0 h-full w-full max-w-xl bg-white dark:bg-gray-800
            shadow-2xl z-50 flex flex-col overflow-hidden">
  <%# 헤더 %>
  <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex-shrink-0">
    <div class="flex-1">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">새 주문 등록</h2>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">수동으로 신규 구매 주문을 생성합니다</p>
    </div>
    <%= link_to kanban_path,
          class: "p-1.5 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex-shrink-0" do %>
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    <% end %>
  </div>

  <%# 폼 바디 (스크롤 가능) %>
  <div class="flex-1 overflow-y-auto p-6">
    <%= render "form", order: @order %>
  </div>
</div>

<script>
  // ESC 키로 닫기
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') history.back();
  });
</script>
