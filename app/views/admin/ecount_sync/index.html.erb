<%# Admin: eCountERP API 동기화 관리 화면 %>
<div class="max-w-5xl mx-auto px-4 py-6">

  <%# 헤더 %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-white">eCountERP API 동기화</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">품목·거래처 자동 동기화 현황 및 수동 실행</p>
    </div>
    <% if @failed_today > 0 %>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 text-sm font-medium">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        오늘 실패 <%= @failed_today %>건
      </span>
    <% end %>
  </div>

  <%# 동기화 상태 카드 %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">

    <%# 품목 동기화 카드 %>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">품목 동기화</p>
            <p class="text-xs text-gray-400 dark:text-gray-500">매 시간 30분 자동 실행</p>
          </div>
        </div>
        <%= button_to trigger_admin_ecount_sync_index_path, method: :post,
              params: { sync_type: "products" },
              class: "text-xs px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors flex items-center gap-1" do %>
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          즉시 실행
        <% end %>
      </div>
      <% if @products_last %>
        <div class="space-y-1.5 text-sm">
          <div class="flex justify-between text-gray-600 dark:text-gray-400">
            <span>마지막 성공</span>
            <span class="font-medium text-gray-900 dark:text-white"><%= @products_last.completed_at&.strftime("%m/%d %H:%M") %></span>
          </div>
          <div class="flex justify-between text-gray-600 dark:text-gray-400">
            <span>처리 / 성공</span>
            <span class="font-medium"><%= @products_last.total_count %> / <span class="text-green-600"><%= @products_last.success_count %></span></span>
          </div>
          <% if @products_last.error_count > 0 %>
            <div class="flex justify-between text-gray-600 dark:text-gray-400">
              <span>실패</span>
              <span class="font-medium text-red-600"><%= @products_last.error_count %>건</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 dark:text-gray-500">아직 동기화 이력이 없습니다.</p>
      <% end %>
    </div>

    <%# 거래처 동기화 카드 %>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-green-50 dark:bg-green-900/30 flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">거래처 동기화</p>
            <p class="text-xs text-gray-400 dark:text-gray-500">매 시간 45분 자동 실행</p>
          </div>
        </div>
        <%= button_to trigger_admin_ecount_sync_index_path, method: :post,
              params: { sync_type: "customers" },
              class: "text-xs px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg font-medium transition-colors flex items-center gap-1" do %>
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          즉시 실행
        <% end %>
      </div>
      <% if @customers_last %>
        <div class="space-y-1.5 text-sm">
          <div class="flex justify-between text-gray-600 dark:text-gray-400">
            <span>마지막 성공</span>
            <span class="font-medium text-gray-900 dark:text-white"><%= @customers_last.completed_at&.strftime("%m/%d %H:%M") %></span>
          </div>
          <div class="flex justify-between text-gray-600 dark:text-gray-400">
            <span>처리 / 성공</span>
            <span class="font-medium"><%= @customers_last.total_count %> / <span class="text-green-600"><%= @customers_last.success_count %></span></span>
          </div>
          <% if @customers_last.error_count > 0 %>
            <div class="flex justify-between text-gray-600 dark:text-gray-400">
              <span>실패</span>
              <span class="font-medium text-red-600"><%= @customers_last.error_count %>건</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 dark:text-gray-500">아직 동기화 이력이 없습니다.</p>
      <% end %>
    </div>
  </div>

  <%# 동기화 이력 테이블 %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700">
      <h2 class="font-semibold text-gray-900 dark:text-white text-sm">동기화 이력 (최근 50건)</h2>
    </div>
    <% if @logs.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">유형</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">상태</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">총건수</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">성공</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">실패</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">소요시간</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">시작시각</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            <% @logs.each do |log| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30">
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                    <%= log.sync_type == 'products' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400' : 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' %>">
                    <%= log.sync_type == 'products' ? '품목' : log.sync_type == 'customers' ? '거래처' : '전표' %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <% status_styles = {
                    "completed" => "text-green-600 dark:text-green-400",
                    "failed"    => "text-red-600 dark:text-red-400",
                    "running"   => "text-blue-600 dark:text-blue-400",
                    "pending"   => "text-gray-400"
                  } %>
                  <span class="text-xs font-medium <%= status_styles[log.status] || 'text-gray-500' %>">
                    <%= { "completed" => "완료", "failed" => "실패", "running" => "진행중", "pending" => "대기" }[log.status] || log.status %>
                  </span>
                </td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300 tabular-nums"><%= log.total_count %></td>
                <td class="px-4 py-3 text-right text-green-600 dark:text-green-400 tabular-nums font-medium"><%= log.success_count %></td>
                <td class="px-4 py-3 text-right tabular-nums">
                  <% if log.error_count > 0 %>
                    <span class="text-red-600 dark:text-red-400 font-medium"><%= log.error_count %></span>
                  <% else %>
                    <span class="text-gray-300 dark:text-gray-600">—</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right text-gray-500 dark:text-gray-400 tabular-nums text-xs">
                  <%= log.duration_seconds ? "#{log.duration_seconds}s" : "—" %>
                </td>
                <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs tabular-nums">
                  <%= log.started_at&.strftime("%m/%d %H:%M") || "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <svg class="w-12 h-12 text-gray-200 dark:text-gray-600 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        <p class="text-sm font-medium text-gray-400 dark:text-gray-500">동기화 이력이 없습니다.</p>
        <p class="text-xs text-gray-300 dark:text-gray-600 mt-1">위에서 즉시 실행 버튼을 누르거나 설정된 스케줄을 기다리세요.</p>
      </div>
    <% end %>
  </div>

  <%# credentials 설정 안내 %>
  <div class="mt-4 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <div class="text-sm text-amber-800 dark:text-amber-300">
        <p class="font-semibold mb-1">API 키 설정 필요</p>
        <p class="text-xs">eCountERP API를 사용하려면 Rails credentials에 키를 설정해야 합니다:</p>
        <code class="block mt-2 bg-amber-100 dark:bg-amber-900/40 rounded px-2 py-1.5 text-xs font-mono">bin/rails credentials:edit</code>
        <pre class="mt-2 bg-amber-100 dark:bg-amber-900/40 rounded px-2 py-1.5 text-xs font-mono">ecount:
  com_code: "148829"
  user_id: "K_KDS"
  api_cert_key: "YOUR_API_CERT_KEY"
  lan_type: "ko"</pre>
      </div>
    </div>
  </div>

</div>
