<% content_for :title, "발주처 관리" %>

<div class="flex flex-col gap-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">발주처 관리</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">발주처별 거래 현황 및 담당자 관리</p>
    </div>
    <%= link_to new_client_path, class: "inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary-dark transition-colors" do %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      새 발주처 등록
    <% end %>
  </div>

  <!-- 검색/필터 -->
  <%= form_with url: clients_path, method: :get, local: true, class: "flex gap-3 items-center flex-wrap" do |f| %>
    <div class="relative flex-1 max-w-xs">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <%= f.text_field :q, placeholder: "회사명, 코드 검색...", value: params[:q],
          class: "w-full pl-9 pr-3 py-2 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %>
    </div>
    <%= f.select :country, options_for_select([["전체 국가", ""], ["AE", "AE"], ["KR", "KR"], ["CH", "CH"], ["US", "US"]], params[:country]),
        {}, class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %>
    <%= f.select :industry, options_for_select([["전체 산업", ""]] + Client::INDUSTRIES.map { |i| [{ "nuclear"=>"원전","hydro"=>"수력","tunnel"=>"터널","gtx"=>"GTX","construction"=>"건설","general"=>"일반" }[i] || i, i] }, params[:industry]),
        {}, class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %>
    <%= f.select :sort, options_for_select([["이름순", ""], ["거래금액순", "value"], ["오더건수순", "orders"]], params[:sort]),
        {}, class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %>
    <%= f.submit "검색", class: "bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-600 cursor-pointer" %>
  <% end %>

  <!-- 통계 카드 -->
  <div class="grid grid-cols-3 gap-4">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">총 발주처</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @total_count %></p>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">현재 <%= @clients.size %>개 표시 중</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">총 거래금액</p>
      <p class="text-2xl font-bold text-primary mt-1">$<%= number_with_delimiter(@total_value.round.to_i) %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">활성 오더</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @clients.sum(&:active_orders_count) %></p>
    </div>
  </div>

  <!-- 테이블 -->
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 dark:bg-gray-700/50 border-b border-gray-100 dark:border-gray-700">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">회사명</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">국가</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">산업</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">신용</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">리스크</th>
          <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">오더</th>
          <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">거래금액</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
        <% @clients.each do |client| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900 dark:text-white"><%= client.name %></div>
              <div class="text-xs text-gray-400 dark:text-gray-500"><%= client.code %></div>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400"><%= client.country %></td>
            <td class="px-4 py-3">
              <% if client.industry.present? %>
                <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400"><%= client.industry_label %></span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if client.credit_grade.present? %>
                <% grade_class = { "A" => "bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400", "B" => "bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400", "C" => "bg-yellow-50 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400", "D" => "bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400" }[client.credit_grade] || "bg-gray-50 text-gray-700 dark:bg-gray-700 dark:text-gray-400" %>
                <span class="inline-flex px-2 py-0.5 text-xs font-bold rounded-full <%= grade_class %>"><%= client.credit_grade %>등급</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <%
                c_total     = client.orders.count
                c_delivered = client.orders.where(status: :delivered).count
                c_overdue   = client.orders.where("due_date < ? AND status != ?", Date.today, Order.statuses[:delivered]).count
                c_rate      = c_total > 0 ? (c_delivered.to_f / c_total * 100).round(1) : nil
                risk_grade  = if c_rate.nil? then nil
                              elsif c_rate >= 90 && c_overdue == 0 then "A"
                              elsif c_rate >= 75 || c_overdue <= 1  then "B"
                              elsif c_rate >= 60 || c_overdue <= 3  then "C"
                              else "D"
                              end
                risk_cls = { "A" => "bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400",
                             "B" => "bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
                             "C" => "bg-yellow-50 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400",
                             "D" => "bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400" }
              %>
              <% if risk_grade %>
                <span class="inline-flex px-2 py-0.5 text-xs font-bold rounded-full <%= risk_cls[risk_grade] %>"><%= risk_grade %></span>
              <% else %>
                <span class="text-xs text-gray-300 dark:text-gray-600">-</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right text-sm text-gray-700 dark:text-gray-300"><%= client.orders.count %></td>
            <td class="px-4 py-3 text-right text-sm font-medium text-gray-900 dark:text-white">$<%= number_with_delimiter(client.total_order_value.round.to_i) %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to "상세", client, class: "text-xs text-primary hover:underline" %>
            </td>
          </tr>
        <% end %>
        <% if @clients.empty? %>
          <tr><td colspan="8" class="px-4 py-12 text-center text-gray-400 dark:text-gray-500 text-sm">등록된 발주처가 없습니다.</td></tr>
        <% end %>
      </tbody>
    </table>

    <!-- 페이지네이션 -->
    <% if @total_pages > 1 %>
      <div class="px-4 py-3 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
        <p class="text-xs text-gray-500 dark:text-gray-400">
          총 <%= @total_count %>개 중 <%= [(@page - 1) * @per_page + 1, @total_count].min %>–<%= [@page * @per_page, @total_count].min %>개 표시
        </p>
        <div class="flex gap-1">
          <% if @page > 1 %>
            <%= link_to clients_path(params.permit(:q, :country, :industry, :sort).merge(page: @page - 1)),
                class: "px-3 py-1 text-xs rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
              ← 이전
            <% end %>
          <% end %>
          <% ([@page - 2, 1].max..[@page + 2, @total_pages].min).each do |p| %>
            <%= link_to p, clients_path(params.permit(:q, :country, :industry, :sort).merge(page: p)),
                class: "px-3 py-1 text-xs rounded-lg #{p == @page ? 'bg-primary text-white' : 'border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700'}" %>
          <% end %>
          <% if @page < @total_pages %>
            <%= link_to clients_path(params.permit(:q, :country, :industry, :sort).merge(page: @page + 1)),
                class: "px-3 py-1 text-xs rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
              다음 →
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
