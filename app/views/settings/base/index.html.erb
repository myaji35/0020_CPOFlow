<%# Settings — main page with Gmail connection management %>
<div class="max-w-4xl mx-auto py-8 px-4">

  <%# Page header %>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Settings</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage your account preferences and integrations</p>
  </div>

  <%# Flash messages %>
  <% if notice %>
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-green-800 text-sm flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <%= notice %>
    </div>
  <% end %>
  <% if alert %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-800 text-sm flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%= alert %>
    </div>
  <% end %>

  <%# --- Gmail Integration Section --- %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-6">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%# Gmail G icon (inline SVG) %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 18H17V9.24L12 13L7 9.24V18H4V6H6.2L12 10.76L17.8 6H20V18Z" fill="#EA4335"/>
        </svg>
        <div>
          <h2 class="text-base font-semibold text-gray-900">Gmail Integration</h2>
          <p class="text-xs text-gray-500">Auto-detect RFQ emails and convert to Kanban cards</p>
        </div>
      </div>
      <%= link_to gmail_oauth_authorize_path, class: "flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Connect Gmail
      <% end %>
    </div>

    <% if @email_accounts.any? %>
      <ul class="divide-y divide-gray-100">
        <% @email_accounts.each do |account| %>
          <li class="px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <%# Status dot %>
              <span class="w-2 h-2 rounded-full <%= account.connected? ? 'bg-green-500' : 'bg-gray-300' %>"></span>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= account.email %></p>
                <p class="text-xs text-gray-500">
                  <% if account.connected? %>
                    <% if account.last_synced_at %>
                      Last synced <%= time_ago_in_words(account.last_synced_at) %> ago
                    <% else %>
                      Connected — not synced yet
                    <% end %>
                    &nbsp;·&nbsp;
                    <span class="text-green-600 font-medium">Active</span>
                  <% else %>
                    Disconnected
                  <% end %>
                </p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <% if account.connected? %>
                <%# Manual sync trigger %>
                <%= button_to "Sync Now", sync_settings_email_account_path(account), method: :post, class: "text-xs px-3 py-1.5 border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition-colors", disabled: account.synced_recently? %>
              <% end %>
              <%# Disconnect %>
              <%= link_to "Disconnect", gmail_oauth_disconnect_path(account), data: { turbo_method: :delete, turbo_confirm: "Disconnect #{account.email}?" }, class: "text-xs px-3 py-1.5 border border-red-200 text-red-600 rounded-lg hover:bg-red-50 transition-colors" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-8 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto text-gray-300 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <p class="text-sm text-gray-500">No Gmail accounts connected.</p>
        <p class="text-xs text-gray-400 mt-1">Connect your Gmail to auto-import RFQ emails.</p>
      </div>
    <% end %>
  </div>

  <%# --- Profile Section --- %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-6">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Profile</h2>
    </div>
    <%= form_with url: settings_profile_path, method: :patch, class: "px-6 py-4 space-y-4" do |f| %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Name</label>
          <%= f.text_field :name, value: current_user.name, class: "w-full border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Email</label>
          <input type="text" value="<%= current_user.email %>" disabled class="w-full border border-gray-100 dark:border-gray-700 rounded-lg px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 text-gray-400 cursor-not-allowed" />
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Branch</label>
        <input type="text" value="<%= current_user.branch.to_s.humanize %>" disabled class="w-full border border-gray-100 dark:border-gray-700 rounded-lg px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 text-gray-400 cursor-not-allowed" />
      </div>
      <div class="flex justify-end">
        <%= f.submit "Save Changes", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%# --- Language & Theme Section --- %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-6">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center gap-3">
      <svg class="w-5 h-5 text-gray-500 dark:text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      <div>
        <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">환경설정</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400">언어 및 화면 테마를 설정합니다</p>
      </div>
    </div>

    <%# 언어 설정 %>
    <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-900 dark:text-gray-100">언어 / Language</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">인터페이스 표시 언어를 선택합니다</p>
        </div>
        <div class="flex gap-2">
          <% [["한국어", "ko"], ["English", "en"], ["العربية", "ar"]].each do |label, code| %>
            <%= button_to settings_update_locale_path, method: :patch,
                params: { locale: code },
                class: "px-4 py-2 text-sm font-medium rounded-lg border transition-colors #{current_user.preferred_locale == code ? 'bg-primary text-white border-primary' : 'border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-primary hover:text-primary dark:hover:border-accent dark:hover:text-accent'}" do %>
              <%= label %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <%# 다크모드 설정 %>
    <div class="px-6 py-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-900 dark:text-gray-100">테마 / Theme</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">라이트, 다크, 또는 시스템 설정에 따릅니다</p>
        </div>
        <div class="flex gap-2">
          <% [
            ["라이트", "light", "☀️"],
            ["다크", "dark", "🌙"],
            ["시스템", "system", "💻"]
          ].each do |label, code, icon| %>
            <%= button_to settings_update_theme_path, method: :patch,
                params: { theme: code },
                class: "flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg border transition-colors #{current_user.preferred_theme == code ? 'bg-primary text-white border-primary' : 'border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-primary hover:text-primary dark:hover:border-accent dark:hover:text-accent'}" do %>
              <span><%= icon %></span>
              <span><%= label %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# --- Admin Only Section --- %>
  <% if current_user.admin? %>

  <%# Google Sheets 연동 설정 (Admin Only) %>
  <% sheets_url = AppConfig.sheets_spreadsheet_url %>
  <% sheets_id  = AppConfig.sheets_spreadsheet_id %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-6">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center gap-3">
      <%# Google Sheets 아이콘 %>
      <svg class="w-5 h-5 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="M3 9h18M3 15h18M9 3v18"/>
      </svg>
      <div>
        <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Google Sheets 연동 <span class="text-xs font-normal text-gray-400 dark:text-gray-500 ml-1">Admin only</span></h2>
        <p class="text-xs text-gray-500 dark:text-gray-400">경영진용 데이터 대시보드 스프레드시트 연결</p>
      </div>
    </div>

    <div class="px-6 py-5">
      <%# 현재 연동 상태 %>
      <% if sheets_id.present? %>
        <div class="flex items-center gap-2 mb-4 px-3 py-2 bg-green-50 dark:bg-green-900/20 rounded-lg">
          <svg class="w-4 h-4 text-green-600 dark:text-green-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-green-800 dark:text-green-300">연동됨</p>
            <p class="text-xs text-green-600 dark:text-green-400 font-mono truncate">ID: <%= sheets_id %></p>
          </div>
          <% if sheets_url.present? %>
            <a href="<%= sheets_url %>" target="_blank" rel="noopener"
               class="flex items-center gap-1 text-xs text-green-700 dark:text-green-400 hover:underline flex-shrink-0">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Sheets 열기
            </a>
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center gap-2 mb-4 px-3 py-2 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
          <svg class="w-4 h-4 text-gray-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p class="text-xs text-gray-500 dark:text-gray-400">아직 연동된 Spreadsheet가 없습니다.</p>
        </div>
      <% end %>

      <%# URL 입력 폼 %>
      <%= form_with url: admin_sheets_config_path, method: :patch, class: "space-y-3" do |f| %>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">
            Google Sheets URL
          </label>
          <div class="flex gap-2">
            <input type="url" name="spreadsheet_url"
                   value="<%= sheets_url %>"
                   placeholder="https://docs.google.com/spreadsheets/d/..."
                   class="flex-1 border border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 font-mono placeholder:font-sans placeholder:text-gray-400" />
            <button type="submit"
                    class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">
              저장
            </button>
          </div>
          <p class="mt-1.5 text-xs text-gray-400 dark:text-gray-500">
            구글 드라이브에서 스프레드시트를 열고 주소창의 URL 전체를 붙여넣으세요.
            Service Account 이메일을 <strong>편집자</strong>로 추가해야 동기화가 됩니다.
          </p>
        </div>
      <% end %>

      <%# 초기화 버튼 (연동된 경우만 표시) %>
      <% if sheets_id.present? %>
        <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
          <p class="text-xs text-gray-400 dark:text-gray-500">연동을 해제하고 초기화합니다.</p>
          <%= button_to admin_sheets_config_clear_path, method: :delete,
              data: { turbo_confirm: "Google Sheets 연동을 초기화하시겠습니까?" },
              class: "text-xs px-3 py-1.5 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-50 dark:hover:bg-red-950 transition-colors" do %>
            연동 초기화
          <% end %>
        </div>
      <% end %>

      <%# Service Account 안내 %>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700">
        <p class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-2">Service Account 설정 안내</p>
        <ol class="text-xs text-gray-500 dark:text-gray-400 space-y-1 list-decimal list-inside">
          <li>Google Cloud Console → Service Account 생성</li>
          <li>JSON 키 다운로드</li>
          <li><code class="bg-gray-100 dark:bg-gray-700 px-1 rounded font-mono">bin/rails credentials:edit</code> 에서 <code class="bg-gray-100 dark:bg-gray-700 px-1 rounded font-mono">google.service_account</code> 등록</li>
          <li>스프레드시트 → 공유 → Service Account 이메일을 <strong>편집자</strong>로 추가</li>
          <li>위 URL 입력창에 스프레드시트 URL 붙여넣기 → 저장</li>
        </ol>
      </div>
    </div>
  </div>

  <%# 메뉴 권한 관리 %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-6">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
      <div>
        <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">메뉴 권한 관리</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400">역할별 메뉴 접근 및 CRUD 권한 설정</p>
      </div>
      <%= link_to settings_menu_permissions_path, class: "text-sm text-primary dark:text-accent hover:underline" do %>
        권한 설정 →
      <% end %>
    </div>
  </div>

  <% end %>

  <%# --- eCountERP API 연동 상태 (manager+ 만 표시) --- %>
  <% if current_user.role.in?(%w[admin manager]) %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">eCountERP API 연동</h2>
      <%= link_to admin_ecount_sync_index_path, class: "text-xs text-blue-600 hover:underline dark:text-blue-400" do %>
        동기화 관리
        <svg class="w-3 h-3 inline ml-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      <% end %>
    </div>
    <div class="px-6 py-4 space-y-3">
      <% products_last  = EcountSyncLog.where(sync_type: "products",  status: :completed).order(:completed_at).last %>
      <% customers_last = EcountSyncLog.where(sync_type: "customers", status: :completed).order(:completed_at).last %>
      <% ecount_configured = Rails.application.credentials.dig(:ecount, :api_cert_key).present? rescue false %>

      <div class="flex items-center justify-between text-sm">
        <span class="text-gray-600 dark:text-gray-400">API 연결 상태</span>
        <% if ecount_configured %>
          <span class="inline-flex items-center gap-1 text-green-600 dark:text-green-400 font-medium text-xs">
            <span class="w-2 h-2 rounded-full bg-green-500"></span> 설정됨
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400 font-medium text-xs">
            <span class="w-2 h-2 rounded-full bg-amber-500"></span> 미설정
          </span>
        <% end %>
      </div>

      <div class="flex items-center justify-between text-sm">
        <span class="text-gray-600 dark:text-gray-400">품목 마지막 동기화</span>
        <span class="text-gray-900 dark:text-gray-200 text-xs tabular-nums">
          <%= products_last ? products_last.completed_at.strftime("%m/%d %H:%M") : "없음" %>
        </span>
      </div>

      <div class="flex items-center justify-between text-sm">
        <span class="text-gray-600 dark:text-gray-400">거래처 마지막 동기화</span>
        <span class="text-gray-900 dark:text-gray-200 text-xs tabular-nums">
          <%= customers_last ? customers_last.completed_at.strftime("%m/%d %H:%M") : "없음" %>
        </span>
      </div>
    </div>
  </div>
  <% end %>

  <%# --- Danger Zone --- %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-red-100 dark:border-red-900">
    <div class="px-6 py-4 border-b border-red-100 dark:border-red-900">
      <h2 class="text-base font-semibold text-red-700 dark:text-red-400">Danger Zone</h2>
    </div>
    <div class="px-6 py-4 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-900 dark:text-gray-100">Sign out of all sessions</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">This will sign you out from all devices</p>
      </div>
      <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "px-4 py-2 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950 text-sm font-medium rounded-lg transition-colors" %>
    </div>
  </div>

</div>
