<% content_for :title, @employee.name %>

<div class="flex flex-col gap-6">
  <!-- Header -->
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-4">
      <!-- FR-01: 아바타 (64px) -->
      <div class="w-16 h-16 rounded-full <%= @employee.avatar_color %> flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
        <%= @employee.initials %>
      </div>
      <div>
        <div class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500 mb-1">
          <%= link_to "직원 관리", employees_path, class: "hover:text-primary" %>
          <span>/</span>
          <span><%= @employee.name %></span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @employee.name %></h1>
        <div class="flex items-center gap-3 mt-1.5 text-sm text-gray-500 dark:text-gray-400">
          <% if @employee.name_en.present? %><span><%= @employee.name_en %></span><% end %>
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400"><%= @employee.nationality_label %></span>
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400"><%= @employee.employment_type_label %></span>
          <% if @employee.job_title.present? %>
            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400"><%= @employee.job_title %></span>
          <% end %>
          <% unless @employee.active? %>
            <span class="inline-flex px-2 py-0.5 text-xs font-bold rounded-full bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400">퇴직</span>
          <% end %>
        </div>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_employee_path(@employee), class: "inline-flex items-center gap-1 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 px-3 py-2 rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-700" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        수정
      <% end %>
      <% if current_user.manager? || current_user.admin? %>
        <%= link_to employee_path(@employee), data: { turbo_method: :delete, turbo_confirm: "직원을 삭제하시겠습니까?" },
            class: "inline-flex items-center gap-1 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 px-3 py-2 rounded-lg text-sm hover:bg-red-50 dark:hover:bg-red-900/20" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6m4-6v6"/><path d="M9 6V4h6v2"/></svg>
          삭제
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- KPI 카드 -->
  <div class="grid grid-cols-4 gap-4">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">재직 기간</p>
      <% if @employee.hire_date %>
        <!-- FR-05: tenure_label -->
        <p class="text-xl font-bold text-gray-900 dark:text-white mt-1"><%= @employee.tenure_label %></p>
        <p class="text-xs text-gray-400 dark:text-gray-500"><%= @employee.hire_date.strftime("%Y.%m.%d") %> 입사 (<%= @employee.tenure_days %>일)</p>
      <% else %>
        <p class="text-xl font-bold text-gray-400 dark:text-gray-500 mt-1">-</p>
      <% end %>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">현재 현장</p>
      <% assignment = @employee.current_assignment %>
      <% if assignment %>
        <p class="text-sm font-bold text-primary mt-1"><%= assignment.project.name %></p>
        <p class="text-xs text-gray-400 dark:text-gray-500"><%= assignment.role %></p>
      <% else %>
        <p class="text-xl font-bold text-gray-400 dark:text-gray-500 mt-1">-</p>
      <% end %>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">비자 만료까지</p>
      <% visa = @employee.active_visa %>
      <% if visa %>
        <% days = visa.days_until_expiry %>
        <p class="text-xl font-bold <%= days <= 30 ? 'text-red-600 dark:text-red-400' : days <= 60 ? 'text-yellow-600 dark:text-yellow-400' : 'text-gray-900 dark:text-white' %> mt-1">
          <%= days >= 0 ? "D-#{days}" : "만료됨" %>
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500"><%= visa.expiry_date.strftime("%Y.%m.%d") %></p>
      <% else %>
        <p class="text-xl font-bold text-gray-400 dark:text-gray-500 mt-1">-</p>
      <% end %>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 p-4 shadow-sm">
      <p class="text-xs text-gray-500 dark:text-gray-400">계약 만료까지</p>
      <% contract = @employee.current_contract %>
      <% if contract&.end_date %>
        <% days = (contract.end_date - Date.today).to_i %>
        <p class="text-xl font-bold <%= days <= 14 ? 'text-red-600 dark:text-red-400' : days <= 30 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-900 dark:text-white' %> mt-1">
          <%= days >= 0 ? "D-#{days}" : "만료됨" %>
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500"><%= contract.end_date.strftime("%Y.%m.%d") %></p>
      <% else %>
        <p class="text-xl font-bold text-gray-400 dark:text-gray-500 mt-1">-</p>
      <% end %>
    </div>
  </div>

  <!-- FR-02: 탭 URL 직링크 -->
  <div x-data="{
    tab: new URLSearchParams(window.location.search).get('tab') || 'info',
    switchTab(t) {
      this.tab = t;
      const url = new URL(window.location);
      url.searchParams.set('tab', t);
      window.history.pushState({}, '', url);
    }
  }" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
    <div class="border-b border-gray-100 dark:border-gray-700 px-4">
      <nav class="flex gap-6">
        <button @click="switchTab('info')" :class="tab==='info' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">기본정보</button>
        <button @click="switchTab('visas')" :class="tab==='visas' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">비자 (<%= @visas.count %>)</button>
        <button @click="switchTab('contracts')" :class="tab==='contracts' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">계약 (<%= @contracts.count %>)</button>
        <button @click="switchTab('assignments')" :class="tab==='assignments' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">현장 배정 (<%= @assignments.count %>)</button>
        <button @click="switchTab('certs')" :class="tab==='certs' ? 'border-primary text-primary' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
            class="py-3 border-b-2 text-sm font-medium transition-colors">자격증 (<%= @certifications.count %>)</button>
      </nav>
    </div>

    <!-- 기본정보 탭 -->
    <div x-show="tab==='info'" class="p-6">
      <dl class="grid grid-cols-2 gap-x-8 gap-y-4 text-sm">
        <div><dt class="text-gray-500 dark:text-gray-400">이름 (한글)</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.name %></dd></div>
        <div><dt class="text-gray-500 dark:text-gray-400">이름 (영문)</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.name_en.presence || "-" %></dd></div>
        <div><dt class="text-gray-500 dark:text-gray-400">국적</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.nationality_label %></dd></div>
        <div><dt class="text-gray-500 dark:text-gray-400">생년월일</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.date_of_birth&.strftime("%Y-%m-%d") || "-" %></dd></div>
        <% if current_user.manager? || current_user.admin? %>
          <div><dt class="text-gray-500 dark:text-gray-400">여권번호</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.passport_number.presence || "-" %></dd></div>
        <% end %>
        <!-- FR-03: 전화번호 원클릭 -->
        <div>
          <dt class="text-gray-500 dark:text-gray-400">전화번호</dt>
          <dd class="mt-1">
            <% if @employee.phone.present? %>
              <div class="flex items-center gap-2">
                <a href="tel:<%= @employee.phone %>" class="font-medium text-gray-900 dark:text-white hover:text-primary flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.63 5a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17.58z"/></svg>
                  <%= @employee.phone %>
                </a>
                <a href="https://wa.me/<%= @employee.phone.gsub(/\D/, '') %>" target="_blank" rel="noopener"
                   class="w-6 h-6 flex items-center justify-center rounded-full bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 hover:bg-green-100 dark:hover:bg-green-900/50"
                   title="WhatsApp으로 연락">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                </a>
              </div>
            <% else %>
              <span class="font-medium text-gray-400 dark:text-gray-500">-</span>
            <% end %>
          </dd>
        </div>
        <div><dt class="text-gray-500 dark:text-gray-400">비상 연락처</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.emergency_contact.presence || "-" %></dd></div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">비상 연락전화</dt>
          <dd class="mt-1">
            <% if @employee.emergency_phone.present? %>
              <a href="tel:<%= @employee.emergency_phone %>" class="font-medium text-gray-900 dark:text-white hover:text-primary flex items-center gap-1 w-fit">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.63 5a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17.58z"/></svg>
                <%= @employee.emergency_phone %>
              </a>
            <% else %>
              <span class="font-medium text-gray-400 dark:text-gray-500">-</span>
            <% end %>
          </dd>
        </div>
        <div><dt class="text-gray-500 dark:text-gray-400">부서</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.department&.name || "-" %></dd></div>
        <div><dt class="text-gray-500 dark:text-gray-400">직급</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.job_title.presence || "-" %></dd></div>
        <div><dt class="text-gray-500 dark:text-gray-400">고용형태</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.employment_type_label %></dd></div>
        <div><dt class="text-gray-500 dark:text-gray-400">입사일</dt><dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @employee.hire_date&.strftime("%Y-%m-%d") || "-" %></dd></div>
        <% if @employee.notes.present? %>
          <div class="col-span-2"><dt class="text-gray-500 dark:text-gray-400">메모</dt><dd class="font-medium text-gray-900 dark:text-white mt-1 whitespace-pre-wrap"><%= @employee.notes %></dd></div>
        <% end %>
      </dl>
    </div>

    <!-- 비자 탭 -->
    <div x-show="tab==='visas'" class="p-4">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium text-gray-900 dark:text-white">비자 목록</h3>
        <%= link_to new_employee_visa_path(@employee), class: "inline-flex items-center gap-1 text-sm text-primary hover:underline" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          비자 추가
        <% end %>
      </div>
      <div class="space-y-3">
        <% @visas.each do |visa| %>
          <div class="flex items-center justify-between p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:border-primary/30 transition-colors">
            <div class="flex items-center gap-4">
              <div>
                <div class="flex items-center gap-2">
                  <span class="font-medium text-sm text-gray-900 dark:text-white"><%= visa.visa_type %></span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">(<%= visa.issuing_country %>)</span>
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= visa.expiry_badge_class %>">
                    <%= visa.expiry_date.strftime("%Y-%m-%d") %>
                    (<%= visa.days_until_expiry >= 0 ? "D-#{visa.days_until_expiry}" : "만료" %>)
                  </span>
                </div>
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">번호: <%= visa.visa_number.presence || "-" %> | 발급: <%= visa.issue_date&.strftime("%Y-%m-%d") || "-" %></p>
              </div>
            </div>
            <div class="flex gap-2">
              <%= link_to edit_employee_visa_path(@employee, visa), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-primary" do %>수정<% end %>
              <%= link_to employee_visa_path(@employee, visa), data: { turbo_method: :delete, turbo_confirm: "비자를 삭제하시겠습니까?" },
                  class: "text-xs text-gray-400 dark:text-gray-500 hover:text-red-500" do %>삭제<% end %>
            </div>
          </div>
        <% end %>
        <!-- FR-04: 빈 상태 CTA -->
        <% if @visas.empty? %>
          <div class="flex flex-col items-center justify-center py-10 gap-3">
            <svg class="w-10 h-10 text-gray-200 dark:text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            <p class="text-sm text-gray-400 dark:text-gray-500">등록된 비자가 없습니다.</p>
            <%= link_to new_employee_visa_path(@employee),
                class: "inline-flex items-center gap-1 text-sm text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/5 transition-colors" do %>
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              비자 추가
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 계약 탭 -->
    <div x-show="tab==='contracts'" class="p-4">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium text-gray-900 dark:text-white">계약 이력</h3>
        <%= link_to new_employee_employment_contract_path(@employee), class: "inline-flex items-center gap-1 text-sm text-primary hover:underline" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          계약 추가
        <% end %>
      </div>
      <div class="space-y-3">
        <% @contracts.each do |contract| %>
          <div class="flex items-center justify-between p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:border-primary/30 transition-colors">
            <div>
              <div class="flex items-center gap-2">
                <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= contract.status_badge_class %>"><%= contract.status_label %></span>
                <span class="text-sm font-medium text-gray-900 dark:text-white">
                  <%= contract.start_date.strftime("%Y.%m.%d") %> ~
                  <%= contract.end_date&.strftime("%Y.%m.%d") || "기간 없음" %>
                </span>
              </div>
              <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                <% if contract.base_salary.present? && (current_user.manager? || current_user.admin?) %>
                  급여: <%= contract.currency %> <%= number_with_delimiter(contract.base_salary.to_i) %> / <%= contract.pay_frequency_label %>
                <% end %>
                <% if contract.project.present? %>
                  | 현장: <%= contract.project.name %>
                <% end %>
              </div>
            </div>
            <div class="flex gap-2">
              <%= link_to edit_employee_employment_contract_path(@employee, contract), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-primary" do %>수정<% end %>
              <%= link_to employee_employment_contract_path(@employee, contract),
                  data: { turbo_method: :delete, turbo_confirm: "계약을 삭제하시겠습니까?" },
                  class: "text-xs text-gray-400 dark:text-gray-500 hover:text-red-500" do %>삭제<% end %>
            </div>
          </div>
        <% end %>
        <!-- FR-04: 빈 상태 CTA -->
        <% if @contracts.empty? %>
          <div class="flex flex-col items-center justify-center py-10 gap-3">
            <svg class="w-10 h-10 text-gray-200 dark:text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            <p class="text-sm text-gray-400 dark:text-gray-500">등록된 계약이 없습니다.</p>
            <%= link_to new_employee_employment_contract_path(@employee),
                class: "inline-flex items-center gap-1 text-sm text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/5 transition-colors" do %>
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              계약 추가
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 현장 배정 탭 -->
    <div x-show="tab==='assignments'" class="p-4">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium text-gray-900 dark:text-white">현장 배정 이력</h3>
        <%= link_to new_employee_employee_assignment_path(@employee), class: "inline-flex items-center gap-1 text-sm text-primary hover:underline" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          현장 배정
        <% end %>
      </div>
      <div class="space-y-3">
        <% @assignments.each do |asgn| %>
          <div class="flex items-center justify-between p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:border-primary/30 transition-colors">
            <div>
              <div class="flex items-center gap-2">
                <span class="font-medium text-sm text-gray-900 dark:text-white"><%= asgn.project.name %></span>
                <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= asgn.status_badge_class %>"><%= asgn.status_label %></span>
              </div>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                <%= asgn.role.presence || "역할 미지정" %> |
                <%= asgn.start_date.strftime("%Y.%m.%d") %> ~
                <%= asgn.end_date&.strftime("%Y.%m.%d") || "현재" %>
              </p>
            </div>
            <div class="flex gap-2">
              <%= link_to edit_employee_employee_assignment_path(@employee, asgn), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-primary" do %>수정<% end %>
              <%= link_to employee_employee_assignment_path(@employee, asgn),
                  data: { turbo_method: :delete, turbo_confirm: "배정을 삭제하시겠습니까?" },
                  class: "text-xs text-gray-400 dark:text-gray-500 hover:text-red-500" do %>삭제<% end %>
            </div>
          </div>
        <% end %>
        <!-- FR-04: 빈 상태 CTA -->
        <% if @assignments.empty? %>
          <div class="flex flex-col items-center justify-center py-10 gap-3">
            <svg class="w-10 h-10 text-gray-200 dark:text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <p class="text-sm text-gray-400 dark:text-gray-500">현장 배정 이력이 없습니다.</p>
            <%= link_to new_employee_employee_assignment_path(@employee),
                class: "inline-flex items-center gap-1 text-sm text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/5 transition-colors" do %>
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              현장 배정
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 자격증 탭 -->
    <div x-show="tab==='certs'" class="p-4">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium text-gray-900 dark:text-white">자격증/교육 이력</h3>
        <%= link_to new_employee_certification_path(@employee), class: "inline-flex items-center gap-1 text-sm text-primary hover:underline" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          자격증 추가
        <% end %>
      </div>
      <div class="space-y-3">
        <% @certifications.each do |cert| %>
          <div class="flex items-center justify-between p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:border-primary/30 transition-colors">
            <div>
              <div class="flex items-center gap-2">
                <span class="font-medium text-sm text-gray-900 dark:text-white"><%= cert.name %></span>
                <% if cert.expiry_date %>
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= cert.expiry_badge_class %>">
                    <%= cert.expired? ? "만료" : cert.expiring_soon? ? "만료임박" : "유효" %>
                  </span>
                <% end %>
              </div>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                <%= cert.issuing_body.presence || "발급기관 미기재" %> |
                취득: <%= cert.issued_date&.strftime("%Y-%m-%d") || "-" %>
                <% if cert.expiry_date %>| 만료: <%= cert.expiry_date.strftime("%Y-%m-%d") %><% end %>
              </p>
            </div>
            <div class="flex gap-2">
              <%= link_to edit_employee_certification_path(@employee, cert), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-primary" do %>수정<% end %>
              <%= link_to employee_certification_path(@employee, cert),
                  data: { turbo_method: :delete, turbo_confirm: "자격증을 삭제하시겠습니까?" },
                  class: "text-xs text-gray-400 dark:text-gray-500 hover:text-red-500" do %>삭제<% end %>
            </div>
          </div>
        <% end %>
        <!-- FR-04: 빈 상태 CTA -->
        <% if @certifications.empty? %>
          <div class="flex flex-col items-center justify-center py-10 gap-3">
            <svg class="w-10 h-10 text-gray-200 dark:text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            <p class="text-sm text-gray-400 dark:text-gray-500">등록된 자격증이 없습니다.</p>
            <%= link_to new_employee_certification_path(@employee),
                class: "inline-flex items-center gap-1 text-sm text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/5 transition-colors" do %>
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              자격증 추가
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
