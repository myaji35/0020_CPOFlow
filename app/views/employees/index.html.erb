<% content_for :title, "직원 관리" %>

<div class="flex flex-col gap-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">직원 관리</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">비자/근무조건 선제 관리</p>
    </div>
    <%= link_to new_employee_path, class: "inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary-dark transition-colors" do %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      직원 등록
    <% end %>
  </div>

  <!-- 비자 만료 임박 배너 -->
  <% if @stats[:visa_expiring] > 0 %>
    <div class="flex items-center gap-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-xl px-4 py-3">
      <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <div class="flex-1">
        <p class="text-sm font-semibold text-yellow-800 dark:text-yellow-300">비자 만료 임박 직원 <%= @stats[:visa_expiring] %>명</p>
        <p class="text-xs text-yellow-700 dark:text-yellow-400 mt-0.5">60일 이내 비자가 만료됩니다. 갱신 절차를 확인하세요.</p>
      </div>
      <%= link_to employees_path(expiring: "visa"), class: "text-xs font-medium text-yellow-700 dark:text-yellow-400 hover:text-yellow-900 dark:hover:text-yellow-200 underline flex-shrink-0" do %>
        대상자 보기
      <% end %>
    </div>
  <% end %>

  <!-- 통계 카드 -->
  <div class="grid grid-cols-4 gap-4">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-4">
      <p class="text-xs text-gray-500 dark:text-gray-400">총 직원</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @stats[:total] %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-4">
      <p class="text-xs text-gray-500 dark:text-gray-400">현재 파견중</p>
      <p class="text-2xl font-bold text-primary mt-1"><%= @stats[:dispatched] %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-4 <%= @stats[:visa_expiring] > 0 ? 'border-yellow-200 dark:border-yellow-800' : '' %>">
      <p class="text-xs text-gray-500 dark:text-gray-400">비자 만료 임박 (60일)</p>
      <p class="text-2xl font-bold <%= @stats[:visa_expiring] > 0 ? 'text-yellow-600 dark:text-yellow-400' : 'text-gray-900 dark:text-white' %> mt-1"><%= @stats[:visa_expiring] %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-4 <%= @stats[:contract_expiring] > 0 ? 'border-orange-200 dark:border-orange-800' : '' %>">
      <p class="text-xs text-gray-500 dark:text-gray-400">계약 만료 임박 (30일)</p>
      <p class="text-2xl font-bold <%= @stats[:contract_expiring] > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-900 dark:text-white' %> mt-1"><%= @stats[:contract_expiring] %></p>
    </div>
  </div>

  <!-- 검색/필터 -->
  <%= form_with url: employees_path, method: :get, class: "flex gap-2 flex-wrap items-center" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "이름 검색...",
        class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm w-36 focus:outline-none focus:border-primary" %>
    <%= f.select :type, [["전체 고용형태", ""], ["정규직", "regular"], ["계약직", "contract"], ["파견", "dispatch"]],
        { selected: params[:type] },
        class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
    <!-- FR-06: 부서 필터 -->
    <%= f.select :department,
        [["전체 부서", ""]] + @departments.map { |d| [d.name, d.id] },
        { selected: params[:department] },
        class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
    <!-- FR-06: 직책 필터 -->
    <%= f.select :job_title,
        [["전체 직책", ""]] + @job_titles.map { |jt| [jt.name, jt.name] },
        { selected: params[:job_title] },
        class: "border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
    <label class="inline-flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-400 cursor-pointer">
      <%= f.check_box :deployed, { checked: params[:deployed] == "1" }, "1", "" %>
      파견중만
    </label>
    <label class="inline-flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-400 cursor-pointer">
      <%= f.check_box :show_inactive, { checked: params[:show_inactive] == "1" }, "1", "" %>
      퇴직자 포함
    </label>
    <%= f.submit "검색", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm hover:bg-primary-dark cursor-pointer" %>
    <%= link_to "초기화", employees_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 px-2 py-2" %>
  <% end %>

  <!-- 테이블 -->
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 dark:bg-gray-700/50 border-b border-gray-100 dark:border-gray-700">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">이름</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">국적 / 부서 · 직책</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">고용형태</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">현재 현장</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">비자 만료</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">계약 만료</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
        <% @employees.each do |emp| %>
          <%
            visa       = emp.active_visa
            contract   = emp.current_contract
            assignment = emp.current_assignment
          %>
          <!-- FR-08: group 클래스로 hover Quick Action 지원 -->
          <tr class="group hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors <%= emp.active? ? '' : 'opacity-50' %>">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2.5">
                <!-- FR-01: 미니 아바타 (32px) -->
                <div class="w-8 h-8 rounded-full <%= emp.avatar_color %> flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                  <%= emp.initials %>
                </div>
                <div>
                  <div class="flex items-center gap-1.5">
                    <span class="font-medium text-gray-900 dark:text-white"><%= emp.name %></span>
                    <% if emp.user_id.present? %>
                      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400" title="시스템 계정 연결됨: <%= emp.user&.email %>">
                        <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        계정연결
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500" title="시스템 계정 미연결">
                        미연결
                      </span>
                    <% end %>
                  </div>
                  <% if emp.name_en.present? %>
                    <div class="text-xs text-gray-400 dark:text-gray-500"><%= emp.name_en %></div>
                  <% end %>
                </div>
              </div>
            </td>
            <!-- FR-07: 직책 컬럼 병합 -->
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
              <div><%= emp.nationality_label %></div>
              <div class="text-xs text-gray-400 dark:text-gray-500">
                <%= [emp.department&.name, emp.job_title.presence].compact.join(" · ") %>
              </div>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400">
                <%= emp.employment_type_label %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
              <% if assignment %>
                <%= assignment.project.name %>
              <% else %>
                <span class="text-gray-300 dark:text-gray-600">-</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if visa %>
                <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= visa.expiry_badge_class %>">
                  <%= visa.expiry_date.strftime("%Y-%m-%d") %>
                  <% if visa.days_until_expiry >= 0 %>
                    (D-<%= visa.days_until_expiry %>)
                  <% else %>
                    (만료)
                  <% end %>
                </span>
              <% else %>
                <span class="text-gray-300 dark:text-gray-600 text-xs">-</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if contract&.end_date %>
                <%
                  days_left = (contract.end_date - Date.today).to_i
                  badge_class = if days_left < 0 then "bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400"
                                elsif days_left <= 14 then "bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400"
                                elsif days_left <= 30 then "bg-orange-50 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400"
                                else "bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400" end
                %>
                <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= badge_class %>">
                  <%= contract.end_date.strftime("%Y-%m-%d") %>
                </span>
              <% else %>
                <span class="text-gray-300 dark:text-gray-600 text-xs">-</span>
              <% end %>
            </td>
            <!-- FR-08: Quick Action -->
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "상세", emp, class: "text-xs text-primary hover:underline" %>
                <% if current_user.manager? || current_user.admin? %>
                  <%= link_to "수정", edit_employee_path(emp),
                      class: "text-xs text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 opacity-0 group-hover:opacity-100 transition-opacity" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @employees.empty? %>
          <tr><td colspan="7" class="px-4 py-12 text-center text-gray-400 dark:text-gray-500 text-sm">등록된 직원이 없습니다.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
