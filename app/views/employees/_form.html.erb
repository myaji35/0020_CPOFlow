<%= form_with model: employee, class: "flex flex-col gap-6" do |f| %>
  <% if employee.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg text-sm">
      <% employee.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-6">
    <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">기본 정보</h3>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :name, "이름 (한글)", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :name, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary", placeholder: "홍길동" %>
      </div>
      <div>
        <%= f.label :name_en, "이름 (영문)", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :name_en, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary", placeholder: "Hong Gildong" %>
      </div>
      <div>
        <%= f.label :nationality, "국적", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.select :nationality,
            Employee::NATIONALITIES.map { |code, label| ["#{label} (#{code})", code] },
            { include_blank: "선택" },
            class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div>
        <%= f.label :date_of_birth, "생년월일", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.date_field :date_of_birth, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div>
        <%= f.label :passport_number, "여권번호", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :passport_number, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div>
        <%= f.label :employment_type, "고용형태", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.select :employment_type,
            [["정규직", "regular"], ["계약직", "contract"], ["파견", "dispatch"]],
            {},
            class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-6">
    <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">연락처 정보</h3>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :phone, "전화번호", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :phone, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary", placeholder: "+971-50-0000000" %>
      </div>
      <div></div>
      <div>
        <%= f.label :emergency_contact, "비상 연락처 (이름)", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :emergency_contact, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div>
        <%= f.label :emergency_phone, "비상 연락전화", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :emergency_phone, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm p-6">
    <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">직무 정보</h3>
    <div class="grid grid-cols-2 gap-4">
      <%# 부서 선택 + 인라인 추가/삭제 %>
      <div data-controller="department-manager"
           data-department-manager-url-value="<%= employees_departments_path %>">

        <div class="flex items-center justify-between mb-1">
          <%= f.label :department_id, "부서", class: "text-xs font-medium text-gray-600 dark:text-gray-400" %>
          <button type="button"
                  class="flex items-center gap-1 text-[11px] text-primary hover:text-primary-dark font-medium"
                  data-action="click->department-manager#open">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            부서 관리
          </button>
        </div>

        <%= f.select :department_id,
            Department.active.by_sort.map { |d| [d.full_name, d.id] },
            { include_blank: "부서 선택" },
            class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary",
            data: { "department-manager-target": "select" } %>

        <%# 부서 관리 모달 %>
        <div data-department-manager-target="modal"
             class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40"
             data-action="click->department-manager#backdropClose">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl w-full max-w-md mx-4 overflow-hidden">

            <%# 헤더 %>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-gray-700">
              <h3 class="text-sm font-semibold text-gray-800 dark:text-white">부서 관리</h3>
              <button type="button" class="p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-400"
                      data-action="click->department-manager#close">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>

            <%# 부서 목록 %>
            <div class="px-4 py-3 max-h-52 overflow-y-auto">
              <div data-department-manager-target="list">
                <p class="text-xs text-gray-400 py-2 text-center">불러오는 중...</p>
              </div>
              <p data-department-manager-target="deleteError" class="text-xs text-red-500 mt-1 min-h-[1rem]"></p>
            </div>

            <%# 부서 추가 폼 %>
            <div class="px-4 pb-4 border-t border-gray-100 dark:border-gray-700 pt-3">
              <p class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-2">새 부서 추가</p>
              <div class="flex gap-2 mb-2">
                <select data-department-manager-target="addCompany"
                        class="border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary flex-shrink-0">
                  <% Company.order(:name).each do |company| %>
                    <option value="<%= company.id %>"><%= company.name %></option>
                  <% end %>
                </select>
                <input type="text"
                       placeholder="부서명 입력"
                       data-department-manager-target="addInput"
                       data-action="keydown.enter->department-manager#addDept"
                       class="flex-1 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-primary" />
                <button type="button"
                        data-action="click->department-manager#addDept"
                        class="px-3 py-1.5 bg-primary text-white rounded-lg text-xs font-medium hover:bg-primary-dark flex-shrink-0">
                  추가
                </button>
              </div>
              <p data-department-manager-target="addError" class="text-xs text-red-500 min-h-[1rem]"></p>
            </div>

          </div>
        </div>
      </div>
      <div>
        <%= f.label :job_title, "직급/직책", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.text_field :job_title, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary", placeholder: "선임 구매 담당" %>
      </div>
      <div>
        <%= f.label :hire_date, "입사일", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.date_field :hire_date, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div>
        <%= f.label :termination_date, "퇴직일", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.date_field :termination_date, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div>
        <%= f.label :user_id, "시스템 계정 연결 (선택)", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
        <%= f.select :user_id,
            User.order(:name).map { |u| [u.display_name, u.id] },
            { include_blank: "계정 없음" },
            class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" %>
      </div>
      <div class="flex items-end">
        <label class="inline-flex items-center gap-2 cursor-pointer">
          <%= f.check_box :active, class: "w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-primary" %>
          <span class="text-sm text-gray-700 dark:text-gray-300">재직중</span>
        </label>
      </div>
    </div>
    <div class="mt-4">
      <%= f.label :notes, "메모", class: "block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" %>
      <%= f.text_area :notes, rows: 3, class: "w-full border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none" %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "취소", employees_path, class: "px-4 py-2 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-700" %>
    <%= f.submit employee.new_record? ? "직원 등록" : "변경 저장",
        class: "px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary-dark cursor-pointer" %>
  </div>
<% end %>
