<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', Arial, sans-serif; font-size: 11pt; color: #1a1a1a; }

    /* ===== 브랜드 헤더 바 ===== */
    .brand-bar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: #1E3A5F; color: white;
      padding: 9px 20mm;
      display: flex; justify-content: space-between; align-items: center;
    }
    .brand-bar .brand-name  { font-size: 13pt; font-weight: bold; letter-spacing: 0.5px; }
    .brand-bar .brand-sub   { font-size: 7.5pt; opacity: 0.75; margin-top: 2px; }
    .brand-bar .brand-right { font-size: 10pt; font-weight: bold; letter-spacing: 2px; opacity: 0.85; }

    /* ===== 페이지 영역 ===== */
    .page { padding: 34mm 20mm 18mm; }

    /* ===== 문서 메타 헤더 ===== */
    .doc-meta {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-bottom: 20px; padding-bottom: 12px;
      border-bottom: 3px solid #1E3A5F;
    }
    .doc-title  { font-size: 22pt; font-weight: bold; color: #1E3A5F; }
    .doc-number { font-size: 9pt; color: #6b7280; margin-top: 4px; }
    .doc-date-block { text-align: right; font-size: 9pt; color: #6b7280; line-height: 1.8; }

    /* ===== 강조 박스 ===== */
    .highlight-box {
      background: #eff6ff; border: 1.5px solid #1E3A5F; border-radius: 4px;
      padding: 8px 16px; display: inline-flex; align-items: center; gap: 16px;
      margin: 0 0 16px;
    }
    .hl-label { font-size: 8pt; color: #6b7280; margin-bottom: 3px; }
    .hl-value { font-size: 11pt; font-weight: bold; color: #1E3A5F; }
    .hl-divider { width: 1px; height: 32px; background: #93c5fd; }

    /* ===== 섹션 헤더 ===== */
    h2 {
      font-size: 9.5pt; color: #1E3A5F;
      text-transform: uppercase; letter-spacing: 1px;
      border-bottom: 1.5px solid #1E3A5F;
      padding-bottom: 4px; margin: 20px 0 10px;
    }

    /* ===== 정보 그리드 ===== */
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 24px; margin-bottom: 16px; }
    .info-item { display: flex; flex-direction: column; }
    .info-label { font-size: 8pt; color: #6b7280; margin-bottom: 2px; }
    .info-value { font-size: 10pt; font-weight: 600; }

    /* ===== 테이블 ===== */
    table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    th { background: #1E3A5F; color: white; padding: 7px 10px; text-align: left; font-size: 9.5pt; }
    th.amount-col { text-align: right; }
    td { padding: 7px 10px; border-bottom: 1px solid #e5e7eb; font-size: 10pt; }
    td.amount-col { text-align: right; }
    tr:nth-child(even) td { background: #f9fafb; }
    .total-row td { font-weight: bold; background: #1E3A5F; color: white; }

    /* ===== 배지 ===== */
    .badge { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: 8.5pt; font-weight: bold; }
    .badge-urgent { background: #fee2e2; color: #dc2626; }
    .badge-high   { background: #ffedd5; color: #ea580c; }
    .badge-medium { background: #fef9c3; color: #ca8a04; }
    .badge-low    { background: #dcfce7; color: #16a34a; }

    /* ===== 서명란 ===== */
    .signature-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 16px; margin-top: 28px;
    }
    .signature-box {
      border: 1px solid #d1d5db; border-radius: 4px;
      padding: 10px 12px; min-height: 72px;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .sig-role  { font-size: 8pt; color: #6b7280; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; }
    .sig-name  { font-size: 9pt; color: #1a1a1a; border-bottom: 1px solid #9ca3af; padding-bottom: 2px; margin: 18px 0 4px; }
    .sig-date  { font-size: 8pt; color: #9ca3af; }

    /* ===== Terms ===== */
    .terms-section {
      margin-top: 24px; padding-top: 12px;
      border-top: 1px solid #e5e7eb;
      font-size: 7.5pt; color: #6b7280; line-height: 1.75;
      columns: 2; column-gap: 24px;
    }
    .terms-section h4 {
      font-size: 8pt; font-weight: bold; color: #374151;
      margin-bottom: 6px; column-span: all;
    }
    .terms-section p { margin-bottom: 3px; break-inside: avoid; }

    /* ===== 강화된 푸터 ===== */
    .footer {
      position: fixed; bottom: 0; left: 0; right: 0;
      background: #1E3A5F; color: rgba(255,255,255,0.82);
      font-size: 7.5pt; padding: 5px 20mm;
      display: flex; justify-content: space-between; align-items: center;
    }
  </style>
</head>
<body>
  <%# 브랜드 헤더 바 %>
  <div class="brand-bar">
    <div>
      <div class="brand-name">&#9632; AtoZ2010 Inc.</div>
      <div class="brand-sub">Abu Dhabi HQ &middot; Seoul Branch &middot; www.atoz2010.com</div>
    </div>
    <div class="brand-right">PROCUREMENT</div>
  </div>

  <%# 페이지 콘텐츠 %>
  <div class="page">
    <%= yield %>
  </div>

  <%# 강화된 푸터 %>
  <div class="footer">
    <span>AtoZ2010 Inc. &middot; Abu Dhabi, UAE</span>
    <span>Generated: <%= Date.today.strftime("%Y-%m-%d") %> &middot; Confidential</span>
  </div>
</body>
</html>
