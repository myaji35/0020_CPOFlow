<!DOCTYPE html>
<html lang="<%= user_signed_in? ? current_user.preferred_locale : 'en' %>"
      data-theme="<%= user_signed_in? ? current_user.preferred_theme : 'light' %>">
  <head>
    <title><%= content_for(:title) || "CPOFlow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- TailwindCSS CDN (dark mode via class strategy) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              primary:   { DEFAULT: '#1E3A5F', light: '#2D5282', dark: '#142844' },
              accent:    { DEFAULT: '#00A1E0', light: '#33b5e8' },
              danger:    '#D93025',
              warning:   '#F4A83A',
              success:   '#1E8E3E',
            }
          }
        }
      }
    </script>
    <!-- Dark mode initializer (prevent flash) -->
    <script>
      (function() {
        var theme = document.documentElement.getAttribute('data-theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (theme === 'system') {
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          }
        }
      })();
    </script>

    <!-- Alpine.js CDN -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Line Icons CDN -->
    <link rel="stylesheet" href="https://cdn.lineicons.com/4.0/lineicons.css" />

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%= yield :head %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 antialiased transition-colors duration-200">
    <% if user_signed_in? %>
      <div class="flex h-screen overflow-hidden">
        <!-- Sidebar Navigation -->
        <%= render "shared/sidebar" %>

        <!-- Main Content -->
        <div class="flex flex-col flex-1 overflow-hidden">
          <!-- Top Header -->
          <%= render "shared/header" %>

          <!-- Flash Messages -->
          <% if notice.present? %>
            <div class="mx-6 mt-4 px-4 py-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-800 dark:text-green-400 text-sm flex items-center gap-2">
              <i class="lni lni-checkmark-circle text-green-600 dark:text-green-400"></i>
              <%= notice %>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="mx-6 mt-4 px-4 py-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-800 dark:text-red-400 text-sm flex items-center gap-2">
              <i class="lni lni-warning text-red-600 dark:text-red-400"></i>
              <%= alert %>
            </div>
          <% end %>

          <!-- Page Content -->
          <main class="flex-1 overflow-y-auto p-6 bg-gray-50 dark:bg-gray-950">
            <%= yield %>
          </main>
        </div>
      </div>

      <%# ===== Command Palette (Cmd+K) ===== %>
      <div data-controller="command-palette">
        <div data-command-palette-target="modal"
             class="hidden fixed inset-0 z-50 flex items-start justify-center pt-20 px-4"
             data-action="click->command-palette#closeOnBackdrop">
          <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
          <div class="relative w-full max-w-xl bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <%# 검색 입력 %>
            <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100 dark:border-gray-700">
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input data-command-palette-target="input"
                     data-action="input->command-palette#search keydown->command-palette#handleKeydown"
                     type="text"
                     placeholder="주문, 발주처, 거래처, 직원, 현장 검색..."
                     class="flex-1 bg-transparent text-sm text-gray-900 dark:text-white placeholder-gray-400 outline-none">
              <kbd class="hidden sm:inline-flex px-1.5 py-0.5 text-xs text-gray-400 dark:text-gray-500 border border-gray-200 dark:border-gray-600 rounded">ESC</kbd>
            </div>
            <%# 결과 목록 %>
            <div data-command-palette-target="results"
                 class="max-h-80 overflow-y-auto py-1">
              <div class="px-4 py-6 text-center">
                <p class="text-sm text-gray-400 dark:text-gray-500">검색어를 2자 이상 입력하세요</p>
                <p class="text-xs text-gray-300 dark:text-gray-600 mt-1">주문 · 발주처 · 거래처 · 직원 · 현장 통합 검색</p>
              </div>
            </div>
            <%# 푸터 %>
            <div class="px-4 py-2 border-t border-gray-100 dark:border-gray-700 flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
              <span><kbd class="px-1 py-0.5 border border-gray-200 dark:border-gray-600 rounded text-xs">↑↓</kbd> 탐색</span>
              <span><kbd class="px-1 py-0.5 border border-gray-200 dark:border-gray-600 rounded text-xs">↵</kbd> 이동</span>
              <span><kbd class="px-1 py-0.5 border border-gray-200 dark:border-gray-600 rounded text-xs">⌘K</kbd> 열기</span>
            </div>
          </div>
        </div>
      </div>

      <%# ===== Order Detail Drawer ===== %>
      <div id="order-drawer-backdrop"
           class="fixed inset-0 bg-black/40 z-40 hidden transition-opacity duration-300 opacity-0"
           onclick="closeOrderDrawer()"></div>

      <div id="order-drawer"
           class="fixed top-0 right-0 h-full w-full max-w-2xl bg-white dark:bg-gray-800 shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
        <%# Drawer Header %>
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex-shrink-0 bg-white dark:bg-gray-800">
          <div id="drawer-title" class="text-sm font-semibold text-gray-900 dark:text-white truncate pr-4"></div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a id="drawer-open-link" href="#"
               class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-600 px-2.5 py-1.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              전체 화면
            </a>
            <button onclick="closeOrderDrawer()"
                    class="p-1.5 rounded-lg text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>
        <%# Drawer Body %>
        <div id="order-drawer-body" class="flex-1 overflow-y-auto">
          <div class="flex items-center justify-center h-32 text-gray-200">
            <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
          </div>
        </div>
      </div>

      <script>
        function openOrderDrawer(orderId, orderTitle, orderPath) {
          const drawer   = document.getElementById('order-drawer');
          const backdrop = document.getElementById('order-drawer-backdrop');
          const body     = document.getElementById('order-drawer-body');
          const title    = document.getElementById('drawer-title');
          const openLink = document.getElementById('drawer-open-link');

          title.textContent = orderTitle || 'Order Detail';
          openLink.href = orderPath || '#';

          body.innerHTML = '<div class="flex items-center justify-center h-40"><svg class="w-6 h-6 text-gray-300 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg></div>';

          backdrop.classList.remove('hidden');
          requestAnimationFrame(() => {
            backdrop.classList.remove('opacity-0');
            drawer.classList.remove('translate-x-full');
          });
          document.body.style.overflow = 'hidden';

          fetch(orderPath + '?drawer=1', {
            headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' }
          })
          .then(r => r.text())
          .then(html => {
            const parser = new DOMParser();
            const doc    = parser.parseFromString(html, 'text/html');
            const el     = doc.getElementById('order-drawer-content');
            body.innerHTML = el ? el.innerHTML : '<div class="p-6 text-sm text-red-400">내용을 불러올 수 없습니다.</div>';
          })
          .catch(() => {
            body.innerHTML = '<div class="p-6 text-sm text-red-400">네트워크 오류가 발생했습니다.</div>';
          });
        }

        function closeOrderDrawer() {
          const drawer   = document.getElementById('order-drawer');
          const backdrop = document.getElementById('order-drawer-backdrop');
          drawer.classList.add('translate-x-full');
          backdrop.classList.add('opacity-0');
          setTimeout(() => {
            backdrop.classList.add('hidden');
            document.body.style.overflow = '';
          }, 300);
        }

        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeOrderDrawer(); });
      </script>

    <% else %>
      <!-- Auth pages: no sidebar -->
      <%= yield %>
    <% end %>
  </body>
</html>
