<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3 shadow-sm hover:shadow-md hover:border-accent/40 dark:hover:border-accent/40 transition-all group"
     data-order-id="<%= order.id %>"
     title="클릭하여 상세 보기">

  <!-- Card Header: drag handle + Priority + Due badge -->
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-1.5">
      <!-- 드래그 핸들 -->
      <span class="drag-handle text-gray-300 dark:text-gray-600 hover:text-gray-400 dark:hover:text-gray-400 opacity-0 group-hover:opacity-100 transition-opacity -ml-1 pr-0.5"
            title="드래그하여 이동">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="9"  cy="5"  r="1.5"/><circle cx="15" cy="5"  r="1.5"/>
          <circle cx="9"  cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/>
          <circle cx="9"  cy="19" r="1.5"/><circle cx="15" cy="19" r="1.5"/>
        </svg>
      </span>
      <%= priority_badge(order) %>
    </div>
    <div class="flex items-center gap-1">
      <% if order.due_date %>
        <%= due_badge(order) %>
      <% end %>
    </div>
  </div>

  <!-- 클릭 영역 (핸들 제외) -->
  <div onclick="openOrderDrawer(<%= order.id %>, <%= order.title.to_json %>, '<%= order_path(order) %>')" class="cursor-pointer">

  <!-- Title -->
  <h4 class="text-sm font-semibold text-gray-900 dark:text-white leading-snug group-hover:text-accent transition-colors mb-1">
    <%= order.title %>
  </h4>

  <!-- 발주처 / 현장 -->
  <div class="flex flex-wrap items-center gap-1.5 mb-2">
    <% if order.client %>
      <span class="text-xs bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-1.5 py-0.5 rounded-full flex items-center gap-1">
        <i class="lni lni-briefcase text-xs"></i>
        <%= order.client.name %>
      </span>
    <% elsif order.customer_name.present? %>
      <span class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
        <i class="lni lni-user text-xs"></i>
        <%= order.customer_name %>
      </span>
    <% end %>
    <% if order.project %>
      <span class="text-xs bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-1.5 py-0.5 rounded-full flex items-center gap-1">
        <i class="lni lni-construction text-xs"></i>
        <%= order.project.name %>
      </span>
    <% end %>
  </div>

  <!-- Item name if present -->
  <% if order.item_name.present? %>
    <p class="text-xs text-gray-400 dark:text-gray-500 mb-2 flex items-center gap-1">
      <i class="lni lni-package text-xs"></i>
      <%= order.item_name %> <%= "× #{order.quantity}" if order.quantity %>
    </p>
  <% end %>

  <!-- Tags -->
  <% if order.tags_array.any? %>
    <div class="flex flex-wrap gap-1 mb-2">
      <% order.tags_array.first(3).each do |tag| %>
        <span class="text-xs bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-1.5 py-0.5 rounded"><%= tag %></span>
      <% end %>
    </div>
  <% end %>

  <!-- Task progress -->
  <% prog = order.task_progress %>
  <% if prog[:total] > 0 %>
    <div class="mb-2">
      <%= task_progress_bar(order) %>
    </div>
  <% end %>

  <!-- Footer: Assignees + Meta -->
  <div class="flex items-center justify-between pt-2 border-t border-gray-50 dark:border-gray-700">
    <!-- Assignee avatars -->
    <div class="flex -space-x-1">
      <% order.assignees.first(3).each do |u| %>
        <div class="w-5 h-5 rounded-full bg-primary text-white text-xs flex items-center justify-center border border-white dark:border-gray-800 font-medium"
             title="<%= u.display_name %>">
          <%= u.initials %>
        </div>
      <% end %>
    </div>

    <!-- Meta icons -->
    <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500">
      <% if order.comments.any? %>
        <span class="flex items-center gap-0.5">
          <i class="lni lni-comments"></i>
          <%= order.comments.count %>
        </span>
      <% end %>
      <span class="flex items-center gap-0.5">
        <i class="lni lni-calendar"></i>
        <%= order.due_date&.strftime("%b %d") || "—" %>
      </span>
    </div>
  </div>
  </div><!-- /클릭 영역 -->
</div>
