<% content_for :page_title, "Kanban Board" %>
<% content_for :head do %>
  <!-- SortableJS for drag-and-drop -->
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<% end %>

<div class="flex items-center justify-between mb-5">
  <div class="flex items-center gap-2">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Procurement Board</h2>
    <span class="text-sm text-gray-400 dark:text-gray-500">— AtoZ2010 Inc.</span>
  </div>
  <%= link_to new_order_path, class: "flex items-center gap-2 bg-accent text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-blue-500 transition-colors" do %>
    <i class="lni lni-plus"></i>
    New Order
  <% end %>
</div>

<!-- 필터 바 (FR-01) -->
<div id="kanban-filter-bar" class="flex flex-wrap items-center gap-2 mb-4 p-3 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
  <%# 담당자 드롭다운 %>
  <select id="filter-assignee"
          class="text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-200 focus:outline-none focus:ring-2 focus:ring-accent/40">
    <option value="">전체 담당자</option>
    <option value="me" data-user-id="<%= current_user.id %>">내 발주</option>
    <% @filter_users.each do |u| %>
      <option value="<%= u.id %>"><%= u.display_name %></option>
    <% end %>
  </select>

  <%# 우선순위 토글 %>
  <div class="flex rounded-lg border border-gray-200 dark:border-gray-600 overflow-hidden text-xs">
    <% [["", "전체"], ["urgent", "긴급"], ["high", "높음"], ["medium", "보통"]].each do |val, lbl| %>
      <button class="filter-priority-btn px-2.5 py-1.5 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors border-r border-gray-200 dark:border-gray-600 last:border-0"
              data-value="<%= val %>"><%= lbl %></button>
    <% end %>
  </div>

  <%# 납기 토글 %>
  <div class="flex rounded-lg border border-gray-200 dark:border-gray-600 overflow-hidden text-xs">
    <% [["", "전체"], ["urgent", "D-7"], ["overdue", "지연"]].each do |val, lbl| %>
      <button class="filter-due-btn px-2.5 py-1.5 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors border-r border-gray-200 dark:border-gray-600 last:border-0"
              data-value="<%= val %>"><%= lbl %></button>
    <% end %>
  </div>

  <%# 키워드 검색 %>
  <div class="flex items-center gap-1.5 flex-1 min-w-[140px] max-w-[220px] border border-gray-200 dark:border-gray-600 rounded-lg px-2.5 py-1.5 bg-white dark:bg-gray-700">
    <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="filter-keyword" type="text" placeholder="검색..."
           class="text-xs bg-transparent text-gray-700 dark:text-gray-200 focus:outline-none w-full placeholder-gray-400 dark:placeholder-gray-500">
  </div>

  <%# 초기화 버튼 — 활성 필터 있을 때만 노출 %>
  <button id="filter-reset"
          class="hidden text-xs text-gray-400 dark:text-gray-500 hover:text-red-500 dark:hover:text-red-400 px-2 py-1.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
</div>

<!-- Kanban Board -->
<div class="flex gap-4 overflow-x-auto pb-4 min-h-[calc(100vh-200px)]" id="kanban-board">
  <% Order::KANBAN_COLUMNS.each_with_index do |status, col_idx| %>
    <% orders = @columns[status] || [] %>
    <% label = Order::STATUS_LABELS[status] %>
    <% prev_stat = col_idx > 0 ? Order::KANBAN_COLUMNS[col_idx - 1] : nil %>
    <% next_stat = col_idx < Order::KANBAN_COLUMNS.length - 1 ? Order::KANBAN_COLUMNS[col_idx + 1] : nil %>

    <div class="kanban-column flex flex-col w-72 shrink-0" data-status="<%= status %>">
      <!-- Column Header -->
      <div class="flex items-center justify-between mb-3 px-1">
        <div class="flex items-center gap-2">
          <span class="column-name text-sm font-semibold text-gray-700 dark:text-gray-300"><%= label %></span>
          <span class="column-count text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded-full px-2 py-0.5"><%= orders.count %></span>
        </div>
        <% if status == "inbox" %>
          <%= link_to inbox_path, class: "text-xs text-accent hover:underline" do %>
            <i class="lni lni-envelope text-sm"></i>
          <% end %>
        <% end %>
      </div>

      <!-- Cards Container -->
      <div class="kanban-cards flex flex-col gap-3 flex-1 min-h-[60px] p-2 bg-gray-100 dark:bg-gray-700/50 rounded-xl"
           data-status="<%= status %>"
           id="column-<%= status %>">
        <% orders.each do |order| %>
          <%= render "kanban/card", order: order, prev_status: prev_stat, next_status: next_stat %>
        <% end %>

        <!-- Empty state -->
        <div class="empty-state flex-1 flex items-center justify-center text-xs text-gray-400 dark:text-gray-500 py-8<%= orders.any? ? ' hidden' : '' %>">
          <div class="text-center">
            <i class="lni lni-inbox text-2xl block mb-1 opacity-50"></i>
            No orders
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const CSRF = document.querySelector('meta[name="csrf-token"]').content;

  // 컬럼 카운트 배지 업데이트
  function updateCounts() {
    document.querySelectorAll('.kanban-column').forEach(function(col) {
      const count = col.querySelectorAll('[data-order-id]').length;
      const badge = col.querySelector('.column-count');
      if (badge) badge.textContent = count;

      // 빈 칼럼 empty-state 토글
      const cards  = col.querySelector('.kanban-cards');
      const empty  = col.querySelector('.empty-state');
      if (!cards || !empty) return;
      const hasCards = cards.querySelectorAll('[data-order-id]').length > 0;
      empty.style.display = hasCards ? 'none' : '';
    });
  }

  // 드래그 중 타겟 컬럼 하이라이트
  function highlightColumn(el, on) {
    if (!el) return;
    el.classList.toggle('ring-2', on);
    el.classList.toggle('ring-accent', on);
    el.classList.toggle('ring-inset', on);
    el.classList.toggle('bg-blue-50/60', on);
    el.classList.toggle('dark:bg-blue-900/20', on);
  }

  // 이동 성공 토스트
  function showToast(msg, ok) {
    const old = document.getElementById('kanban-toast');
    if (old) old.remove();
    const t = document.createElement('div');
    t.id = 'kanban-toast';
    t.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-4 py-2.5 rounded-xl text-sm font-medium shadow-lg transition-all duration-300 flex items-center gap-2 '
      + (ok ? 'bg-green-500 text-white' : 'bg-red-500 text-white');
    t.innerHTML = (ok
      ? '<svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>'
      : '<svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>')
      + msg;
    document.body.appendChild(t);
    setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 2500);
  }

  // ── FR-01: 필터 ──────────────────────────────────────────────
  const filterAssignee = document.getElementById('filter-assignee');
  const filterKeyword  = document.getElementById('filter-keyword');
  const filterReset    = document.getElementById('filter-reset');
  const meId           = '<%= current_user.id %>';
  let   activePriority = '';
  let   activeDue      = '';

  function setActiveToggle(btnClass, activeVal) {
    document.querySelectorAll('.' + btnClass).forEach(function(btn) {
      const on = btn.dataset.value === activeVal;
      btn.classList.toggle('bg-accent',            on);
      btn.classList.toggle('text-white',           on);
      btn.classList.toggle('bg-white',            !on);
      btn.classList.toggle('dark:bg-gray-700',    !on);
      btn.classList.toggle('text-gray-600',       !on);
      btn.classList.toggle('dark:text-gray-300',  !on);
    });
  }

  function applyFilters() {
    const assigneeVal = filterAssignee.value;
    const keyword     = filterKeyword.value.toLowerCase().trim();
    const anyActive   = assigneeVal || activePriority || activeDue || keyword;

    document.querySelectorAll('[data-order-id]').forEach(function(card) {
      const assigneeIds = (card.dataset.assigneeIds || '').split(',').filter(Boolean);
      const assigneeOk  = !assigneeVal ? true
        : assigneeVal === 'me' ? assigneeIds.includes(meId)
        : assigneeIds.includes(assigneeVal);

      const priorityOk  = !activePriority || card.dataset.priority === activePriority;

      const dueDays = parseInt(card.dataset.dueDays, 10);
      const dueOk   = !activeDue ? true
        : activeDue === 'overdue' ? dueDays < 0
        : activeDue === 'urgent'  ? (dueDays >= 0 && dueDays <= 7)
        : true;

      const text      = (card.dataset.title || '') + ' ' + (card.dataset.customer || '');
      const keywordOk = !keyword || text.toLowerCase().includes(keyword);

      card.classList.toggle('hidden', !(assigneeOk && priorityOk && dueOk && keywordOk));
    });

    filterReset.classList.toggle('hidden', !anyActive);
    updateCounts();
  }

  document.querySelectorAll('.filter-priority-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      activePriority = activePriority === btn.dataset.value ? '' : btn.dataset.value;
      setActiveToggle('filter-priority-btn', activePriority);
      applyFilters();
    });
  });

  document.querySelectorAll('.filter-due-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      activeDue = activeDue === btn.dataset.value ? '' : btn.dataset.value;
      setActiveToggle('filter-due-btn', activeDue);
      applyFilters();
    });
  });

  filterAssignee.addEventListener('change', applyFilters);
  filterKeyword.addEventListener('input', applyFilters);

  filterReset.addEventListener('click', function() {
    filterAssignee.value = '';
    filterKeyword.value  = '';
    activePriority = '';
    activeDue      = '';
    setActiveToggle('filter-priority-btn', '');
    setActiveToggle('filter-due-btn', '');
    applyFilters();
  });

  setActiveToggle('filter-priority-btn', '');
  setActiveToggle('filter-due-btn', '');

  // ── FR-02: 퀵액션 ──────────────────────────────────────────
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.quick-move-btn');
    if (!btn) return;
    e.stopPropagation();

    const orderId = btn.dataset.orderId;
    const moveTo  = btn.dataset.moveTo;
    const cardEl  = document.querySelector('[data-order-id="' + orderId + '"]');
    if (!orderId || !moveTo || !cardEl) return;

    btn.disabled = true;
    btn.classList.add('opacity-50');

    fetch('/orders/' + orderId + '/move', {
      method:  'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
      body:    JSON.stringify({ status: moveTo })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        const targetCol = document.getElementById('column-' + moveTo);
        if (targetCol) {
          targetCol.insertBefore(cardEl, targetCol.firstChild);
          updateCounts();
          const colLabel = targetCol.closest('.kanban-column')?.querySelector('.column-name')?.textContent || moveTo;
          showToast('→ ' + colLabel + ' 이동 완료', true);
        }
      } else {
        showToast('이동 실패: ' + (data.errors || []).join(', '), false);
        btn.disabled = false;
        btn.classList.remove('opacity-50');
      }
    })
    .catch(function() {
      showToast('네트워크 오류가 발생했습니다.', false);
      btn.disabled = false;
      btn.classList.remove('opacity-50');
    });
  });

  // 각 컬럼에 SortableJS 적용
  document.querySelectorAll('.kanban-cards').forEach(function(column) {
    new Sortable(column, {
      group:       'kanban',
      animation:   180,
      easing:      'cubic-bezier(0.25, 1, 0.5, 1)',
      handle:      '.drag-handle',   // 핸들 아이콘으로만 드래그
      ghostClass:  'kanban-ghost',
      dragClass:   'kanban-dragging',
      chosenClass: 'kanban-chosen',

      onStart: function(evt) {
        document.querySelectorAll('.kanban-cards').forEach(function(c) {
          if (c !== evt.from) highlightColumn(c, true);
        });
      },

      onEnd: function(evt) {
        // 모든 하이라이트 해제
        document.querySelectorAll('.kanban-cards').forEach(function(c) {
          highlightColumn(c, false);
        });

        const cardEl   = evt.item;
        const orderId  = cardEl.dataset.orderId;
        const newCol   = evt.to;
        const oldCol   = evt.from;
        const newStatus = newCol.dataset.status;
        const oldStatus = oldCol.dataset.status;

        // 같은 컬럼 내 재정렬 → 서버 호출 불필요
        if (newStatus === oldStatus) return;

        // 낙관적 UI: 카드 컬럼명 배지 즉시 업데이트
        const statusBadge = cardEl.querySelector('.card-status-badge');
        if (statusBadge) statusBadge.textContent = newCol.closest('.kanban-column').querySelector('.column-name')?.textContent || '';

        updateCounts();

        fetch('/orders/' + orderId + '/move', {
          method:  'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          body:    JSON.stringify({ status: newStatus })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            const colLabel = newCol.closest('.kanban-column').querySelector('.column-name')?.textContent || newStatus;
            showToast('→ ' + colLabel + ' 이동 완료', true);
          } else {
            // 실패 시 원위치 복원
            if (evt.oldIndex < oldCol.children.length) {
              oldCol.insertBefore(cardEl, oldCol.children[evt.oldIndex]);
            } else {
              oldCol.appendChild(cardEl);
            }
            updateCounts();
            showToast('이동 실패: ' + (data.errors || []).join(', '), false);
          }
        })
        .catch(function() {
          oldCol.insertBefore(cardEl, oldCol.children[evt.oldIndex] || null);
          updateCounts();
          showToast('네트워크 오류가 발생했습니다.', false);
        });
      }
    });
  });
});
</script>

<style>
.kanban-ghost    { opacity: 0.35; border: 2px dashed #00A1E0 !important; background: #e0f2fe !important; border-radius: 0.5rem; }
.kanban-dragging { opacity: 0.95; transform: rotate(1.5deg) scale(1.03); box-shadow: 0 12px 32px rgba(0,0,0,0.18) !important; }
.kanban-chosen   { box-shadow: 0 0 0 2px #00A1E0; }
.drag-handle     { cursor: grab; touch-action: none; }
.drag-handle:active { cursor: grabbing; }
</style>
