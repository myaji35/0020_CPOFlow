#!/bin/bash
set -e

SERVER_IP="158.247.235.31"
APP_NAME="cpoflow"
HOST="${APP_NAME}.${SERVER_IP}.nip.io"
SSH_USER="root"
SSH_HOST="${SSH_USER}@${SERVER_IP}"
REMOTE_BUILD_DIR="/var/${APP_NAME}/build"
ENV_FILE="/root/.kamal/apps/${APP_NAME}/env/roles/web.env"
NETWORK="kamal"
VOLUME="${APP_NAME}_storage:/rails/storage"

# 시작 시간 기록
START_TIME=$SECONDS

FULL_BUILD=false
RESTART_ONLY=false

while [[ "$#" -gt 0 ]]; do
  case $1 in
    --full) FULL_BUILD=true; shift ;;
    --restart) RESTART_ONLY=true; shift ;;
    *) echo "알 수 없는 옵션: $1"; exit 1 ;;
  esac
done

# 로컬 변경사항 확인
if ! git diff-index --quiet HEAD --; then
  echo "⚠️ 경고: 커밋되지 않은 변경사항이 있습니다. git archive는 HEAD 기준 커밋된 코드만 가져갑니다!"
  echo "진행하시려면 3초를 기다립니다..."
  sleep 3
fi

if [ "$RESTART_ONLY" = true ]; then
  echo "🚀 컨테이너만 재시작합니다..."
  REV=$(ssh $SSH_HOST "docker ps --filter label=service=$APP_NAME --format '{{.Image}}' | head -1 | cut -d: -f2")
  if [ -z "$REV" ] || [ "$REV" == "latest" ]; then
    REV=$(ssh $SSH_HOST "docker config ls 2>/dev/null || true && docker images $APP_NAME --format '{{.Tag}}' | grep -v latest | head -1")
    if [ -z "$REV" ]; then
      echo "❌ 가동 중인 컨테이너 버전을 찾을 수 없습니다."
      exit 1
    fi
  fi
  echo "현재 버전: $REV"
else
  REV=$(git rev-parse --short HEAD)
  echo "🚀 배포 시작 (버전: $REV) ..."
  
  echo "📦 1. 소스 코드 전송 중 (git archive)..."
  ssh $SSH_HOST "mkdir -p $REMOTE_BUILD_DIR"
  git archive --format=tar.gz HEAD | ssh $SSH_HOST "tar -xzf - -C $REMOTE_BUILD_DIR"
  
  echo "🔨 2. Docker 이미지 빌드 (서버 자체 빌드 🚀)..."
  BUILD_ARGS="--build-arg BUILDKIT_INLINE_CACHE=1"
  if [ "$FULL_BUILD" = true ]; then
    BUILD_ARGS="$BUILD_ARGS --no-cache"
  fi
  
  # 원격 서버에서 직접 Docker를 빌드합니다. (캐시 적극 활용)
  ssh $SSH_HOST "cd $REMOTE_BUILD_DIR && docker buildx build $BUILD_ARGS -t $APP_NAME:latest -t $APP_NAME:$REV ."
fi

if [ "$RESTART_ONLY" = false ]; then
  echo "🗄️ 3. DB 마이그레이션..."
  ssh $SSH_HOST "docker run --rm --network $NETWORK --env-file $ENV_FILE -v $VOLUME $APP_NAME:$REV bin/rails db:migrate"
fi

echo "🟢 4. 새 애플리케이션 시작..."
TIMESTAMP=$(date +%s)
CONTAINER_NAME="${APP_NAME}-web-${REV}-${TIMESTAMP}"

ssh $SSH_HOST "docker run -d --name $CONTAINER_NAME --network $NETWORK --env-file $ENV_FILE -v $VOLUME -l service=$APP_NAME -l role=web $APP_NAME:$REV"

echo "⏳ 컨테이너 부팅 대기 (15초)..."
sleep 15

echo "🔄 5. Kamal-Proxy 라우팅 등록..."
ssh $SSH_HOST "docker exec kamal-proxy kamal-proxy deploy ${APP_NAME}-web --target=\"$CONTAINER_NAME:3000\" --host=\"$HOST\" --deploy-timeout=\"120s\""

echo "⚙️  6. Nginx 설정 점검 (kamal-proxy:3030 포워딩)..."
ssh $SSH_HOST "
mkdir -p /etc/nginx/sites-available /etc/nginx/sites-enabled
cat << 'EOF' > /etc/nginx/sites-available/$APP_NAME
server {
    listen 80;
    server_name $HOST;
    location / {
        proxy_pass http://127.0.0.1:3030;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
}
EOF
ln -sf /etc/nginx/sites-available/$APP_NAME /etc/nginx/sites-enabled/
systemctl reload nginx || true
"

echo "🧹 7. 이전 컨테이너 정리..."
ssh $SSH_HOST "
  OLD_CONTAINERS=\$(docker ps -q --filter label=service=$APP_NAME --filter label=role=web | grep -v \$(docker inspect -f '{{.Id}}' $CONTAINER_NAME | cut -c1-12))
  if [ ! -z \"\$OLD_CONTAINERS\" ]; then
    echo \"종료 중 컨테이너: \$OLD_CONTAINERS\"
    docker stop -t 10 \$OLD_CONTAINERS && docker rm \$OLD_CONTAINERS
  else
    echo \"종료할 이전 컨테이너가 없습니다.\"
  fi
"

echo "🗑️ 8. 오래된 Docker 이미지 정리 (최근 3개 유지)..."
ssh $SSH_HOST "
  IMAGE_IDS=\$(docker images $APP_NAME --format '{{.ID}}' | awk '!seen[\$0]++')
  let count=0
  for id in \$IMAGE_IDS; do
    count=\$((count+1))
    if [ \$count -gt 3 ]; then
      docker rmi -f \$id 2>/dev/null || true
    fi
  done
  docker image prune -f
"

ELAPSED=$(( SECONDS - START_TIME ))
MINUTES=$(( ELAPSED / 60 ))
SECS=$(( ELAPSED % 60 ))
echo "==========================================="
echo "✅ 배포 완료! 소요 시간: ${MINUTES}분 ${SECS}초"
echo "👉 접속 URL: http://$HOST"
echo "==========================================="
